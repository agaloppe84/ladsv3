<% family = local_assigns.fetch(:family) %>
<% pattern = local_assigns.fetch(:pattern).to_s %>
<% seed = pattern.bytes.sum %>
<% active = seed % 5 %>
<% tone = ->(index) { index == active ? "bg-[#84cc16]" : "bg-white" } %>
<% muted = ->(index) { index == active ? "bg-[#84cc16]" : "bg-[#e4e8dc]" } %>

<% case family %>
<% when :global_portal %>
  <div class="grid gap-2">
    <span class="h-7 rounded bg-[#111510]"></span>
    <div class="grid grid-cols-[.34fr_1fr] gap-2">
      <div class="grid gap-2 rounded bg-white p-2">
        <% 4.times do |index| %>
          <span class="rounded <%= muted.call(index) %>"></span>
        <% end %>
      </div>
      <div class="grid grid-cols-4 gap-2">
        <% 8.times do |index| %>
          <span class="rounded <%= tone.call(index) %>"></span>
        <% end %>
      </div>
    </div>
  </div>
<% when :global_funnel %>
  <div class="grid grid-cols-[.32fr_1fr] gap-2">
    <div class="grid gap-2">
      <% 5.times do |index| %>
        <span class="rounded <%= muted.call(index) %>"></span>
      <% end %>
    </div>
    <div class="grid gap-2 rounded bg-white p-2">
      <span class="h-5 rounded bg-[#111510]"></span>
      <div class="grid grid-cols-2 gap-2">
        <span class="h-10 rounded border border-[#d8dccf] bg-[#f7f8f1]"></span>
        <span class="h-10 rounded border border-[#d8dccf] bg-[#f7f8f1]"></span>
      </div>
      <span class="h-10 rounded border border-[#d8dccf] bg-[#f7f8f1]"></span>
      <span class="h-7 w-1/3 rounded bg-[#84cc16]"></span>
    </div>
  </div>
<% when :global_proof %>
  <div class="grid gap-2">
    <div class="grid grid-cols-5 gap-2">
      <% 5.times do |index| %>
        <span class="h-12 rounded <%= tone.call(index) %>"></span>
      <% end %>
    </div>
    <div class="grid grid-cols-[1fr_.42fr] gap-2">
      <span class="rounded bg-[#cfd8e3]"></span>
      <div class="grid content-center gap-2 rounded bg-[#111510] p-2">
        <span class="h-4 rounded bg-[#84cc16]"></span>
        <span class="h-6 rounded bg-white"></span>
        <span class="h-3 rounded bg-white/35"></span>
      </div>
    </div>
  </div>
<% when :global_catalogue %>
  <div class="grid grid-cols-[.28fr_1fr] gap-2">
    <div class="grid gap-2 rounded bg-white p-2">
      <span class="h-4 rounded bg-[#111510]"></span>
      <% 5.times do |index| %>
        <span class="rounded <%= muted.call(index) %>"></span>
      <% end %>
    </div>
    <div class="grid gap-2">
      <span class="h-8 rounded bg-[#111510]"></span>
      <div class="grid grid-cols-4 gap-2">
        <% 8.times do |index| %>
          <span class="rounded <%= tone.call(index) %>"></span>
        <% end %>
      </div>
    </div>
  </div>
<% when :global_story %>
  <div class="grid grid-cols-[.45fr_1fr] gap-2">
    <div class="grid gap-2 rounded bg-[#111510] p-2">
      <span class="h-4 rounded bg-[#84cc16]"></span>
      <span class="h-8 rounded bg-white"></span>
      <span class="h-4 rounded bg-white/35"></span>
      <span class="h-16 rounded bg-white/15"></span>
    </div>
    <div class="grid gap-2">
      <span class="h-16 rounded bg-[#cfd8e3]"></span>
      <div class="grid grid-cols-3 gap-2">
        <% 6.times do |index| %>
          <span class="rounded <%= tone.call(index) %>"></span>
        <% end %>
      </div>
    </div>
  </div>
<% when :global_process %>
  <div class="grid gap-2">
    <span class="h-7 rounded bg-[#111510]"></span>
    <div class="grid grid-cols-5 items-center gap-2">
      <% 5.times do |index| %>
        <span class="h-8 rounded-full <%= muted.call(index) %>"></span>
      <% end %>
    </div>
    <div class="grid grid-cols-5 gap-2">
      <% 5.times do |index| %>
        <span class="h-14 rounded <%= tone.call(index) %>"></span>
      <% end %>
    </div>
  </div>
<% when :section_hero %>
  <div class="grid grid-cols-[1fr_.48fr] gap-2">
    <div class="grid content-center gap-2 rounded <%= active.even? ? "bg-[#84cc16]" : "bg-[#111510]" %> p-3">
      <span class="h-3 w-1/4 rounded bg-black/35"></span>
      <span class="h-8 rounded <%= active.even? ? "bg-black/70" : "bg-white" %>"></span>
      <span class="h-3 rounded <%= active.even? ? "bg-black/25" : "bg-white/35" %>"></span>
    </div>
    <span class="rounded bg-[#cfd8e3]"></span>
  </div>
<% when :section_grid %>
  <div class="grid gap-2">
    <span class="h-6 w-1/2 rounded bg-[#111510]"></span>
    <div class="grid grid-cols-4 gap-2">
      <% 8.times do |index| %>
        <span class="h-14 rounded <%= tone.call(index) %>"></span>
      <% end %>
    </div>
  </div>
<% when :section_strip %>
  <div class="grid content-center gap-2 rounded bg-white p-2">
    <div class="grid grid-cols-[1fr_auto] gap-3">
      <div class="grid gap-2">
        <span class="h-5 rounded bg-[#111510]"></span>
        <span class="h-3 w-2/3 rounded bg-[#d8dccf]"></span>
      </div>
      <span class="h-10 w-24 rounded bg-[#84cc16]"></span>
    </div>
    <div class="grid grid-cols-4 gap-2">
      <% 4.times do |index| %>
        <span class="h-10 rounded <%= muted.call(index) %>"></span>
      <% end %>
    </div>
  </div>
<% when :section_process %>
  <div class="grid grid-cols-[.3fr_1fr] gap-2">
    <span class="rounded bg-[#84cc16]"></span>
    <div class="grid gap-2">
      <% 4.times do |index| %>
        <div class="grid grid-cols-[2rem_1fr] gap-2 rounded bg-white p-2">
          <span class="h-7 w-7 rounded-full <%= muted.call(index) %>"></span>
          <span class="self-center h-4 rounded bg-[#111510]"></span>
        </div>
      <% end %>
    </div>
  </div>
<% when :section_content %>
  <div class="grid grid-cols-[.42fr_1fr] gap-2">
    <div class="grid content-center gap-2">
      <span class="h-4 w-1/3 rounded bg-[#84cc16]"></span>
      <span class="h-7 rounded bg-[#111510]"></span>
      <span class="h-3 rounded bg-[#d8dccf]"></span>
    </div>
    <div class="grid gap-2">
      <% 4.times do |index| %>
        <span class="rounded <%= tone.call(index) %>"></span>
      <% end %>
    </div>
  </div>
<% when :micro_card %>
  <div class="grid content-center">
    <div class="grid max-w-[180px] gap-2 rounded bg-white p-2">
      <span class="h-16 rounded bg-[#cfd8e3]"></span>
      <span class="h-4 rounded bg-[#111510]"></span>
      <span class="h-3 w-2/3 rounded bg-[#d8dccf]"></span>
      <span class="h-6 w-1/2 rounded bg-[#84cc16]"></span>
    </div>
  </div>
<% when :micro_row %>
  <div class="grid content-center gap-2">
    <% 3.times do |index| %>
      <div class="grid grid-cols-[2rem_1fr_auto] gap-2 rounded bg-white p-2">
        <span class="h-8 w-8 rounded <%= muted.call(index) %>"></span>
        <span class="self-center h-4 rounded bg-[#111510]"></span>
        <span class="h-7 w-12 rounded border border-[#d8dccf]"></span>
      </div>
    <% end %>
  </div>
<% when :micro_chip %>
  <div class="grid content-center gap-3">
    <span class="h-5 w-1/2 rounded bg-[#111510]"></span>
    <div class="flex flex-wrap gap-2">
      <% 7.times do |index| %>
        <span class="h-8 rounded-full <%= index == active ? "w-28 bg-[#84cc16]" : "w-20 bg-white" %>"></span>
      <% end %>
    </div>
  </div>
<% when :micro_notice %>
  <div class="grid content-center gap-2 rounded <%= active.even? ? "bg-[#84cc16]" : "bg-white" %> p-3">
    <span class="h-4 w-1/3 rounded bg-black/45"></span>
    <span class="h-6 rounded bg-[#111510]"></span>
    <span class="h-3 rounded bg-black/25"></span>
    <div class="grid grid-cols-[1fr_auto] gap-2">
      <span class="h-3 self-center rounded bg-black/15"></span>
      <span class="h-7 w-20 rounded border border-black/20"></span>
    </div>
  </div>
<% else %>
  <div class="grid grid-cols-3 gap-2">
    <span class="rounded bg-white"></span>
    <span class="rounded bg-[#84cc16]"></span>
    <span class="rounded bg-white"></span>
  </div>
<% end %>
