<% composition = local_assigns.fetch(:composition) %>
<% blueprint = local_assigns.fetch(:blueprint) %>
<% recipe_rows = @home_test.full_recipe_rows(composition) %>
<% product_families = blueprint.product_families.map { |family| family.merge(path: public_v2_categories_path) } %>
<% media_items = [
  { image: blueprint.hero.media[:image], alt: blueprint.hero.media[:alt], caption: "Showroom conseil", ratio: :wide },
  { image: blueprint.showroom.media[:image], alt: blueprint.showroom.media[:alt], caption: "Finitions visibles", ratio: :category },
  { image: "magasin-02.jpeg", alt: "Stores et finitions exposes", caption: "Comparer les options", ratio: :category }
] %>
<% comparison_items = [
  { kicker: "Soleil", title: "Stores et pergolas", text: "Ombre, chaleur, terrasse.", points: ["toile", "motorisation", "pose"] },
  { kicker: "Fermeture", title: "Volets et garage", text: "Confort, securite, usage.", points: ["mesure", "finition", "SAV"] },
  { kicker: "Confort", title: "Moustiquaires", text: "Ventiler sans subir.", points: ["cadre", "usage", "pose"] }
] %>

<article id="home-full-<%= composition.code.downcase %>" class="grid min-w-0 gap-4 overflow-hidden rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 shadow-sm min-[821px]:p-5">
  <header class="grid min-w-0 gap-3 min-[821px]:grid-cols-[minmax(0,1fr)_auto] min-[821px]:items-start">
    <div class="grid min-w-0 gap-1">
      <p class="pv2-eyebrow"><%= composition.code %> - home complete</p>
      <h2 class="m-0 text-[1.2rem] font-black leading-tight min-[821px]:text-[1.55rem]"><%= composition.name %></h2>
      <p class="m-0 max-w-[88ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]"><%= composition.strategy %></p>
    </div>

    <div class="flex max-w-full flex-wrap gap-2">
      <% composition.layout_codes.each do |code| %>
        <span class="rounded-full border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] px-2.5 py-1 font-mono text-[0.65rem] font-black uppercase text-[var(--pv2-accent)]"><%= code %></span>
      <% end %>
    </div>
  </header>

  <section class="grid min-w-0 gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(260px,.34fr)]">
    <div class="grid min-w-0 gap-2 min-[821px]:grid-cols-3">
      <% recipe_rows.each do |label, value| %>
        <div class="min-w-0">
          <span class="block font-mono text-[0.62rem] font-black uppercase leading-4 text-[var(--pv2-accent)]"><%= label %></span>
          <strong class="mt-1 block text-[0.78rem] font-extrabold leading-5 text-[var(--pv2-home-text)]"><%= value %></strong>
        </div>
      <% end %>
    </div>

    <div class="flex min-w-0 flex-wrap content-start gap-2">
      <% composition.bricks.each do |brick| %>
        <span class="rounded-full border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] px-2.5 py-1 text-[0.66rem] font-extrabold leading-5 text-[var(--pv2-home-muted)]"><%= brick %></span>
      <% end %>
    </div>
  </section>

  <div class="grid min-w-0 gap-4 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[821px]:p-4">
    <% case composition.pattern %>
    <% when :quote_studio %>
      <section class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(300px,420px)]">
        <%= render PublicV2::Ui::SummaryBoxComponent.new(
          kicker: blueprint.hero.kicker,
          title: composition.hero_title,
          text: composition.hero_text,
          items: ["Stores, volets, pergolas.", "Conseil, pose, suivi local.", "Premier retour en 48h."],
          variant: :dark,
          classes: "h-full"
        ) %>

        <aside class="grid min-w-0 content-start gap-3">
          <div class="pv2-home-mini-media h-[190px]">
            <%= render PublicV2::Ui::MediaFrameComponent.new(
              image: blueprint.hero.media[:image],
              alt: blueprint.hero.media[:alt],
              ratio: :wide,
              loading: "eager",
              classes: "h-full min-h-full"
            ) %>
          </div>

          <%= render PublicV2::Ui::QuoteIntakeComponent.new(
            kicker: "Devis",
            title: "Cadrage en 4 points.",
            text: "Court, utile, sans tunnel.",
            steps: blueprint.quote_journey,
            primary_label: "Demander un devis",
            primary_path: public_v2_new_quote_path,
            secondary_label: "Voir les familles",
            secondary_path: public_v2_categories_path,
            variant: :compact
          ) %>
        </aside>
      </section>

      <%= render PublicV2::Ui::TrustClusterComponent.new(
        kicker: "Preuves avant action",
        title: "Ce qui rassure avant de demander un prix.",
        items: blueprint.proofs,
        variant: :compact
      ) %>

      <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.45fr)_minmax(0,.55fr)]">
        <%= render PublicV2::Ui::IconListComponent.new(
          label: "Besoins",
          items: blueprint.needs,
          variant: :soft
        ) %>

        <%= render PublicV2::Ui::ProductFamilyGridComponent.new(
          label: "Familles a chiffrer",
          families: product_families,
          variant: :compact
        ) %>
      </div>

      <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.52fr)_minmax(0,.48fr)]">
        <%= render PublicV2::Ui::MediaMosaicComponent.new(
          label: "Preuve showroom",
          items: media_items,
          variant: :strip
        ) %>

        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: blueprint.final_cta.kicker,
          title: blueprint.final_cta.title,
          text: blueprint.final_cta.text,
          primary_label: "Demander un devis",
          primary_path: public_v2_new_quote_path,
          secondary_label: "Contact showroom",
          secondary_path: public_v2_contact_path,
          meta: "Direction F01 : conversion claire, photo controlee.",
          variant: :flashy
        ) %>
      </div>
    <% when :showroom_editorial %>
      <section class="grid min-w-0 gap-4 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1rem,2vw,1.6rem)]">
        <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.58fr)_minmax(0,.42fr)] min-[1121px]:items-end">
          <div class="grid min-w-0 gap-3">
            <p class="pv2-eyebrow"><%= blueprint.showroom.kicker %></p>
            <h3 class="m-0 max-w-[16ch] text-[clamp(1.9rem,3.6vw,3.35rem)] font-black leading-[1.02]"><%= composition.hero_title %></h3>
            <p class="m-0 max-w-[42ch] text-[0.98rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.hero_text %></p>
          </div>

          <%= render PublicV2::Ui::PanelComponent.new(kicker: "48h", title: "Premier retour devis.", variant: :flashy, padding: :sm, classes: "max-w-[360px] min-[1121px]:justify-self-end") do %>
            <p>Un cadrage court apres le choix.</p>
          <% end %>
        </div>

        <%= render PublicV2::Ui::MediaMosaicComponent.new(
          label: "Photo en support, pas plein ecran",
          items: media_items,
          variant: :feature
        ) %>
      </section>

      <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.45fr)_minmax(0,.55fr)]">
        <%= render PublicV2::Ui::SummaryBoxComponent.new(
          kicker: blueprint.showroom.kicker,
          title: blueprint.showroom.title,
          text: blueprint.showroom.text,
          items: blueprint.showroom.items.map { |item| "#{item[:title]} : #{item[:text]}" },
          variant: :outline,
          classes: "h-full"
        ) %>

        <%= render PublicV2::Ui::ComparisonStripComponent.new(
          label: "Comparer avant devis",
          items: comparison_items,
          variant: :soft
        ) %>
      </div>

      <%= render PublicV2::Ui::ProductFamilyGridComponent.new(
        label: "Catalogue dirige vers la demande",
        families: product_families,
        variant: :editorial
      ) %>

      <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.6fr)_minmax(270px,.4fr)]">
        <%= render PublicV2::Ui::ProcessListComponent.new(
          label: "Parcours premium",
          steps: blueprint.quote_journey,
          variant: :timeline
        ) %>

        <%= render PublicV2::Ui::QuoteIntakeComponent.new(
          kicker: "Passer au concret",
          title: "Demande lisible.",
          text: "Produit, usage, contraintes.",
          steps: blueprint.quote_journey.first(3),
          primary_label: "Demander un devis",
          primary_path: public_v2_new_quote_path,
          secondary_label: "Appeler le showroom",
          secondary_path: public_v2_contact_path,
          variant: :soft,
          classes: "h-full"
        ) %>
      </div>

      <%= render PublicV2::Ui::ActionDockComponent.new(
        kicker: "Synthese",
        title: "Une page qui vend le conseil avant le prix.",
        text: "Le devis devient la suite logique du showroom.",
        primary_label: "Demander un devis",
        primary_path: public_v2_new_quote_path,
        secondary_label: "Voir les produits",
        secondary_path: public_v2_categories_path,
        variant: :soft
      ) %>
    <% when :choice_concierge %>
      <section class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.48fr)_minmax(0,.52fr)]">
        <div class="grid min-w-0 gap-4 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1rem,2vw,1.6rem)]">
          <div class="grid min-w-0 gap-3">
            <p class="pv2-eyebrow"><%= blueprint.hero.kicker %></p>
            <h3 class="m-0 max-w-[14ch] text-[clamp(1.85rem,3.4vw,3rem)] font-black leading-[1.03]"><%= composition.hero_title %></h3>
            <p class="m-0 max-w-[40ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.hero_text %></p>
          </div>

          <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-3">
            <% blueprint.needs.each_with_index do |need, index| %>
              <%= render PublicV2::Ui::ChoiceTileComponent.new(
                kicker: need[:kicker],
                title: need[:title],
                text: need[:text],
                path: public_v2_new_quote_path,
                active: index.zero?,
                variant: index.zero? ? :flashy : :default,
                classes: "h-full"
              ) %>
            <% end %>
          </div>
        </div>

        <aside class="grid min-w-0 gap-3">
          <div class="grid min-w-0 grid-cols-[112px_minmax(0,1fr)] gap-3">
            <div class="pv2-home-mini-media h-[112px]">
              <%= render PublicV2::Ui::MediaFrameComponent.new(
                image: blueprint.hero.media[:image],
                alt: blueprint.hero.media[:alt],
                ratio: :square,
                loading: "eager",
                classes: "h-full min-h-full"
              ) %>
            </div>

            <%= render PublicV2::Ui::ActionDockComponent.new(
              kicker: "Devis",
              title: "Demande courte.",
              text: "Un besoin suffit pour commencer.",
              primary_label: "Commencer",
              primary_path: public_v2_new_quote_path,
              variant: :flashy
            ) %>
          </div>

          <%= render PublicV2::Ui::TrustClusterComponent.new(
            kicker: "Confiance",
            items: blueprint.proofs,
            variant: :soft
          ) %>
        </aside>
      </section>

      <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.6fr)_minmax(0,.4fr)]">
        <%= render PublicV2::Ui::ProductFamilyGridComponent.new(
          label: "Entrees produit",
          families: product_families,
          variant: :soft
        ) %>

        <%= render PublicV2::Ui::ProcessListComponent.new(
          label: "Du besoin au devis",
          steps: blueprint.quote_journey,
          variant: :compact
        ) %>
      </div>

      <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.42fr)_minmax(0,.58fr)]">
        <%= render PublicV2::Ui::IconListComponent.new(
          label: "Conseil, pose, suivi",
          items: blueprint.service_flow,
          variant: :default
        ) %>

        <%= render PublicV2::Ui::FaqAccordionComponent.new(
          label: "Objections a lever",
          items: blueprint.objections,
          variant: :soft
        ) %>
      </div>

      <%= render PublicV2::Ui::ActionDockComponent.new(
        kicker: blueprint.final_cta.kicker,
        title: "Un devis guide par le bon besoin.",
        text: "La page aide le visiteur a se situer avant de demander un prix.",
        primary_label: "Demander un devis",
        primary_path: public_v2_new_quote_path,
        secondary_label: "Voir les familles",
        secondary_path: public_v2_categories_path,
        variant: :soft
      ) %>
    <% end %>
  </div>
</article>
