<% title "Public V2 - Design System" %>
<% description "Laboratoire Public V2 : documentation sobre, composants reels, themes clair sombre, accents et typographies." %>

<main class="mx-auto w-full max-w-[1440px] px-[var(--p-shell-x)] py-8 pb-20 text-[var(--pv2-home-text)]">
  <div class="grid gap-6 xl:grid-cols-[230px_minmax(0,1fr)] xl:items-start">
    <aside class="hidden xl:block xl:sticky xl:top-[96px]">
      <div class="rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-3 shadow-sm">
        <p class="mb-3 font-[var(--p-font-mono)] text-[0.66rem] font-black uppercase text-[var(--pv2-accent)]">Public V2 Lab</p>
        <nav class="grid gap-1" aria-label="Sections du design system">
          <% @design_system.kit_sections.each do |section| %>
            <a class="grid grid-cols-[2rem_minmax(0,1fr)] items-center gap-2 rounded px-2 py-2 text-[0.78rem] font-bold text-[var(--pv2-home-muted)] transition hover:bg-[rgba(var(--pv2-accent-rgb),0.1)] hover:text-[var(--pv2-home-text)]" href="#<%= section[:id] %>">
              <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black text-[var(--pv2-accent)]"><%= section[:number] %></span>
              <span><%= section[:label] %></span>
            </a>
          <% end %>
        </nav>
      </div>
    </aside>

    <div class="grid min-w-0 gap-7">
      <header class="grid gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-5 min-[821px]:grid-cols-[minmax(0,1fr)_minmax(320px,0.38fr)] min-[821px]:items-center min-[1121px]:p-7">
        <div class="grid gap-3">
          <p class="font-[var(--p-font-mono)] text-[0.68rem] font-black uppercase text-[var(--pv2-accent)]">Public V2 · Design system retenu</p>
          <h1 class="max-w-[16ch] text-[1.9rem] font-black leading-[1.02] tracking-normal min-[821px]:text-[2.3rem]">Atelier Graphite, composants reels.</h1>
          <p class="max-w-[68ch] text-[0.94rem] font-semibold leading-7 text-[var(--pv2-home-muted)]">
            La page documente le systeme sans le deformer : la coquille de presentation reste sobre et majoritairement Tailwind,
            les exemples rendent directement les ViewComponents Public V2 avec leur propre API et leur propre CSS.
          </p>
        </div>

        <%= render PublicV2::Ui::SpotlightPanelComponent.new(
          kicker: "Contrat actif",
          title: "pv2-* pour le skin.",
          text: "Tailwind structure la mise en page. Themes, dark mode et accent restent pilotables depuis la navbar.",
          size: :md
        ) %>
      </header>

      <nav class="sticky top-[82px] z-20 flex gap-2 overflow-x-auto rounded-md border border-[var(--pv2-home-border)] bg-[color-mix(in_srgb,var(--pv2-home-surface)_92%,transparent)] p-2 backdrop-blur xl:hidden" aria-label="Sections du design system">
        <% @design_system.kit_sections.each do |section| %>
          <a class="shrink-0 rounded-full border border-[var(--pv2-home-border)] px-3 py-2 text-[0.72rem] font-extrabold text-[var(--pv2-home-muted)] hover:border-[rgba(var(--pv2-accent-rgb),0.34)] hover:text-[var(--pv2-home-text)]" href="#<%= section[:id] %>"><%= section[:label] %></a>
        <% end %>
      </nav>

      <section id="public-v2-kit-foundations" class="scroll-mt-28 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="font-[var(--p-font-mono)] text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]">01 · Fondations</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Tokens, palettes, typo et regles.</h2>
          <p class="max-w-[72ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">La palette dynamique controle les couleurs. Le systeme fixe surtout les surfaces, rayons, densites, contrastes et comportements responsive.</p>
        </div>

        <div class="grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
          <article class="grid gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Light</span>
            <strong class="text-[0.98rem] font-black">Fond clair technique.</strong>
            <div class="flex flex-wrap gap-2">
              <i class="h-8 w-8 rounded-full border border-[var(--pv2-home-border-strong)]" style="background:#f5f6ef"></i>
              <i class="h-8 w-8 rounded-full border border-[var(--pv2-home-border-strong)]" style="background:#e8ebe0"></i>
              <i class="h-8 w-8 rounded-full border border-[var(--pv2-home-border-strong)]" style="background:#ffffff"></i>
              <i class="h-8 w-8 rounded-full border border-[var(--pv2-home-border-strong)]" style="background:#111510"></i>
              <i class="h-8 w-8 rounded-full border border-[var(--pv2-home-border-strong)]" style="background:#84cc16"></i>
            </div>
            <p class="text-[0.82rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Light par defaut, surfaces nettes, accent dose sur CTA, labels et focus.</p>
          </article>

          <article class="grid gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[#111510] p-4 text-[#f5f6ef]">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Dark</span>
            <strong class="text-[0.98rem] font-black">Graphite secondaire.</strong>
            <div class="flex flex-wrap gap-2">
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#0d1110"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#15191d"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#1e242a"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#f5f6f1"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#84cc16"></i>
            </div>
            <p class="text-[0.82rem] font-semibold leading-6 text-white/70">Contraste confortable, meme logique d'accent et pas d'effet dashboard.</p>
          </article>

          <article class="grid gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Typo</span>
            <strong class="text-[1.35rem] font-black leading-tight">H1 public · 2rem</strong>
            <b class="text-[1.02rem] font-black leading-tight">H2 section · 1.12rem</b>
            <p class="text-[0.82rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Body 0.86-0.98rem, line-height 1.5 a 1.64, labels mono compacts.</p>
          </article>

          <article class="grid gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Regles</span>
            <ul class="m-0 grid gap-2 pl-4 text-[0.8rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">
              <li>Rayons 6 a 8px, sauf pills.</li>
              <li>Rail accent sur les sections fortes.</li>
              <li>Images en ratios stables.</li>
              <li>Mobile en pile simple, CTA lisibles.</li>
              <li>Pas de surcouche demo sur les composants.</li>
            </ul>
          </article>
        </div>

        <div class="mt-4 grid gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
          <div class="grid gap-1">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Accent fixe</span>
            <p class="m-0 max-w-[70ch] text-[0.82rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Warm System V9 garde un accent chaud unique. Les variantes viennent maintenant de la densite, des surfaces, des composants et du mode clair/sombre.</p>
          </div>
          <div class="grid gap-3 min-[821px]:grid-cols-3">
            <span class="grid gap-2 rounded border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-3 text-[0.72rem] font-extrabold text-[var(--pv2-home-muted)]">
              <i class="h-10 rounded" style="background:var(--pv2-accent)"></i>
              <em class="not-italic">Accent chaud</em>
              <strong class="font-[var(--p-font-mono)] text-[0.68rem] uppercase text-[var(--pv2-home-text)]">#ff3d12</strong>
            </span>
            <span class="grid gap-2 rounded border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-3 text-[0.72rem] font-extrabold text-[var(--pv2-home-muted)]">
              <i class="h-10 rounded border border-[var(--pv2-accent)]" style="background:var(--p-accent-soft)"></i>
              <em class="not-italic">Accent attenue</em>
              <strong class="font-[var(--p-font-mono)] text-[0.68rem] uppercase text-[var(--pv2-home-text)]">#fff0e8</strong>
            </span>
            <span class="grid gap-2 rounded border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-3 text-[0.72rem] font-extrabold text-[var(--pv2-home-muted)]">
              <i class="h-10 rounded border" style="background:var(--pv2-home-bg); border-color:var(--p-accent-border)"></i>
              <em class="not-italic">Bord accent</em>
              <strong class="font-[var(--p-font-mono)] text-[0.68rem] uppercase text-[var(--pv2-home-text)]">#ffc3ad</strong>
            </span>
          </div>
        </div>
      </section>

      <section id="public-v2-kit-layout" class="scroll-mt-28 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="font-[var(--p-font-mono)] text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]">02 · Layout</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Shell, hero, medias, CTA et footer.</h2>
          <p class="max-w-[72ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Les exemples sont des cadres neutres. Le style visible a l'interieur vient des composants eux-memes.</p>
        </div>

        <div class="grid gap-4 min-[1121px]:grid-cols-2">
          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[821px]:p-4">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">HeroComponent</span>
            <%= render PublicV2::Content::HeroComponent.new(
              kicker: @design_system.featured_category&.name || @design_system.fallback_category_name,
              title: @design_system.featured_product&.name || @design_system.fallback_product_name,
              text: "Hero compact, rail accent, titre court, texte utile et panneau de preuve.",
              panel_label: "Preuve",
              panel_value: "48h",
              panel_text: "Premier retour devis."
            ) %>
          </article>

          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[821px]:p-4">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">MediaFrameComponent + contenu</span>
            <div class="grid gap-4 min-[821px]:grid-cols-[minmax(0,0.58fr)_minmax(0,0.42fr)] min-[821px]:items-center">
              <div class="min-h-[220px] overflow-hidden rounded-md">
                <%= render PublicV2::Ui::MediaFrameComponent.new(image: @design_system.featured_image, fallback: "magasin-04.jpeg", alt: "Showroom Les Artisans du Store") %>
              </div>
              <div class="grid gap-2">
                <p class="pv2-eyebrow">Showroom</p>
                <h3 class="text-[1rem] font-black">Voir, toucher, comparer.</h3>
                <p class="text-[0.84rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Bloc editorial court pour contextualiser le metier sans gonfler les pages.</p>
              </div>
            </div>
          </article>

          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[821px]:p-4">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">CtaBandComponent</span>
            <%= render PublicV2::Content::CtaBandComponent.new(
              kicker: "Besoin d'aide ?",
              title: "Envoyez les premieres informations.",
              action_label: "Demander un devis",
              action_path: public_v2_new_quote_path
            ) %>
          </article>

          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[821px]:p-4">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">PartnersComponent</span>
            <%= render PublicV2::Content::PartnersComponent.new(
              text: "Grille responsive, logos sobres et accent au survol pour les marques de reference."
            ) %>
          </article>

          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[821px]:col-span-2 min-[821px]:p-4">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">FooterComponent</span>
            <%= render PublicV2::Layout::FooterComponent.new(
              eyebrow: "Les Artisans du Store",
              title: "Showroom de L'Arbresle.",
              text: "Coordonnees, horaires et liens utiles en bas de page."
            ) %>
          </article>
        </div>
      </section>

      <section id="public-v2-kit-navigation" class="scroll-mt-28 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="font-[var(--p-font-mono)] text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]">03 · Navigation</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Navbar, breadcrumb et controles.</h2>
          <p class="max-w-[72ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">La navbar reelle garde l'etat actif. Cette page ajoute seulement une navigation laterale dediee au design system.</p>
        </div>

        <div class="grid gap-4 min-[1121px]:grid-cols-3">
          <article class="min-w-0 overflow-visible rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[1121px]:col-span-3">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">NavbarComponent</span>
            <%= render PublicV2::Layout::NavbarComponent.new(
              items: @design_system.nav_items,
              phone: "04 74 01 05 11",
              show_mode_toggle: false,
              active_key: :products,
              classes: "!static rounded-md border border-[var(--pv2-home-border)]"
            ) %>
          </article>

          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">BreadcrumbComponent</span>
            <%= render PublicV2::Ui::BreadcrumbComponent.new(
              items: [
                { label: "Accueil", path: public_v2_home_path },
                { label: "Produits", path: public_v2_categories_path },
                { label: @design_system.featured_category&.name || @design_system.fallback_category_name }
              ],
              label: "Demo breadcrumb"
            ) %>
          </article>

          <article class="grid min-w-0 gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">DropdownComponent</span>
            <%= render PublicV2::Ui::DropdownComponent.new(label: "Actions exemple", align: :left, width: :sm, trigger_classes: "min-w-[128px] gap-2 px-3") do |dropdown| %>
              <% dropdown.with_trigger do %>
                <span>Actions</span>
                <span aria-hidden="true">+</span>
              <% end %>
              <% dropdown.with_panel do %>
                <div class="grid gap-2 text-[0.82rem] font-bold text-[var(--pv2-home-muted)]">
                  <button type="button" class="rounded border border-[var(--pv2-home-border)] px-3 py-2 text-left hover:border-[rgba(var(--pv2-accent-rgb),0.34)] hover:text-[var(--pv2-home-text)]">Voir la categorie</button>
                  <button type="button" class="rounded border border-[var(--pv2-home-border)] px-3 py-2 text-left hover:border-[rgba(var(--pv2-accent-rgb),0.34)] hover:text-[var(--pv2-home-text)]">Preparer un devis</button>
                </div>
              <% end %>
            <% end %>
          </article>

          <article class="grid min-w-0 gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Segmented</span>
            <div class="flex flex-wrap gap-2">
              <button type="button" class="rounded-full border border-[var(--pv2-accent)] bg-[var(--pv2-accent)] px-3 py-2 text-[0.78rem] font-black text-[var(--pv2-accent-text)]">Stores</button>
              <button type="button" class="rounded-full border border-[var(--pv2-home-border)] px-3 py-2 text-[0.78rem] font-extrabold text-[var(--pv2-home-muted)]">Volets</button>
              <button type="button" class="rounded-full border border-[var(--pv2-home-border)] px-3 py-2 text-[0.78rem] font-extrabold text-[var(--pv2-home-muted)]">Portes</button>
            </div>
          </article>

          <article class="grid min-w-0 gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">Pagination</span>
            <div class="flex flex-wrap gap-2">
              <button type="button" class="grid h-9 w-9 place-items-center rounded-full border border-[var(--pv2-home-border)] text-[var(--pv2-home-muted)]">Prev</button>
              <button type="button" class="grid h-9 min-w-9 place-items-center rounded-full border border-[var(--pv2-accent)] bg-[var(--pv2-accent)] px-3 font-black text-[var(--pv2-accent-text)]">1</button>
              <button type="button" class="grid h-9 min-w-9 place-items-center rounded-full border border-[var(--pv2-home-border)] px-3 font-black text-[var(--pv2-home-muted)]">2</button>
              <button type="button" class="grid h-9 w-9 place-items-center rounded-full border border-[var(--pv2-home-border)] text-[var(--pv2-home-muted)]">Next</button>
            </div>
          </article>
        </div>
      </section>

      <section id="public-v2-kit-content" class="scroll-mt-28 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="font-[var(--p-font-mono)] text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]">04 · Contenu</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Cards, panels, listes, stats et badges.</h2>
          <p class="max-w-[72ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Ces composants couvrent home, categories, contact, reassurance et les futures sections repetables.</p>
        </div>

        <div class="grid gap-4 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-3">
          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4 min-[1121px]:col-span-3">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">PanelComponent · variantes</span>
            <div class="grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
              <% [
                [:default, "Default", "Surface neutre pour contenu courant."],
                [:accent, "Accent", "Bord gauche discret pour attirer l'oeil."],
                [:soft, "Soft", "Accent attenue dans la surface."],
                [:rail, "Rail", "Signal fort mais encore sobre."],
                [:elevated, "Elevated", "Surface avec ombre legere."],
                [:outline, "Outline", "Bloc transparent pour zones calmes."],
                [:inset, "Inset", "Fond rentrant pour details techniques."],
                [:flashy, "Flashy", "Accent plein pour message court."]
              ].each do |variant, title, text| %>
                <%= render PublicV2::Ui::PanelComponent.new(kicker: variant.to_s, title: title, text: text, variant: variant, padding: :sm) do %>
                  <p>Panel `width: 100%`, layout gere par le parent.</p>
                <% end %>
              <% end %>
            </div>
          </article>

          <article class="min-w-0 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4 min-[1121px]:col-span-3">
            <span class="mb-3 block font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]">ButtonComponent · tailles et formes</span>
            <div class="grid gap-4 min-[821px]:grid-cols-3">
              <div class="grid gap-2">
                <strong class="text-[0.82rem] font-black">Tailles</strong>
                <div class="flex flex-wrap gap-2">
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Petit", path: "#", variant: :secondary, size: :sm) %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Standard", path: "#", variant: :primary, size: :md) %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Large", path: "#", variant: :secondary, size: :lg) %>
                </div>
              </div>
              <div class="grid gap-2">
                <strong class="text-[0.82rem] font-black">Formes</strong>
                <div class="flex flex-wrap gap-2">
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Soft", path: "#", variant: :primary, shape: :soft) %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Sharp", path: "#", variant: :secondary, shape: :sharp) %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Pill", path: "#", variant: :secondary, shape: :pill) %>
                </div>
              </div>
              <div class="grid gap-2">
                <strong class="text-[0.82rem] font-black">Variants</strong>
                <div class="flex flex-wrap gap-2">
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Primaire", path: "#", variant: :primary) %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Secondaire", path: "#", variant: :secondary) %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Danger", path: "#", variant: :danger) %>
                </div>
              </div>
            </div>
          </article>

