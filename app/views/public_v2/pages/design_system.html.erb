        </div>

        <div class="grid gap-4 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
          <button type="button" class="rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4 text-left text-[0.86rem] font-black transition hover:-translate-y-px hover:border-[rgba(var(--pv2-accent-rgb),0.38)] hover:shadow-lg">Hover lift</button>
          <div class="overflow-hidden rounded-full bg-[color-mix(in_srgb,var(--pv2-home-bg)_78%,#000)]"><i class="block h-2 w-3/5 animate-pulse rounded-full bg-[var(--pv2-accent)]"></i></div>
          <div class="grid gap-2 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4">
            <span class="border-l-2 border-[rgba(var(--pv2-accent-rgb),0.42)] pl-3 text-[0.82rem] font-extrabold text-[var(--pv2-home-muted)]">Conseil</span>
            <span class="border-l-2 border-[rgba(var(--pv2-accent-rgb),0.42)] pl-3 text-[0.82rem] font-extrabold text-[var(--pv2-home-muted)]">Devis</span>
            <span class="border-l-2 border-[rgba(var(--pv2-accent-rgb),0.42)] pl-3 text-[0.82rem] font-extrabold text-[var(--pv2-home-muted)]">Pose</span>
          </div>
          <details class="rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4" open>
            <summary class="cursor-pointer text-[0.86rem] font-black">Accordion</summary>
            <p class="mt-2 text-[0.82rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Informations compactes.</p>
          </details>
        </div>
      </section>

      <section id="public-v2-kit-components" class="scroll-mt-28 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="font-[var(--p-font-mono)] text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]">09 · ViewComponents</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Inventaire d'extraction.</h2>
          <p class="max-w-[72ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">Ces composants portent les pages reelles Public V2. La suite consiste a stabiliser les APIs et optimiser seulement les patterns repetes.</p>
        </div>

        <div class="grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-3">
          <% @design_system.component_inventory.each do |group, name, text| %>
            <article class="grid min-w-0 gap-2 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-4 transition hover:-translate-y-px hover:border-[rgba(var(--pv2-accent-rgb),0.38)]">
              <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]"><%= group %></span>
              <strong class="[overflow-wrap:anywhere] text-[0.9rem] font-black leading-6"><%= name %></strong>
              <p class="text-[0.82rem] font-semibold leading-6 text-[var(--pv2-home-muted)]"><%= text %></p>
            </article>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</main>
