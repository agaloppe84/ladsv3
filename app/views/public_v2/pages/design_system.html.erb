<% title "Public V2 - Design System Warm System" %>
<% description "Design system Public V2 Warm System V9 : fondations, UI Kit, composants reels et regles de construction." %>

<main class="pv2-design-system-page mx-auto w-full px-[var(--p-shell-x)] py-8 pb-20 text-pv2-text">
  <div class="grid gap-6 xl:grid-cols-[230px_minmax(0,1fr)] xl:items-start">
    <aside class="hidden xl:block xl:sticky xl:top-[96px]">
      <div class="rounded-pv2 border border-pv2-border bg-pv2-surface p-3 shadow-sm">
        <p class="mb-3 text-[0.66rem] font-black uppercase text-pv2-accent">Warm System</p>
        <nav class="grid gap-1" aria-label="Sections du design system">
          <% @design_system.kit_sections.each do |section| %>
            <a class="grid grid-cols-[2rem_minmax(0,1fr)] items-center gap-2 rounded px-2 py-2 text-[0.78rem] font-bold text-pv2-muted transition hover:bg-pv2-accent-soft hover:text-pv2-text" href="#<%= section[:id] %>">
              <span class="text-[0.62rem] font-black text-pv2-accent"><%= section[:number] %></span>
              <span><%= section[:label] %></span>
            </a>
          <% end %>
        </nav>
      </div>
    </aside>

    <div class="grid min-w-0 gap-7">
      <header class="grid min-w-0 gap-5 overflow-hidden rounded-pv2-lg border border-pv2-border bg-pv2-surface p-5 min-[821px]:grid-cols-[minmax(0,1fr)_minmax(300px,0.36fr)] min-[821px]:items-center min-[1121px]:p-7">
        <div class="grid min-w-0 gap-3">
          <p class="text-[0.68rem] font-black uppercase text-pv2-accent">Public V2 / Warm System V9</p>
          <h1 class="max-w-[15ch] text-[1.9rem] font-black leading-[1.02] tracking-normal min-[821px]:text-[2.35rem]">UI Kit propre, composants reels.</h1>
          <p class="max-w-[72ch] text-[0.94rem] font-semibold leading-7 text-pv2-muted">
            Cette page sert de reference stable pour construire Public V2. Elle montre les fondations, les primitives et les composants
            sans prototypes de pages, sans bibliotheque de layouts et avec une palette editoriale bornee.
          </p>
        </div>

        <%= render PublicV2::Ui::SpotlightPanelComponent.new(
          kicker: "Contrat systeme",
          title: "Clair, sombre, accents doses.",
          text: "Les variations viennent des composants, des surfaces, de la densite, du responsive et de quelques accents nommes.",
          size: :md,
          classes: "max-w-full min-w-0"
        ) %>
      </header>

      <nav class="sticky top-[82px] z-20 flex min-w-0 max-w-full gap-2 overflow-x-auto rounded-pv2 border border-pv2-border bg-pv2-surface p-2 backdrop-blur xl:hidden" aria-label="Sections du design system">
        <% @design_system.kit_sections.each do |section| %>
          <a class="shrink-0 rounded-full border border-pv2-border px-3 py-2 text-[0.72rem] font-extrabold text-pv2-muted hover:border-pv2-accent-border hover:text-pv2-text" href="#<%= section[:id] %>"><%= section[:label] %></a>
        <% end %>
      </nav>

      <section id="public-v2-kit-foundations" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">01 / Fondations</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Tokens, palette, typo et regles.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">
            Public V2 utilise des surfaces neutres, un dark mode calme, des dimensions stables et six accents editoriaux limites.
          </p>
        </div>

        <div class="mb-4 grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-3">
          <% @design_system.style_accents.each do |accent| %>
            <article class="grid min-w-0 gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="grid min-w-0 gap-1">
                  <span class="text-[0.62rem] font-black uppercase text-pv2-muted">Accent <%= accent[:number] %></span>
                  <strong class="text-[1rem] font-black leading-tight"><%= accent[:name] %></strong>
                </div>
                <i class="h-12 w-12 shrink-0 rounded-full border border-pv2-border-strong" style="background: var(<%= accent[:token] %>);"></i>
              </div>
              <code class="text-[0.74rem] font-black text-pv2-muted"><%= accent[:token] %> / <%= accent[:hex] %></code>
              <p class="m-0 text-[0.82rem] font-semibold leading-6 text-pv2-muted"><%= accent[:usage] %></p>
            </article>
          <% end %>
        </div>

        <article class="mb-4 grid gap-2 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
          <span class="text-[0.62rem] font-black uppercase text-pv2-accent">Regles accents</span>
          <ul class="m-0 grid gap-2 pl-4 text-[0.82rem] font-semibold leading-6 text-pv2-muted min-[821px]:grid-cols-2">
            <li>Accent 1 reste le signal principal des grands titres editoriaux.</li>
            <li>Accent 2 sert aux chiffres, preuves ou surfaces tres courtes.</li>
            <li>Accents 3 et 4 enrichissent les etats secondaires sans remplacer le bleu.</li>
            <li>Accents 5 et 6 sont chauds et ponctuels : pas de grand aplat dominant.</li>
          </ul>
        </article>

        <div class="grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
          <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <span class="text-[0.62rem] font-black uppercase text-pv2-accent">Light</span>
            <strong class="text-[0.98rem] font-black">Nuances naturelles.</strong>
            <div class="flex flex-wrap gap-2">
              <i class="h-8 w-8 rounded-full border border-pv2-border-strong" style="background:#fbf7ef"></i>
              <i class="h-8 w-8 rounded-full border border-pv2-border-strong" style="background:#fffdf7"></i>
              <i class="h-8 w-8 rounded-full border border-pv2-border-strong" style="background:#f2e8da"></i>
              <i class="h-8 w-8 rounded-full border border-pv2-border-strong" style="background:#1a1815"></i>
              <i class="h-8 w-8 rounded-full border border-pv2-border-strong" style="background:#ff3d12"></i>
            </div>
            <p class="text-[0.82rem] font-semibold leading-6 text-pv2-muted">Fond doux, texte chaud, surfaces claires, accent visible mais dose.</p>
          </article>

          <article class="grid gap-3 rounded-pv2 border border-white/10 bg-[#17120f] p-4 text-[#fff9f1]">
            <span class="text-[0.62rem] font-black uppercase text-[#ff6b45]">Dark</span>
            <strong class="text-[0.98rem] font-black">Sombre chaud.</strong>
            <div class="flex flex-wrap gap-2">
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#17120f"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#211914"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#2b211a"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#fff9f1"></i>
              <i class="h-8 w-8 rounded-full border border-white/15" style="background:#ff3d12"></i>
            </div>
            <p class="text-[0.82rem] font-semibold leading-6 text-white/70">Contraste lisible, ambiance premium, pas d'effet dashboard froid.</p>
          </article>

          <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <span class="text-[0.62rem] font-black uppercase text-pv2-accent">Typo</span>
            <strong class="text-[1.35rem] font-black leading-tight">Titre compact</strong>
            <b class="text-[1.02rem] font-black leading-tight">Sous-titre solide</b>
            <p class="text-[0.82rem] font-semibold leading-6 text-pv2-muted">Police unique, variations par taille, graisse et couleur. Letter-spacing a 0.</p>
          </article>

          <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <span class="text-[0.62rem] font-black uppercase text-pv2-accent">Regles</span>
            <ul class="m-0 grid gap-2 pl-4 text-[0.8rem] font-semibold leading-6 text-pv2-muted">
              <li>Mode clair/sombre uniquement.</li>
              <li>Accents nommes et bornes.</li>
              <li>Angles courts, pas de boutons enormes.</li>
              <li>Medias en ratios stables.</li>
              <li>Debug global conserve.</li>
            </ul>
          </article>
        </div>
      </section>

      <section id="public-v2-kit-primitives" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">02 / Primitives</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Boutons, panels, badges et stats.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">Ces briques doivent rester predictibles : variantes bornees, tailles stables et fallback sur la variante par defaut.</p>
        </div>

        <div class="grid gap-4">
          <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <span class="text-[0.62rem] font-black uppercase text-pv2-accent">ButtonComponent</span>
            <div class="flex flex-wrap items-center gap-2">
              <%= render PublicV2::Ui::ButtonComponent.new(label: "Primaire", path: public_v2_new_quote_path, variant: :primary) %>
              <%= render PublicV2::Ui::ButtonComponent.new(label: "Secondaire", path: public_v2_categories_path, variant: :secondary) %>
              <%= render PublicV2::Ui::ButtonComponent.new(label: "Ghost", path: public_v2_contact_path, variant: :ghost) %>
              <%= render PublicV2::Ui::ButtonComponent.new(label: "Danger", variant: :danger) %>
              <%= render PublicV2::Ui::ButtonComponent.new(label: "Sharp", variant: :secondary, shape: :sharp, size: :sm) %>
              <%= render PublicV2::Ui::ButtonComponent.new(label: "Pill", variant: :primary, shape: :pill, size: :lg) %>
            </div>
          </article>

          <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <span class="text-[0.62rem] font-black uppercase text-pv2-accent">PanelComponent</span>
            <div class="grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
              <% [
                [:default, "Default", "Surface standard."],
                [:soft, "Soft", "Accent attenue."],
                [:outline, "Outline", "Cadre calme."],
                [:rail, "Rail", "Signal lateral."],
                [:elevated, "Elevated", "Ombre legere."],
                [:inset, "Inset", "Fond rentrant."],
                [:accent, "Accent", "Fond discret."],
                [:flashy, "Flashy", "Message court."]
              ].each do |variant, panel_title, panel_text| %>
                <%= render PublicV2::Ui::PanelComponent.new(kicker: variant.to_s, title: panel_title, text: panel_text, variant: variant, padding: :sm) %>
              <% end %>
            </div>
          </article>

          <div class="grid gap-4 min-[821px]:grid-cols-2">
            <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <span class="text-[0.62rem] font-black uppercase text-pv2-accent">BadgeComponent</span>
              <div class="flex flex-wrap items-center gap-2">
                <%= render PublicV2::Ui::BadgeComponent.new(label: "RGE", variant: :success) %>
                <%= render PublicV2::Ui::BadgeComponent.new(label: "Sur mesure", variant: :accent) %>
                <%= render PublicV2::Ui::BadgeComponent.new(label: "Pose", variant: :service) %>
                <%= render PublicV2::Ui::BadgeComponent.new(label: "Destockage", variant: :destock) %>
                <%= render PublicV2::Ui::BadgeComponent.new(label: "A verifier", variant: :warning, size: :sm) %>
              </div>
            </article>

            <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <span class="text-[0.62rem] font-black uppercase text-pv2-accent">StatCardComponent</span>
              <div class="grid gap-3 min-[560px]:grid-cols-3">
                <%= render PublicV2::Ui::StatCardComponent.new(label: "Showroom", value: "200m2", text: "Comparer les finitions.", variant: :default) %>
                <%= render PublicV2::Ui::StatCardComponent.new(label: "Metier", value: "35 ans", text: "Conseil et pose.", variant: :soft) %>
                <%= render PublicV2::Ui::StatCardComponent.new(label: "Retour", value: "48h", text: "Premier cadrage.", variant: :accent) %>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="public-v2-kit-navigation" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">03 / Navigation</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Navbar, breadcrumb, dropdown.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">La navigation publique expose le logo, les liens essentiels, le menu mobile et le toggle clair/sombre.</p>
        </div>

        <div class="grid gap-4">
          <article class="min-w-0 overflow-visible rounded-pv2 border border-pv2-border bg-pv2-bg p-3">
            <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">NavbarComponent</span>
            <%= render PublicV2::Layout::NavbarComponent.new(
              items: @design_system.nav_items,
              show_mode_toggle: false,
              active_key: :products,
              classes: "!static rounded-pv2"
            ) %>
          </article>

          <div class="grid gap-4 min-[821px]:grid-cols-3">
            <article class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">BreadcrumbComponent</span>
              <%= render PublicV2::Ui::BreadcrumbComponent.new(
                items: [
                  { label: "Accueil", path: public_v2_home_path },
                  { label: "Produits", path: public_v2_categories_path },
                  { label: @design_system.featured_category&.name || @design_system.fallback_category_name }
                ],
                label: "Demo breadcrumb"
              ) %>
            </article>

            <article class="grid min-w-0 gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <span class="text-[0.62rem] font-black uppercase text-pv2-accent">DropdownComponent</span>
              <%= render PublicV2::Ui::DropdownComponent.new(label: "Actions exemple", align: :left, width: :sm, trigger_classes: "min-w-[128px] gap-2 px-3") do |dropdown| %>
                <% dropdown.with_trigger do %>
                  <span>Actions</span>
                  <span aria-hidden="true">+</span>
                <% end %>
                <% dropdown.with_panel do %>
                  <div class="grid gap-2 text-[0.82rem] font-bold text-pv2-muted">
                    <%= link_to "Voir les produits", public_v2_categories_path, class: "rounded border border-pv2-border px-3 py-2 hover:border-pv2-accent-border hover:text-pv2-text" %>
                    <%= link_to "Preparer un devis", public_v2_new_quote_path, class: "rounded border border-pv2-border px-3 py-2 hover:border-pv2-accent-border hover:text-pv2-text" %>
                  </div>
                <% end %>
              <% end %>
            </article>

            <article class="grid min-w-0 gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <span class="text-[0.62rem] font-black uppercase text-pv2-accent">Mode toggle</span>
              <button
                type="button"
                class="pv2-public-theme-switch"
                data-theme-target="switch"
                data-action="theme#toggleMode"
                aria-label="Activer le mode sombre"
                aria-pressed="false">
                <span class="pv2-public-theme-switch__icon pv2-public-theme-switch__icon--sun" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M12 3.75a1.05 1.05 0 0 1 1.05 1.05v.58a1.05 1.05 0 1 1-2.1 0V4.8A1.05 1.05 0 0 1 12 3.75Zm0 13.82a1.05 1.05 0 0 1 1.05 1.05v.58a1.05 1.05 0 1 1-2.1 0v-.58A1.05 1.05 0 0 1 12 17.57ZM5.25 12a1.05 1.05 0 0 1-1.05 1.05h-.58a1.05 1.05 0 1 1 0-2.1h.58A1.05 1.05 0 0 1 5.25 12Zm15.13 0a1.05 1.05 0 0 1-1.05 1.05h-.58a1.05 1.05 0 1 1 0-2.1h.58A1.05 1.05 0 0 1 20.38 12ZM7.2 7.2a1.05 1.05 0 0 1-1.49 0l-.42-.42a1.05 1.05 0 0 1 1.49-1.49l.42.42a1.05 1.05 0 0 1 0 1.49Zm11.51 11.51a1.05 1.05 0 0 1-1.49 0l-.42-.42a1.05 1.05 0 0 1 1.49-1.49l.42.42a1.05 1.05 0 0 1 0 1.49Zm-11.51-1.5a1.05 1.05 0 0 1 0 1.5l-.42.41a1.05 1.05 0 1 1-1.49-1.48l.42-.43a1.05 1.05 0 0 1 1.49 0Zm11.51-11.5a1.05 1.05 0 0 1 0 1.49l-.42.42a1.05 1.05 0 0 1-1.49-1.49l.42-.42a1.05 1.05 0 0 1 1.49 0ZM12 7.5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Z" />
                  </svg>
                </span>
                <span class="pv2-public-theme-switch__icon pv2-public-theme-switch__icon--moon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M18.9 14.42A7.25 7.25 0 0 1 9.58 5.1a.92.92 0 0 0-1.02-1.28A9.2 9.2 0 1 0 20.18 15.44a.92.92 0 0 0-1.28-1.02Z" />
                  </svg>
                </span>
                <span class="pv2-public-theme-switch__thumb" aria-hidden="true"></span>
              </button>
            </article>
          </div>
        </div>
      </section>

      <section id="public-v2-kit-content" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">04 / Contenu</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Hero, sections, media, CTA et footer.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">Les composants de contenu structurent les messages publics sans transformer la page en landing generique.</p>
        </div>

        <div class="grid gap-4">
          <article class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-bg p-3 min-[821px]:p-4">
            <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">HeroComponent</span>
            <%= render PublicV2::Content::HeroComponent.new(
              kicker: @design_system.featured_category&.name || @design_system.fallback_category_name,
              title: @design_system.featured_product&.name || @design_system.fallback_product_name,
              text: "Hero compact avec rail accent, titre court, texte utile et preuve visible.",
              panel_label: "Premier retour",
              panel_value: "48h",
              panel_text: "Cadrage devis apres reception des informations."
            ) %>
          </article>

          <div class="grid gap-4 min-[1121px]:grid-cols-2">
            <article class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-bg p-3 min-[821px]:p-4">
              <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">MediaFrameComponent</span>
              <div class="grid gap-4 min-[821px]:grid-cols-[minmax(0,0.58fr)_minmax(0,0.42fr)] min-[821px]:items-center">
                <div class="min-h-[220px] overflow-hidden rounded-pv2">
                  <%= render PublicV2::Ui::MediaFrameComponent.new(image: @design_system.featured_image, fallback: "magasin-04.jpeg", alt: "Showroom Les Artisans du Store") %>
                </div>
                <div class="grid gap-2">
                  <p class="pv2-eyebrow">Showroom</p>
                  <h3 class="text-[1rem] font-black">Voir, toucher, comparer.</h3>
                  <p class="text-[0.84rem] font-semibold leading-6 text-pv2-muted">Image utile, non dominante, toujours dans un ratio stable.</p>
                </div>
              </div>
            </article>

            <article class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-bg p-3 min-[821px]:p-4">
              <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">SectionShellComponent</span>
              <%= render PublicV2::Ui::SectionShellComponent.new(
                kicker: "Section",
                title: "Un cadre reutilisable.",
                text: "Header, actions, surface et contenu slotte pour structurer les futures pages.",
                variant: :soft
              ) do |section| %>
                <% section.with_actions do %>
                  <%= render PublicV2::Ui::ButtonComponent.new(label: "Devis", path: public_v2_new_quote_path, size: :sm) %>
                <% end %>
                <%= render PublicV2::Ui::PanelComponent.new(kicker: "Usage", title: "Conseil + pose.", text: "Une section assemble les micro-composants sans les specialiser.") %>
              <% end %>
            </article>
          </div>

          <article class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-bg p-3 min-[821px]:p-4">
            <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">ShowcaseCarouselComponent</span>
            <%= render PublicV2::Ui::ShowcaseCarouselComponent.new(
              items: @design_system.showcase_samples,
              label: "Carousel showcase",
              title: "Collection fluide et reutilisable.",
              text: "Une brique pour photos, familles produits ou selections cliquables, avec pagination compacte.",
              variant: :soft,
              size: :compact
            ) %>
          </article>

          <div class="grid gap-4 min-[1121px]:grid-cols-2">
            <%= render PublicV2::Content::CtaBandComponent.new(
              kicker: "Besoin d'aide ?",
              title: "Envoyez les premieres informations.",
              action_label: "Demander un devis",
              action_path: public_v2_new_quote_path,
              secondary_label: "Voir les produits",
              secondary_path: public_v2_categories_path
            ) %>

            <%= render PublicV2::Content::InfoCardComponent.new(
              label: "Showroom",
              title: "35 Rue des Martinets",
              text: "L'Arbresle, Rhone. Comparer produits, mecanismes et finitions.",
              path: public_v2_contact_path
            ) %>
          </div>

          <article class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-bg p-3 min-[821px]:p-4">
            <span class="mb-3 block text-[0.62rem] font-black uppercase text-pv2-accent">FooterComponent</span>
            <%= render PublicV2::Layout::FooterComponent.new(
              id: "public-v2-footer-demo",
              eyebrow: "Les Artisans du Store",
              title: "Showroom de L'Arbresle.",
              text: "Coordonnees, horaires et liens utiles en bas de page."
            ) %>
          </article>
        </div>
      </section>

      <section id="public-v2-kit-business" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">05 / Metier</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Devis, preuves, etapes et choix.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">Ces micro-composants servent a construire des parcours courts : comprendre, choisir, demander un devis.</p>
        </div>

        <div class="grid gap-4">
          <div class="grid gap-4 min-[1121px]:grid-cols-2">
            <%= render PublicV2::Ui::ActionDockComponent.new(
              kicker: "Devis",
              title: "Cadrer le projet rapidement.",
              text: "Produit, dimensions, exposition et contexte suffisent pour un premier retour.",
              primary_label: "Demander un devis",
              primary_path: public_v2_new_quote_path,
              secondary_label: "Contacter",
              secondary_path: public_v2_contact_path,
              meta: "Retour commercial sous 48h",
              variant: :soft
            ) %>

            <%= render PublicV2::Ui::QuoteIntakeComponent.new(
              kicker: "Parcours",
              title: "Trois infos pour demarrer.",
              text: "Un mini parcours devis utilisable dans une home ou une fiche produit.",
              steps: @design_system.micro_ui_samples[:quote_steps],
              primary_label: "Commencer",
              primary_path: public_v2_new_quote_path,
              variant: :soft
            ) %>
          </div>

          <div class="grid gap-4 min-[1121px]:grid-cols-3">
            <%= render PublicV2::Ui::ProofRailComponent.new(items: @design_system.micro_ui_samples[:trust_items], label: "Preuves") %>
            <%= render PublicV2::Ui::StepRailComponent.new(steps: @design_system.micro_ui_samples[:process_steps], label: "Etapes") %>
            <%= render PublicV2::Ui::TrustClusterComponent.new(items: @design_system.micro_ui_samples[:trust_items], kicker: "Confiance", title: "Signaux locaux.", variant: :soft) %>
          </div>

          <div class="grid gap-4 min-[1121px]:grid-cols-2">
            <%= render PublicV2::Ui::ProductFamilyGridComponent.new(families: @design_system.product_family_samples, label: "Familles produit", variant: :compact) %>
            <%= render PublicV2::Ui::ComparisonStripComponent.new(items: @design_system.micro_ui_samples[:comparison_items], label: "Comparer les besoins") %>
          </div>
        </div>
      </section>

      <section id="public-v2-kit-products" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">06 / Produits</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Catalogue, cards, categorie et options.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">La page produit sera riche, mais les composants doivent rester scannables et modulaires.</p>
        </div>

        <div class="grid gap-4">
          <%= render PublicV2::Products::CategoryBlockComponent.new(
            category: @design_system.featured_category,
            products: @design_system.sample_products,
            image: @design_system.featured_image,
            title: @design_system.featured_category&.name || @design_system.fallback_category_name,
            text: "Bloc categorie avec media, tags et grille produits.",
            tags: @design_system.sample_categories.any? ? @design_system.sample_categories.map(&:name) : ["Stores", "Volets", "Pergolas"]
          ) %>

          <div class="grid grid-cols-1 gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
            <% if @design_system.sample_products.any? %>
              <% @design_system.sample_products.each do |product| %>
                <%= render PublicV2::Products::ProductCardComponent.new(
                  product: product,
                  path: public_v2_product_path(slug: product.slug),
                  image: @design_system.product_image(product)
                ) %>
              <% end %>
            <% else %>
              <%= render PublicV2::Products::ProductCardComponent.new(
                product: nil,
                eyebrow: @design_system.fallback_category_name,
                description: "Produit sur mesure selon projet."
              ) %>
            <% end %>
          </div>

          <article class="grid min-w-0 gap-4 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <div class="grid gap-2">
              <span class="text-[0.62rem] font-black uppercase text-pv2-accent">OptionListComponent</span>
              <p class="m-0 max-w-[82ch] text-[0.82rem] font-semibold leading-6 text-pv2-muted">Cinq lectures compactes pour les options produit, a choisir selon la densite de la fiche.</p>
            </div>

            <div class="grid gap-4 min-[1121px]:grid-cols-2">
              <% @design_system.option_list_concepts.each do |concept| %>
                <div class="min-w-0 rounded-pv2 border border-pv2-border bg-pv2-surface p-3">
                  <%= render PublicV2::Products::OptionListComponent.new(
                    items: @design_system.sample_option_items,
                    variant: concept[:variant],
                    kicker: concept[:label],
                    title: concept[:title],
                    text: concept[:text]
                  ) %>
                </div>
              <% end %>
            </div>
          </article>
        </div>
      </section>

      <section id="public-v2-kit-forms" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">07 / Formulaires</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Champs et formulaire devis.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">Les formulaires doivent rester clairs, courts en perception, et rassurants sur mobile.</p>
        </div>

        <div class="grid items-start gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_360px]">
          <%= render PublicV2::Ui::PanelComponent.new(kicker: "QuoteFormComponent", title: "Formulaire devis complet.", classes: "pv2-quote-form-card") do %>
            <%= render PublicV2::Forms::QuoteFormComponent.new(
              quote: @design_system.quote_preview,
              products: @design_system.quote_products,
              url: public_v2_quotes_path
            ) %>
          <% end %>

          <article class="grid min-w-0 gap-4 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
            <span class="text-[0.62rem] font-black uppercase text-pv2-accent">FieldComponent</span>
            <%= render PublicV2::Forms::FieldComponent.new(label: "Nom", name: "demo_lastname", value: "Durand", readonly: true) %>
            <%= render PublicV2::Forms::FieldComponent.new(label: "Besoin", name: "demo_need", type: :select, value: "Protection solaire", options: ["Protection solaire", "Fermeture", "Moustiquaire"], disabled: true) %>
            <%= render PublicV2::Forms::FieldComponent.new(label: "Message", name: "demo_message", type: :textarea, value: "Dimensions, exposition, delai souhaite...", readonly: true, hint: "Hint court, utile et lisible.") %>
          </article>
        </div>
      </section>

      <section id="public-v2-kit-feedback" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">08 / Etats</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Feedback, vide, FAQ et media mosaic.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">Les etats ne doivent pas dominer l'ecran : ils guident, rassurent ou expliquent le manque de contenu.</p>
        </div>

        <div class="grid gap-4">
          <div class="grid gap-4 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-4">
            <%= render PublicV2::Ui::NotificationBannerComponent.new(title: "Information", message: "Produit ajoute au devis.", icon: "i") %>
            <%= render PublicV2::Ui::EmptyStateComponent.new(message: "Aucun resultat pour ce filtre.", title: "Etat vide") %>
            <article class="grid gap-2 rounded-pv2 border border-red-500/25 bg-red-500/10 p-4">
              <strong class="text-[0.86rem] font-black">Erreur form</strong>
              <p class="m-0 text-[0.82rem] font-semibold leading-6 text-pv2-muted">Certains champs sont a completer.</p>
            </article>
            <article class="grid gap-3 rounded-pv2 border border-pv2-border bg-pv2-bg p-4">
              <i class="h-3 animate-pulse rounded-full bg-pv2-border"></i>
              <i class="h-3 w-3/4 animate-pulse rounded-full bg-pv2-border"></i>
              <i class="h-3 w-1/2 animate-pulse rounded-full bg-pv2-border"></i>
            </article>
          </div>

          <div class="grid gap-4 min-[1121px]:grid-cols-2">
            <%= render PublicV2::Ui::FaqAccordionComponent.new(items: @design_system.micro_ui_samples[:faq_items], label: "Questions devis", variant: :soft) %>
            <%= render PublicV2::Ui::MediaMosaicComponent.new(items: @design_system.micro_ui_samples[:media_items], label: "Showroom", variant: :feature) %>
          </div>
        </div>
      </section>

      <section id="public-v2-kit-components" class="scroll-mt-28 rounded-pv2-lg border border-pv2-border bg-pv2-surface p-4 min-[821px]:p-5">
        <div class="mb-5 grid gap-2">
          <p class="text-[0.64rem] font-black uppercase text-pv2-accent">09 / ViewComponents</p>
          <h2 class="text-[1.15rem] font-black leading-tight">Inventaire de reference.</h2>
          <p class="max-w-[74ch] text-[0.86rem] font-semibold leading-6 text-pv2-muted">Les composants ci-dessous forment la base reusable avant reconstruction des pages reelles.</p>
        </div>

        <div class="grid gap-3 min-[821px]:grid-cols-2 min-[1121px]:grid-cols-3">
          <% @design_system.component_inventory.each do |group, name, text| %>
            <article class="grid min-w-0 gap-2 rounded-pv2 border border-pv2-border bg-pv2-bg p-4 transition hover:-translate-y-px hover:border-pv2-accent-border">
              <span class="text-[0.62rem] font-black uppercase text-pv2-accent"><%= group %></span>
              <strong class="[overflow-wrap:anywhere] text-[0.9rem] font-black leading-6"><%= name %></strong>
              <p class="text-[0.82rem] font-semibold leading-6 text-pv2-muted"><%= text %></p>
            </article>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</main>
