<% title "HOME TEST - Public V2" %>
<% description "Page TEST Public V2 dediee aux essais temporaires de layouts home." %>

<main class="pv2-home-page pv2-home-graphite grid gap-6 pb-20 pt-8">
  <section class="grid gap-3 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-5 min-[821px]:p-7">
    <p class="pv2-eyebrow">HOME TEST</p>
    <h1 class="m-0 max-w-[20ch] text-[1.8rem] font-black leading-tight min-[821px]:text-[2.2rem]">3 homes completes + 10 compositions section.</h1>
    <p class="m-0 max-w-[72ch] text-[0.9rem] font-semibold leading-7 text-[var(--pv2-home-muted)]">
      Objectif : tester des directions premium/design orientees devis a l'echelle d'une home complete, puis garder les essais de premiere section comme reserve d'idees. Rien ici ne touche la vraie home-v2.
    </p>
  </section>

  <%= render PublicV2::Ui::SectionShellComponent.new(
    kicker: "HomeContentBlueprint",
    title: "Source commune pour generer une home complete.",
    text: "Cette couche organise les infos home classique + home-v2 avant de choisir les layouts. Elle sert de base au step suivant.",
    variant: :soft,
    padding: :md
  ) do %>
    <div class="grid gap-4">
      <div class="grid gap-3 min-[1121px]:grid-cols-[minmax(0,.42fr)_minmax(0,.58fr)]">
        <%= render PublicV2::Ui::SummaryBoxComponent.new(
          kicker: @home_test.blueprint.hero.kicker,
          title: @home_test.blueprint.hero.title,
          text: @home_test.blueprint.hero.text,
          items: @home_test.blueprint.source_notes.map { |note| "#{note[:label]} : #{note[:text]}" },
          variant: :outline
        ) %>

        <%= render PublicV2::Ui::TrustClusterComponent.new(
          kicker: "Preuves",
          title: "Reassurance avant devis.",
          text: "Les preuves doivent rester visibles dans chaque direction de home.",
          items: @home_test.blueprint.proofs,
          variant: :soft
        ) %>
      </div>

      <div class="grid gap-4 min-[1121px]:grid-cols-2">
        <%= render PublicV2::Ui::IconListComponent.new(
          label: "Besoins client",
          items: @home_test.blueprint.needs,
          variant: :soft
        ) %>

        <%= render PublicV2::Ui::ProcessListComponent.new(
          label: "Parcours devis",
          steps: @home_test.blueprint.quote_journey,
          variant: :timeline
        ) %>
      </div>

      <%= render PublicV2::Ui::ProductFamilyGridComponent.new(
        label: "Familles produit",
        families: @home_test.blueprint.product_families.map { |family| family.merge(path: public_v2_categories_path) },
        variant: :editorial
      ) %>

      <div class="grid gap-4 min-[1121px]:grid-cols-[minmax(0,.54fr)_minmax(0,.46fr)]">
        <%= render PublicV2::Ui::SummaryBoxComponent.new(
          kicker: @home_test.blueprint.showroom.kicker,
          title: @home_test.blueprint.showroom.title,
          text: @home_test.blueprint.showroom.text,
          items: @home_test.blueprint.showroom.items.map { |item| "#{item[:title]} : #{item[:text]}" },
          variant: :default
        ) %>

        <%= render PublicV2::Ui::FaqAccordionComponent.new(
          label: "Objections client",
          items: @home_test.blueprint.objections,
          variant: :soft
        ) %>
      </div>

      <div class="grid gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3">
        <p class="pv2-eyebrow">Sequence cible</p>
        <div class="grid gap-2 min-[821px]:grid-cols-3">
          <% @home_test.blueprint.section_sequence.each do |section| %>
            <article class="grid gap-1 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-3">
              <span class="font-[var(--p-font-mono)] text-[0.62rem] font-black uppercase text-[var(--pv2-accent)]"><%= section[:key] %></span>
              <strong class="text-[0.9rem] font-black leading-5"><%= section[:label] %></strong>
              <p class="m-0 text-[0.76rem] font-semibold leading-5 text-[var(--pv2-home-muted)]"><%= section[:component_hint] %></p>
            </article>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <section class="grid gap-3 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
    <div class="grid gap-1">
      <p class="pv2-eyebrow">Homes completes</p>
      <h2 class="m-0 text-[1.15rem] font-black leading-tight min-[821px]:text-[1.45rem]">3 directions pour tester la page entiere.</h2>
      <p class="m-0 max-w-[78ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">
        Chaque direction pioche dans le blueprint, les briques UI et la bibliotheque de layouts pour composer un vrai parcours client.
      </p>
    </div>

    <nav class="flex gap-2 overflow-x-auto rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-2" aria-label="Homes completes test">
      <% @home_test.full_compositions.each do |composition| %>
        <a class="shrink-0 rounded-full border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] px-3 py-2 text-[0.72rem] font-extrabold text-[var(--pv2-home-muted)] hover:border-[var(--pv2-accent)] hover:text-[var(--pv2-home-text)]" href="#home-full-<%= composition.code.downcase %>">
          <%= composition.code %> - <%= composition.name %>
        </a>
      <% end %>
    </nav>
  </section>

  <% @home_test.full_compositions.each do |composition| %>
    <%= render "home_test_full_composition", composition: composition, blueprint: @home_test.blueprint %>
  <% end %>

  <section class="grid gap-3 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 min-[821px]:p-5">
    <div class="grid gap-1">
      <p class="pv2-eyebrow">Premiere section</p>
      <h2 class="m-0 text-[1.15rem] font-black leading-tight min-[821px]:text-[1.45rem]">10 compositions courtes conservees comme banque d'idees.</h2>
      <p class="m-0 max-w-[78ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]">
        Ces options restent utiles pour extraire un hero, un micro-layout ou une pression devis precise.
      </p>
    </div>
  </section>

  <nav class="sticky top-[82px] z-20 flex gap-2 overflow-x-auto rounded-md border border-[var(--pv2-home-border)] bg-[color-mix(in_srgb,var(--pv2-home-surface)_92%,transparent)] p-2 backdrop-blur" aria-label="Compositions premiere section home test">
    <% @home_test.compositions.each do |composition| %>
      <a class="shrink-0 rounded-full border border-[var(--pv2-home-border)] px-3 py-2 text-[0.72rem] font-extrabold text-[var(--pv2-home-muted)] hover:border-[var(--pv2-accent)] hover:text-[var(--pv2-home-text)]" href="#home-test-<%= composition.code.downcase %>">
        <%= composition.code %> - <%= composition.name %>
      </a>
    <% end %>
  </nav>

  <% @home_test.compositions.each do |composition| %>
    <%= render "home_test_composition", composition: composition %>
  <% end %>
</main>
