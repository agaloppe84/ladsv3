<% composition = local_assigns.fetch(:composition) %>
<% recipe_rows = @home_test.recipe_rows(composition) %>
<% recipe_bricks = @home_test.recipe_bricks(composition) %>

<article id="home-test-<%= composition.code.downcase %>" class="grid min-w-0 gap-4 overflow-hidden rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] p-4 shadow-sm min-[821px]:p-5">
  <header class="grid min-w-0 gap-3 min-[821px]:grid-cols-[minmax(0,1fr)_auto] min-[821px]:items-start">
    <div class="grid min-w-0 gap-1">
      <p class="pv2-eyebrow"><%= composition.code %> - <%= composition.intent %></p>
      <h2 class="m-0 text-[1.15rem] font-black leading-tight min-[821px]:text-[1.35rem]"><%= composition.name %></h2>
      <p class="m-0 max-w-[86ch] text-[0.86rem] font-semibold leading-6 text-[var(--pv2-home-muted)]"><%= composition.strategy %></p>
    </div>

    <div class="flex max-w-full flex-wrap gap-2">
      <% composition.layout_codes.each do |code| %>
        <span class="rounded-full border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] px-2.5 py-1 font-mono text-[0.65rem] font-black uppercase text-[var(--pv2-accent)]"><%= code %></span>
      <% end %>
    </div>
  </header>

  <section class="grid min-w-0 gap-3 rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(260px,.34fr)]">
    <div class="grid min-w-0 gap-2 min-[821px]:grid-cols-3">
      <% recipe_rows.each do |label, value| %>
        <div class="min-w-0">
          <span class="block font-mono text-[0.62rem] font-black uppercase leading-4 text-[var(--pv2-accent)]"><%= label %></span>
          <strong class="mt-1 block text-[0.78rem] font-extrabold leading-5 text-[var(--pv2-home-text)]"><%= value %></strong>
        </div>
      <% end %>
    </div>

    <div class="flex min-w-0 flex-wrap content-start gap-2">
      <% recipe_bricks.each do |brick| %>
        <span class="rounded-full border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface)] px-2.5 py-1 text-[0.66rem] font-extrabold leading-5 text-[var(--pv2-home-muted)]"><%= brick %></span>
      <% end %>
    </div>
  </section>

  <% case composition.pattern %>
  <% when :compact_command %>
    <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(280px,.42fr)]">
      <section class="grid min-w-0 gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2.1rem)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[13ch] text-[clamp(1.85rem,3.3vw,2.95rem)] font-black leading-[1.03]"><%= composition.title %></h3>
          <p class="m-0 max-w-[36ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <%= render PublicV2::Ui::ProofRailComponent.new(items: composition.facts, variant: :compact) %>

        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: "Action",
          title: "Devis rapide.",
          text: "Produit, contexte, contact.",
          primary_label: "Demander un devis",
          primary_path: public_v2_new_quote_path,
          secondary_label: "Voir les produits",
          secondary_path: public_v2_categories_path,
          variant: :soft
        ) %>
      </section>

      <aside class="grid min-w-0 gap-3">
        <div class="pv2-home-mini-media h-[160px]">
          <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :category, loading: "eager", classes: "h-full min-h-full") %>
        </div>
        <%= render PublicV2::Ui::SpotlightPanelComponent.new(
          kicker: "48h",
          title: "Premier retour.",
          text: "Base courte, suite claire.",
          variant: :flashy,
          size: :md
        ) %>
      </aside>
    </div>

    <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-3">
      <% composition.panels.each_with_index do |panel, index| %>
        <%= render PublicV2::Ui::ChoiceTileComponent.new(
          kicker: panel[:kicker],
          title: panel[:title],
          text: panel[:text],
          active: index.zero?,
          variant: index.zero? ? :soft : :default,
          classes: "h-full"
        ) %>
      <% end %>
    </div>
  <% when :quote_dock %>
    <div class="grid min-w-0 gap-4 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-3 min-[1121px]:grid-cols-[minmax(0,.36fr)_minmax(0,1fr)]">
      <aside class="grid min-w-0 gap-3">
        <div class="pv2-home-mini-media h-[150px]">
          <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :category, loading: "eager", classes: "h-full min-h-full") %>
        </div>
        <%= render PublicV2::Ui::ProofRailComponent.new(items: composition.facts, variant: :compact) %>
      </aside>

      <section class="grid min-w-0 content-between gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2.1rem)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[15ch] text-[clamp(1.8rem,3.3vw,2.9rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[36ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: "Devis",
          title: "Dock rapide.",
          text: "Produit, lieu, contact.",
          primary_label: "Etre rappele",
          primary_path: public_v2_new_quote_path,
          variant: :flashy
        ) %>
      </section>
    </div>

    <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-3">
      <% composition.panels.each do |panel| %>
        <%= render PublicV2::Ui::PanelComponent.new(kicker: panel[:kicker], title: panel[:title], variant: :soft, padding: :sm, classes: "h-full") do %>
          <p><%= panel[:text] %></p>
        <% end %>
      <% end %>
    </div>
  <% when :soft_bento %>
    <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-4">
      <section class="grid min-w-0 content-between gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2rem)] min-[821px]:col-span-2 min-[1121px]:col-span-2">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[13ch] text-[clamp(1.75rem,3vw,2.7rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[34ch] text-[0.94rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Demarrer le devis", path: public_v2_new_quote_path, variant: :primary, size: :md, classes: "w-fit") %>
      </section>

      <div class="pv2-home-mini-media h-[210px] min-[821px]:col-span-1">
        <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :category, loading: "eager", classes: "h-full min-h-full") %>
      </div>

      <%= render PublicV2::Ui::PanelComponent.new(kicker: "48h", title: "Retour devis.", variant: :flashy, padding: :sm, classes: "h-full") do %>
        <p>Un signal visible, pas un pave.</p>
      <% end %>

      <% composition.panels.each_with_index do |panel, index| %>
        <%= render PublicV2::Ui::ChoiceTileComponent.new(
          kicker: panel[:kicker],
          title: panel[:title],
          text: panel[:text],
          active: index.zero?,
          variant: index.zero? ? :soft : :default,
          classes: "h-full"
        ) %>
      <% end %>
    </div>
  <% when :selection_board %>
    <div class="grid min-w-0 gap-4">
      <section class="grid min-w-0 gap-4 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2rem)]">
        <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_auto] min-[1121px]:items-end">
          <div class="grid gap-4">
            <p class="pv2-eyebrow"><%= composition.kicker %></p>
            <h3 class="m-0 max-w-[14ch] text-[clamp(1.75rem,3vw,2.7rem)] font-black leading-[1.04]"><%= composition.title %></h3>
            <p class="m-0 max-w-[38ch] text-[0.94rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
          </div>
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: public_v2_new_quote_path, variant: :primary, size: :md, classes: "w-fit") %>
        </div>

        <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-3">
          <% composition.panels.each_with_index do |panel, index| %>
            <%= render PublicV2::Ui::ChoiceTileComponent.new(
              kicker: panel[:kicker],
              title: panel[:title],
              text: panel[:text],
              active: index.zero?,
              variant: index.zero? ? :flashy : :default,
              classes: "h-full"
            ) %>
          <% end %>
        </div>
      </section>

      <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-[minmax(0,1fr)_minmax(220px,.32fr)]">
        <div class="pv2-home-mini-media h-[120px]">
          <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :wide, loading: "eager", classes: "h-full min-h-full") %>
        </div>
        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: "Devis",
          title: "Apres le choix.",
          text: "La demande part mieux.",
          primary_label: "Chiffrer",
          primary_path: public_v2_new_quote_path,
          variant: :soft
        ) %>
      </div>
    </div>
  <% when :studio_notes %>
    <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.82fr)_minmax(0,1fr)]">
      <section class="grid min-w-0 content-between gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] p-[clamp(1.25rem,3vw,2rem)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[12ch] text-[clamp(1.8rem,3.2vw,2.8rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[32ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <div class="grid grid-cols-[96px_minmax(0,1fr)] gap-3">
          <div class="pv2-home-mini-media h-[96px]">
            <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :square, loading: "eager", classes: "h-full min-h-full") %>
          </div>
          <%= render PublicV2::Ui::PanelComponent.new(kicker: "Devis", title: "Cadrage court.", variant: :flashy, padding: :sm) do %>
            <p>Besoin, delai, contact.</p>
          <% end %>
        </div>
      </section>

      <section class="grid min-w-0 gap-3">
        <%= render PublicV2::Ui::StepRailComponent.new(steps: composition.panels, variant: :rail, label: "Notes projet") %>

        <div class="flex flex-wrap gap-2">
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Cadrer le projet", path: public_v2_new_quote_path, variant: :primary, size: :md) %>
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Showroom", path: public_v2_contact_path, variant: :secondary, size: :md) %>
        </div>
      </section>
    </div>
  <% when :conversion_rail %>
    <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(280px,.38fr)]">
      <section class="grid min-w-0 gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2rem)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[14ch] text-[clamp(1.8rem,3.2vw,2.8rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[34ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <%= render PublicV2::Ui::StepRailComponent.new(steps: composition.panels, variant: :rail, label: "Devis en 3 infos") %>
      </section>

      <aside class="grid min-w-0 content-between gap-3">
        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: "Action",
          title: "Lancer le devis.",
          text: "Simple, court, visible.",
          primary_label: "Continuer",
          primary_path: public_v2_new_quote_path,
          variant: :flashy
        ) %>
        <div class="pv2-home-mini-media h-[150px]">
          <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :category, loading: "eager", classes: "h-full min-h-full") %>
        </div>
      </aside>
    </div>
  <% when :proof_stack %>
    <div class="grid min-w-0 gap-4">
      <section class="grid min-w-0 gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2rem)] min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(240px,.32fr)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[14ch] text-[clamp(1.8rem,3.2vw,2.8rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[34ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <div class="grid grid-cols-[88px_minmax(0,1fr)] gap-3 min-[1121px]:grid-cols-1">
          <div class="pv2-home-mini-media h-[88px] min-[1121px]:h-[140px]">
            <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :square, loading: "eager", classes: "h-full min-h-full") %>
          </div>
          <%= render PublicV2::Ui::PanelComponent.new(kicker: "Devis", title: "Contact local.", variant: :flashy, padding: :sm) do %>
            <p>Pas de tunnel froid.</p>
          <% end %>
        </div>
      </section>

      <%= render PublicV2::Ui::ProofRailComponent.new(items: composition.facts, variant: :soft, label: "Preuves courtes") %>
    </div>
  <% when :modular_catalog %>
    <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(260px,.34fr)]">
      <section class="grid min-w-0 gap-4 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2rem)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[15ch] text-[clamp(1.75rem,3vw,2.65rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[36ch] text-[0.94rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-3">
          <% composition.panels.each_with_index do |panel, index| %>
            <%= render PublicV2::Ui::ChoiceTileComponent.new(
              kicker: panel[:kicker],
              title: panel[:title],
              text: panel[:text],
              variant: index == 1 ? :soft : :default,
              classes: "h-full"
            ) %>
          <% end %>
        </div>
      </section>

      <aside class="grid min-w-0 gap-3">
        <div class="pv2-home-mini-media h-[150px]">
          <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :category, loading: "eager", classes: "h-full min-h-full") %>
        </div>
        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: "Devis",
          title: "Bonne entree.",
          text: "Le besoin est deja trie.",
          primary_label: "Demander",
          primary_path: public_v2_new_quote_path,
          variant: :flashy
        ) %>
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Voir les familles", path: public_v2_categories_path, variant: :secondary, size: :md, full_width: true) %>
      </aside>
    </div>
  <% when :graphite_desk %>
    <div class="grid min-w-0 gap-4 overflow-hidden rounded-lg border border-white/10 bg-[#101314] p-4 text-white min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(280px,.36fr)]">
      <section class="grid min-w-0 content-between gap-5 p-[clamp(0.5rem,2vw,1rem)]">
        <div class="grid gap-4">
          <p class="m-0 font-mono text-[0.72rem] font-black uppercase text-[var(--pv2-accent)]"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[14ch] text-[clamp(1.85rem,3.6vw,3rem)] font-black leading-[1.03]"><%= composition.title %></h3>
          <p class="m-0 max-w-[34ch] text-[0.96rem] font-semibold leading-7 text-white/68"><%= composition.text %></p>
        </div>

        <div class="grid min-w-0 gap-3 min-[821px]:grid-cols-3">
          <% composition.panels.each do |panel| %>
            <div class="rounded-md border border-white/10 bg-white/[0.04] p-3">
              <span class="font-mono text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]"><%= panel[:kicker] %></span>
              <strong class="mt-2 block text-[0.98rem] font-black leading-5 text-white"><%= panel[:title] %></strong>
              <p class="mt-1 text-[0.78rem] font-semibold leading-5 text-white/58"><%= panel[:text] %></p>
            </div>
          <% end %>
        </div>
      </section>

      <aside class="grid min-w-0 gap-3">
        <div class="pv2-home-mini-media h-[150px] border-white/10 bg-white/[0.04]">
          <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :category, loading: "eager", classes: "h-full min-h-full") %>
        </div>
        <%= render PublicV2::Ui::ActionDockComponent.new(
          kicker: "48h",
          title: "Devis compact.",
          text: "Un point de depart net.",
          primary_label: "Demander un devis",
          primary_path: public_v2_new_quote_path,
          variant: :dark
        ) %>
      </aside>
    </div>
  <% when :calm_intake %>
    <div class="grid min-w-0 gap-4 min-[1121px]:grid-cols-[minmax(0,.9fr)_minmax(0,1.1fr)]">
      <section class="grid min-w-0 gap-5 rounded-lg border border-[var(--pv2-home-border)] bg-[var(--pv2-home-surface-strong)] p-[clamp(1.25rem,3vw,2rem)]">
        <div class="grid gap-4">
          <p class="pv2-eyebrow"><%= composition.kicker %></p>
          <h3 class="m-0 max-w-[13ch] text-[clamp(1.8rem,3.2vw,2.8rem)] font-black leading-[1.04]"><%= composition.title %></h3>
          <p class="m-0 max-w-[34ch] text-[0.96rem] font-semibold leading-7 text-[var(--pv2-home-muted)]"><%= composition.text %></p>
        </div>

        <div class="grid min-w-0 gap-2">
          <% composition.facts.each do |fact| %>
            <div class="rounded-md border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] px-3 py-2">
              <span class="font-mono text-[0.64rem] font-black uppercase text-[var(--pv2-accent)]"><%= fact[:value] %></span>
              <span class="ml-2 text-[0.78rem] font-bold text-[var(--pv2-home-muted)]"><%= fact[:label] %></span>
            </div>
          <% end %>
        </div>

        <%= render PublicV2::Ui::ButtonComponent.new(label: "Commencer", path: public_v2_new_quote_path, variant: :primary, size: :md, classes: "w-fit") %>
      </section>

      <section class="grid min-w-0 gap-3">
        <div class="grid min-w-0 grid-cols-[96px_minmax(0,1fr)] gap-3">
          <div class="pv2-home-mini-media h-[96px]">
            <%= render PublicV2::Ui::MediaFrameComponent.new(image: composition.image, alt: composition.image_alt, ratio: :square, loading: "eager", classes: "h-full min-h-full") %>
          </div>
          <%= render PublicV2::Ui::ActionDockComponent.new(
            kicker: "48h",
            title: "Retour simple.",
            text: "Un rappel pour cadrer.",
            primary_label: "Demarrer",
            primary_path: public_v2_new_quote_path,
            variant: :flashy
          ) %>
        </div>

        <%= render PublicV2::Ui::StepRailComponent.new(steps: composition.panels, variant: :compact, label: "Demande guidee") %>
      </section>
    </div>
  <% end %>

  <footer class="flex min-w-0 flex-wrap gap-2 border-t border-[var(--pv2-home-border)] pt-3">
    <% composition.variant_labels.each do |label| %>
      <span class="rounded-full border border-[var(--pv2-home-border)] bg-[var(--pv2-home-bg)] px-2.5 py-1 text-[0.68rem] font-extrabold leading-5 text-[var(--pv2-home-muted)]"><%= label %></span>
    <% end %>
  </footer>
</article>
