<section id="admin_v2_store_nav">
  <% active_key = active.to_sym %>

  <%= render AdminV2::SidebarSectionComponent.new(title: "Store") do %>
    <%= render AdminV2::SidebarItemComponent.new(
      label: "Produits",
      path: admin_v2_products_path,
      active: active_key == :products,
      count: Product.where(type: nil).count,
      data: { turbo_stream: true }
    ) %>
    <%= render AdminV2::SidebarItemComponent.new(
      label: "Catégories",
      path: admin_v2_categories_path,
      active: active_key == :categories,
      count: Category.count,
      data: { turbo_stream: true }
    ) %>
    <%= render AdminV2::SidebarItemComponent.new(
      label: "Events",
      path: admin_v2_events_path,
      active: active_key == :events,
      count: Event.count,
      data: { turbo_stream: true }
    ) %>
    <%= render AdminV2::SidebarItemComponent.new(label: "RALs", path: "#", active: active_key == :rals, disabled: true) %>
    <%= render AdminV2::SidebarItemComponent.new(
      label: "Devis",
      path: admin_v2_quotes_path,
      active: active_key == :quotes,
      count: Quote.count,
      data: { turbo_stream: true }
    ) %>
  <% end %>
</section>
