<li class="grid grid-cols-[8px_58px_48px_minmax(0,1fr)] items-start gap-2 border-b border-white/[0.055] px-3 py-2">
  <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full <%= event.level == "success" ? "bg-[var(--g-green)]" : event.level == "warning" ? "bg-[var(--g-amber)]" : event.level == "error" ? "bg-[var(--g-red)]" : event.level == "server" ? "bg-[var(--g-cyan)]" : event.level == "info" ? "bg-[var(--g-accent)]" : "bg-[var(--g-faint)]" %>"></span>
  <span class="text-[10px] text-[var(--g-subtle)]"><%= l(event.created_at, format: "%H:%M:%S") %></span>
  <span class="text-[9px] uppercase tracking-wide <%= event.level == "success" ? "text-[var(--g-green)]" : event.level == "warning" ? "text-[var(--g-amber)]" : event.level == "error" ? "text-[var(--g-red)]" : event.level == "server" ? "text-[var(--g-cyan)]" : event.level == "info" ? "text-[var(--g-accent)]" : "text-[var(--g-faint)]" %>"><%= event.level %></span>
  <span class="min-w-0 flex-1 truncate text-[11px] text-[var(--g-muted)]"><%= event.message %></span>
</li>
