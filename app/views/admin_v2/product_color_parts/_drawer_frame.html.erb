<%
  palette = part.color_palette
  items = palette.color_palette_items.includes(:ral, :finish).sort_by { |item| [item.ral&.collection.to_s, item.ral&.ref.to_s, item.finish&.label.to_s] }
  paid_count = items.count(&:paid_option)
  finish_count = items.map(&:finish_id).compact.uniq.size
%>

<turbo-frame id="admin_v2_drawer" class="admin-v2-scrollbar relative z-10 block h-full min-h-0 overflow-y-auto">
  <div class="min-h-full">
    <div class="border-b border-white/[0.075] p-5">
      <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-accent)]">Part RALs</p>
      <h2 class="mt-2 text-xl font-semibold text-[var(--g-text)]"><%= part.label %></h2>
      <p class="mt-1 text-sm text-[var(--g-muted)]"><%= product.name %> · <%= palette.name %></p>
    </div>

    <div class="space-y-4 p-5">
      <div class="grid grid-cols-3 gap-2">
        <div class="rounded-xl border border-white/[0.075] bg-[var(--g-surface)]/88 p-3">
          <p class="text-[9px] font-semibold uppercase tracking-[0.16em] text-[var(--g-faint)]">RALs</p>
          <p class="mt-1 text-lg font-semibold text-[var(--g-text)]"><%= items.size %></p>
        </div>
        <div class="rounded-xl border border-white/[0.075] bg-[var(--g-surface)]/88 p-3">
          <p class="text-[9px] font-semibold uppercase tracking-[0.16em] text-[var(--g-faint)]">Finitions</p>
          <p class="mt-1 text-lg font-semibold text-[var(--g-text)]"><%= finish_count %></p>
        </div>
        <div class="rounded-xl border border-white/[0.075] bg-[var(--g-surface)]/88 p-3">
          <p class="text-[9px] font-semibold uppercase tracking-[0.16em] text-[var(--g-faint)]">Payants</p>
          <p class="mt-1 text-lg font-semibold text-[var(--g-text)]"><%= paid_count %></p>
        </div>
      </div>

      <%= render AdminV2::Ui::PanelComponent.new(title: "RALs disponibles", subtitle: "Liste attachée à cette partie") do %>
        <% if items.empty? %>
          <div class="flex min-h-36 items-center justify-center rounded-xl border border-dashed border-white/[0.1] bg-white/[0.025]">
            <p class="text-sm font-medium text-[var(--g-subtle)]">Aucun RAL disponible pour cette partie.</p>
          </div>
        <% else %>
          <div class="grid gap-2">
            <% items.each do |item| %>
              <% raw_color = item.ral.hex.presence || item.ral.try(:rgb).presence || "#505766" %>
              <% swatch_color = raw_color.to_s.start_with?("#", "rgb", "hsl") ? raw_color : "##{raw_color}" %>

              <article class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-center gap-3 rounded-xl border border-white/[0.075] bg-[var(--g-surface-inset)] p-3 transition hover:border-[var(--g-accent-border)]">
                <div class="flex min-w-0 items-center gap-3">
                  <span class="h-5 w-5 shrink-0 rounded-full border border-white/[0.18] shadow-[0_0_0_2px_rgba(255,255,255,0.035)]" style="background-color: <%= swatch_color %>"></span>
                  <div class="min-w-0">
                    <p class="truncate text-[11px] font-semibold text-[var(--g-text)]">
                      <span class="text-[var(--g-cyan)]">RAL <%= item.ral.ref %></span>
                      <span><%= item.ral.name %></span>
                    </p>
                    <p class="mt-0.5 truncate text-[9px] text-[var(--g-subtle)]"><%= item.finish&.label || "Sans finition" %></p>
                  </div>
                </div>

                <div class="flex shrink-0 items-center gap-1.5">
                  <%= form_with scope: :color_palette_item,
                    url: admin_v2_product_color_part_item_path(product, part, item),
                    method: :patch,
                    data: { controller: "inline-form", action: "change->inline-form#submit turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete" },
                    class: "inline-flex items-center" do |f| %>
                    <%= hidden_field_tag :admin_v2_drawer_context, "color_part" %>
                    <%= hidden_field_tag "color_palette_item[paid_option]", "0" %>
                    <label class="admin-v2-focus inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-lg border border-white/[0.075] bg-white/[0.035] text-[var(--g-muted)] transition has-[:checked]:border-[var(--g-accent-border)] has-[:checked]:bg-[var(--g-accent-soft)] has-[:checked]:text-[var(--g-accent)]" title="Option payante">
                      <span class="sr-only">Option payante</span>
                      <%= f.check_box :paid_option, checked: item.paid_option, class: "sr-only" %>
                      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3v18" />
                        <path d="M17 7.5c-.8-.9-2.1-1.5-3.7-1.5-2.1 0-3.8 1.1-3.8 2.8 0 1.8 1.8 2.4 3.7 2.9 2 .5 3.8 1.1 3.8 3 0 1.7-1.6 3.1-4 3.1-1.8 0-3.4-.7-4.3-1.8" />
                      </svg>
                    </label>
                  <% end %>

                  <%= button_to admin_v2_product_color_part_item_path(product, part, item), method: :delete, params: { admin_v2_drawer_context: "color_part" }, title: "Supprimer ce RAL", class: "admin-v2-focus inline-flex h-8 w-8 items-center justify-center rounded-lg border border-red-300/20 bg-red-300/10 text-[var(--g-red)] transition hover:bg-red-300/15", form: { data: { turbo_stream: true, turbo_confirm: "Supprimer ce RAL ?" } } do %>
                    <span class="sr-only">Supprimer ce RAL</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 6h18" />
                      <path d="M8 6V4.5A1.5 1.5 0 0 1 9.5 3h5A1.5 1.5 0 0 1 16 4.5V6" />
                      <path d="M19 6l-1 14H6L5 6" />
                      <path d="M10 11v5" />
                      <path d="M14 11v5" />
                    </svg>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</turbo-frame>
