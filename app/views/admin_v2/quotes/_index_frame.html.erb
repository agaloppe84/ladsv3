<turbo-frame id="admin_v2_main">
  <div class="min-h-full">
    <header class="sticky top-0 z-10 border-b border-white/[0.075] bg-[var(--g-bg)]/90 px-7 py-5 backdrop-blur">
      <div class="flex items-end justify-between gap-5">
        <div>
          <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">admin-v2 / devis / index</p>
          <h1 class="mt-2 text-2xl font-semibold text-[var(--g-text)]">Devis</h1>
          <p class="mt-1 text-sm text-[var(--g-muted)]">Demandes entrantes et suivi de traitement.</p>
        </div>

        <div
          data-controller="live-search"
          data-live-search-delay-value="300"
          data-live-search-min-length-value="2"
          class="flex items-center gap-2">
          <%= form_with url: admin_v2_quotes_path,
            method: :get,
            id: "admin_v2_quotes_filter_form",
            data: {
              live_search_target: "form",
              turbo_frame: "admin_v2_quotes_results"
            },
            class: "w-72" do |f| %>
            <%= f.label :query, "Recherche devis", class: "sr-only" %>
            <%= f.search_field :query,
              value: params[:query],
              placeholder: "Rechercher un devis",
              data: { live_search_target: "query", action: "input->live-search#queue" },
              class: "h-9 w-full rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 text-sm text-[var(--g-text)] placeholder:text-[var(--g-faint)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
          <% end %>
          <%= render AdminV2::Ui::BadgeComponent.new(label: "#{total_quotes} devis", variant: :server) %>
        </div>
      </div>
    </header>

    <div class="grid gap-5 px-7 py-6">
      <%= render "admin_v2/quotes/results_frame", quotes: quotes %>
    </div>
  </div>
</turbo-frame>
