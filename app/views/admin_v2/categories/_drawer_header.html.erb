<div id="admin_v2_category_drawer_header" class="border-b border-white/[0.075] p-5">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">Category context</p>
      <h2 class="mt-2 truncate text-xl font-semibold text-[var(--g-text)]"><%= category.name.presence || "Catégorie sans nom" %></h2>
      <p class="mt-1 truncate text-sm text-[var(--g-muted)]"><%= category.description.presence || "Aucune description" %></p>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <%= render AdminV2::Ui::BadgeComponent.new(label: category.active? ? "Publié" : "Non publié", variant: category.active? ? :success : :neutral) %>
      <%= render AdminV2::Categories::ColorBadgeComponent.new(category: category) %>
    </div>
  </div>
</div>
