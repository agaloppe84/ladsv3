<turbo-frame id="admin_v2_drawer" class="admin-v2-scrollbar relative z-10 block h-full min-h-0 overflow-y-auto">
  <div class="min-h-full">
    <div class="border-b border-white/[0.075] p-5">
      <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-accent)]">Product media</p>
      <h2 class="mt-2 text-xl font-semibold text-[var(--g-text)]"><%= @product.name %></h2>
      <p class="mt-1 text-sm text-[var(--g-muted)]"><%= pluralize(@product.images.size, "image") %> attachée<%= "s" unless @product.images.size == 1 %></p>
    </div>

    <div class="space-y-4 p-5">
      <%= render AdminV2::Ui::PanelComponent.new(title: "Photos", subtitle: "Aperçu du produit") do %>
        <% if @product.images.attached? %>
          <div class="grid grid-cols-2 gap-3">
            <% @product.ordered_images.each do |image| %>
              <div class="overflow-hidden rounded-xl border border-white/[0.075] bg-[var(--g-surface-inset)]">
                <div class="aspect-[4/3]">
                  <%= cl_image_tag(image.key, crop: :scale, class: "h-full w-full object-cover") %>
                </div>
                <div class="border-t border-white/[0.075] px-3 py-2">
                  <p class="truncate text-[10px] font-semibold text-[var(--g-text)]"><%= image.blob.filename %></p>
                  <p class="mt-1 text-[9px] text-[var(--g-subtle)]"><%= "#{(image.blob.byte_size.to_f / 1_000_000.0).round(1)} MB" %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex min-h-36 items-center justify-center rounded-xl border border-dashed border-white/[0.1] bg-white/[0.025]">
            <p class="text-sm font-medium text-[var(--g-subtle)]">Aucune image attachée.</p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</turbo-frame>
