<turbo-frame id="admin_v2_drawer" class="admin-v2-grid-bg admin-v2-scrollbar min-h-0 overflow-y-auto">
  <div class="flex min-h-full items-center justify-center px-8 text-center">
    <div class="max-w-sm">
      <p class="text-[10px] uppercase tracking-[0.26em] text-[var(--g-accent)]">Product deleted</p>
      <h2 class="mt-3 text-xl font-semibold text-[var(--g-text)]"><%= result.product_name %></h2>
      <p class="mt-2 text-[11px] leading-5 text-[var(--g-subtle)]">
        Product#<%= result.product_id %> a été supprimé avec ses médias, documentations, options et palettes couleur.
      </p>
    </div>
  </div>
</turbo-frame>
