<turbo-frame id="admin_v2_drawer">
  <div class="min-h-full" data-controller="action-state" data-action-state-hide-delay-value="1800">
    <div class="border-b border-white/[0.075] p-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-accent)]">New product</p>
          <h2 class="mt-2 text-xl font-semibold text-[var(--g-text)]">Créer un produit</h2>
          <p class="mt-1 text-sm text-[var(--g-muted)]">Crée la base produit, puis ouvre l’atelier edit V2.</p>
        </div>
        <%= render AdminV2::Ui::ActionStateComponent.new %>
      </div>
    </div>

    <div class="space-y-4 p-5">
      <% if @product.errors.any? %>
        <div class="rounded-xl border border-red-300/20 bg-red-300/10 p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[var(--g-red)]">Création impossible</p>
          <ul class="mt-2 grid gap-1 text-sm text-[var(--g-muted)]">
            <% @product.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render AdminV2::Ui::PanelComponent.new(title: "Base produit", subtitle: "Champs requis avant atelier") do %>
        <%= form_with scope: :product,
          url: admin_v2_products_path,
          method: :post,
          data: {
            action: "turbo:submit-start->action-state#saving turbo:submit-end->action-state#complete turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete",
            controller: "inline-form"
          },
          class: "grid gap-4" do |f| %>
          <div>
            <%= f.label :name, "Nom", class: "mb-1 block text-[11px] font-semibold text-[var(--g-subtle)]" %>
            <%= f.text_field :name,
              value: @product.name,
              autofocus: true,
              placeholder: "Nom du produit",
              class: "w-full rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 py-2 text-sm text-[var(--g-text)] placeholder:text-[var(--g-faint)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
          </div>

          <div>
            <span class="mb-2 block text-[11px] font-semibold text-[var(--g-subtle)]">Catégorie</span>
            <div class="grid grid-cols-2 gap-2">
              <% @categories.each do |category| %>
                <% category_input_id = "admin_v2_new_product_category_#{category.id}" %>
                <label
                  for="<%= category_input_id %>"
                  class="admin-v2-focus flex h-11 cursor-pointer items-center justify-center rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 text-center text-[12px] font-bold capitalize text-[var(--g-muted)] transition hover:border-[var(--g-accent-border)] hover:bg-[var(--g-accent-soft)] has-[:checked]:border-[var(--g-accent-border)] has-[:checked]:bg-[var(--g-accent-soft)] has-[:checked]:text-[var(--g-accent)]">
                  <%= f.radio_button :category_id,
                    category.id,
                    id: category_input_id,
                    checked: @product.category_id == category.id,
                    class: "sr-only" %>
                  <span class="min-w-0 truncate"><%= category.name.to_s.downcase %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div>
            <span class="mb-2 block text-[11px] font-semibold text-[var(--g-subtle)]">Garantie</span>
            <div class="grid grid-cols-5 gap-2">
              <% (1..10).each do |year| %>
                <% warranty_input_id = "admin_v2_new_product_warranty_#{year}" %>
                <label
                  for="<%= warranty_input_id %>"
                  class="admin-v2-focus flex h-8 cursor-pointer items-center justify-center rounded-lg border border-white/[0.075] bg-white/[0.035] px-2 text-[10px] font-bold text-[var(--g-muted)] transition hover:border-white/[0.18] hover:bg-white/[0.07] has-[:checked]:border-white/[0.24] has-[:checked]:bg-white/[0.12] has-[:checked]:text-[var(--g-text)]">
                  <%= f.radio_button :warranty,
                    year,
                    id: warranty_input_id,
                    checked: @product.warranty.to_i == year,
                    class: "sr-only" %>
                  <%= year %> an<%= "s" if year > 1 %>
                </label>
              <% end %>
            </div>
          </div>

          <div>
            <%= f.label :description, "Description courte", class: "mb-1 block text-[11px] font-semibold text-[var(--g-subtle)]" %>
            <%= f.text_area :description,
              value: @product.description,
              rows: 4,
              placeholder: "Optionnel, éditable ensuite dans l’atelier.",
              class: "w-full resize-none rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 py-2 text-sm text-[var(--g-text)] placeholder:text-[var(--g-faint)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
          </div>

          <%= f.submit "Créer et ouvrir l’atelier",
            class: "admin-v2-focus h-10 rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-4 text-sm font-semibold text-[var(--g-accent)] transition hover:bg-[var(--g-accent-hover)]" %>
        <% end %>
      <% end %>

      <%= render AdminV2::Ui::PanelComponent.new(title: "Après création", subtitle: "L’atelier complet prend le relais") do %>
        <div class="grid gap-3 text-sm">
          <% ["Médias et documentations", "Options", "Associations", "Configuration couleur"].each do |label| %>
            <div class="flex items-center gap-3 rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 py-2">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--g-accent)]"></span>
              <span class="text-[var(--g-muted)]"><%= label %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
