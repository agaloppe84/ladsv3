<tr id="admin_v2_product_<%= product.id %>" class="group hover:bg-white/[0.035]">
  <td class="px-4 py-3">
    <%= link_to admin_v2_product_path(product), data: { turbo_frame: "admin_v2_drawer" }, class: "flex items-center gap-3" do %>
      <div class="h-12 w-16 overflow-hidden rounded-lg border border-white/[0.075] bg-[var(--g-surface-inset)]">
        <% if product.primary_image %>
          <%= cl_image_tag(product.primary_image.key, crop: :scale, class: "h-full w-full object-cover") %>
        <% end %>
      </div>
      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-[var(--g-text)]"><%= product.name %></p>
        <p class="mt-1 text-[10px] text-[var(--g-subtle)]">Product#<%= product.id %></p>
      </div>
    <% end %>
  </td>
  <td class="px-4 py-3">
    <%= render AdminV2::Ui::BadgeComponent.new(label: product.category.name, variant: :neutral) %>
  </td>
  <td class="px-4 py-3">
    <div class="flex items-center gap-2">
      <%= render AdminV2::Ui::BadgeComponent.new(label: "#{product.images.size} images", variant: :server) %>
      <%= render AdminV2::Ui::BadgeComponent.new(label: "#{product.documentations.size} docs", variant: :neutral) %>
    </div>
  </td>
  <td class="px-4 py-3 text-right">
    <div class="inline-flex items-center gap-2">
      <%= link_to "Drawer", admin_v2_product_path(product), data: { turbo_frame: "admin_v2_drawer" }, class: "admin-v2-focus rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 py-2 text-[11px] font-semibold text-[var(--g-muted)] hover:bg-white/[0.08] hover:text-[var(--g-text)]" %>
      <%= link_to "Edit V2", edit_admin_v2_product_path(product), data: { turbo_frame: "admin_v2_main" }, class: "admin-v2-focus rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-3 py-2 text-[11px] font-semibold text-[var(--g-accent-text)] hover:bg-[var(--g-accent-hover)]" %>
    </div>
  </td>
</tr>
