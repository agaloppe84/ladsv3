<% upload_input_id = "admin_v2_product_#{product.id}_media_upload" %>

<%= render AdminV2::Ui::PanelComponent.new(
  id: "admin_v2_product_media",
  title: "Médias",
  subtitle: "Upload, suppression et ordre sauvegardés par action",
  data: {
    controller: "upload",
    upload_create_url_value: admin_v2_product_media_items_path(product),
    upload_field_value: "image"
  }
) do |panel| %>
  <% panel.with_actions do %>
    <span
      data-upload-target="status"
      class="hidden h-8 items-center gap-2 rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-2.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--g-accent)]">
      <svg
        data-upload-target="spinner"
        viewBox="0 0 24 24"
        aria-hidden="true"
        class="h-3.5 w-3.5 animate-spin"
        fill="none">
        <circle class="opacity-20" cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" />
        <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
      </svg>
      <span data-upload-target="statusLabel">uploading</span>
      <span data-upload-target="progress" class="hidden h-1 w-14 overflow-hidden rounded-full bg-white/[0.1]">
        <span data-upload-target="progressBar" class="block h-full w-2 rounded-full bg-[var(--g-accent)] transition-[width] duration-150"></span>
      </span>
    </span>

    <label
      for="<%= upload_input_id %>"
      title="Upload fichier"
      class="admin-v2-focus inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-[var(--g-accent)] transition hover:bg-[var(--g-accent-hover)]">
      <span class="sr-only">Upload fichier</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 16V4" />
        <path d="m7 9 5-5 5 5" />
        <path d="M20 16.5v1.75A1.75 1.75 0 0 1 18.25 20H5.75A1.75 1.75 0 0 1 4 18.25V16.5" />
      </svg>
    </label>

    <%= link_to drawer_admin_v2_product_media_items_path(product), data: { turbo_frame: "admin_v2_drawer" }, title: "Afficher les photos dans le context drawer", class: "admin-v2-focus inline-flex h-8 w-8 items-center justify-center rounded-lg border border-white/[0.075] bg-white/[0.035] text-[var(--g-accent)] transition hover:border-[var(--g-accent-border)] hover:bg-[var(--g-accent-soft)]" do %>
      <span class="sr-only">Afficher les photos dans le context drawer</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="5" width="18" height="14" rx="2" />
        <circle cx="8.5" cy="10" r="1.5" />
        <path d="m21 15-4.5-4.5L9 18" />
      </svg>
    <% end %>
  <% end %>

  <input id="<%= upload_input_id %>" type="file" multiple direct_upload="true" class="hidden" data-upload-target="input" data-action="change->upload#upload">

  <% if product.images.attached? %>
    <ul
      class="grid grid-cols-4 gap-3"
      data-controller="sortable"
      data-sortable-url-value="<%= reorder_admin_v2_product_media_items_path(product) %>"
      data-sortable-param-value="attachments">
      <% product.ordered_images.each do |image| %>
        <li data-sortable-id="<%= image.id %>" class="group overflow-hidden rounded-xl border border-white/[0.075] bg-white/[0.035]">
          <div class="aspect-[4/3] bg-[var(--g-surface-inset)]">
            <%= cl_image_tag(image.key, crop: :scale, class: "h-full w-full object-cover") %>
          </div>
          <div class="flex items-center justify-between gap-2 px-4 py-3">
            <div class="min-w-0">
              <p class="truncate text-[10px] font-semibold text-[var(--g-text)]"><%= image.blob.filename %></p>
              <p class="text-[9px] text-[var(--g-subtle)]"><%= "#{(image.blob.byte_size.to_f / 1_000_000.0).round(1)} MB" %></p>
            </div>
            <div class="flex items-center gap-2">
              <button type="button" data-admin-v2-sortable-handle class="admin-v2-focus rounded-md border border-white/[0.075] px-2 py-1 text-[10px] text-[var(--g-subtle)]">drag</button>
              <%= button_to "×", admin_v2_product_media_item_path(product, image), method: :delete, class: "admin-v2-focus rounded-md border border-red-300/20 px-2 py-1 text-[11px] font-bold text-[var(--g-red)]", form: { data: { turbo_stream: true } } %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="flex min-h-44 items-center justify-center rounded-xl border border-dashed border-white/[0.1] bg-white/[0.025]">
      <div class="text-center">
        <p class="text-sm font-medium text-[var(--g-subtle)]">Aucune image attachée.</p>
        <p class="mt-1 text-[11px] text-[var(--g-faint)]">Utilise l’icône upload dans le header du bloc.</p>
      </div>
    </div>
  <% end %>
<% end %>
