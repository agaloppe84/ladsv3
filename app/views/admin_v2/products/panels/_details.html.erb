<% autosave_actions = "turbo:submit-start->action-state#saving turbo:submit-end->action-state#complete turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete turbo:submit-end->autosave-field#complete" %>
<% blur_autosave_action = "focusin->autosave-field#remember blur->autosave-field#submitIfChanged" %>

<%= render AdminV2::Ui::PanelComponent.new(
  id: "admin_v2_product_details",
  title: "Description",
  subtitle: "Nom, description et garantie",
  data: {
    controller: "action-state",
    action_state_hide_delay_value: 1800
  }
) do |panel| %>
  <% panel.with_actions do %>
    <%= render AdminV2::Ui::ActionStateComponent.new %>
  <% end %>

  <div class="grid grid-cols-12 gap-4">
    <%= form_with scope: :product,
      url: admin_v2_product_details_path(product),
      method: :patch,
      data: { controller: "autosave-field inline-form", action: autosave_actions },
      class: "col-span-12" do |f| %>
      <%= f.label :name, "Nom", class: "mb-1 block text-[11px] font-semibold text-[var(--g-subtle)]" %>
      <%= f.text_field :name,
        value: product.name,
        data: { action: blur_autosave_action },
        class: "w-full rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
    <% end %>

    <%= form_with scope: :product,
      url: admin_v2_product_details_path(product),
      method: :patch,
      data: { controller: "autosave-field inline-form", action: autosave_actions },
      class: "col-span-12" do |f| %>
      <%= f.label :description, "Description", class: "mb-1 block text-[11px] font-semibold text-[var(--g-subtle)]" %>
      <%= f.text_area :description,
        value: product.description,
        rows: 7,
        data: { action: blur_autosave_action },
        class: "w-full resize-none rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
    <% end %>
  </div>
<% end %>
