<%= render AdminV2::Ui::PanelComponent.new(id: "admin_v2_product_configurator", title: "Configuration couleur", subtitle: "Source V2 des RALs, finitions et palettes") do %>
  <div class="mb-4 grid grid-cols-2 gap-4">
    <%= form_with scope: :product_color_part,
      url: admin_v2_product_color_parts_path(product),
      method: :post,
      data: { controller: "part-form inline-form", action: "turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete" },
      class: "rounded-xl border border-white/[0.075] bg-white/[0.035] p-4" do |f| %>
      <h3 class="text-xs font-semibold text-[var(--g-text)]">Créer une part couleur</h3>
      <div class="mt-3 grid gap-3">
        <%= f.text_field :label, placeholder: "Label", data: { part_form_target: "label", action: "input->part-form#syncCode" }, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
        <%= f.text_field :code, placeholder: "code_unique", data: { part_form_target: "code", action: "input->part-form#markManualEdit" }, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
        <%= f.text_field :palette_name, placeholder: "Nom palette optionnel", class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
        <%= f.submit "Ajouter part", class: "admin-v2-focus h-9 rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-3 text-[11px] font-semibold text-[var(--g-accent-text)] hover:bg-[var(--g-accent-hover)]" %>
      </div>
    <% end %>

    <%= form_with scope: :finish,
      url: admin_v2_product_finishes_path(product),
      method: :post,
      data: { controller: "inline-form", action: "turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete" },
      class: "rounded-xl border border-white/[0.075] bg-white/[0.035] p-4" do |f| %>
      <h3 class="text-xs font-semibold text-[var(--g-text)]">Créer une finition</h3>
      <div class="mt-3 grid gap-3">
        <%= f.text_field :code, placeholder: "code", class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
        <%= f.text_field :label, placeholder: "Nom finition", class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
        <%= f.submit "Ajouter finition", class: "admin-v2-focus h-9 rounded-lg border border-white/[0.09] bg-white/[0.055] px-3 text-[11px] font-semibold text-[var(--g-text)]" %>
      </div>
    <% end %>
  </div>

  <div class="grid gap-4">
    <% if product_color_parts.empty? %>
      <div class="rounded-xl border border-dashed border-white/[0.1] bg-white/[0.025] p-8 text-center text-sm font-medium text-[var(--g-subtle)]">
        Aucune part couleur configurée.
      </div>
    <% end %>

    <% product_color_parts.each do |part| %>
      <% palette = part.color_palette %>
      <% items = palette.color_palette_items.sort_by { |item| [item.ral&.collection.to_s, item.ral&.ref.to_s, item.finish&.label.to_s] } %>

      <section class="rounded-xl border border-white/[0.075] bg-white/[0.035]">
        <header class="flex items-start justify-between gap-4 border-b border-white/[0.075] px-4 py-3">
          <div>
            <p class="text-sm font-semibold text-[var(--g-text)]"><%= part.label %></p>
            <p class="mt-1 font-mono text-[10px] text-[var(--g-subtle)]"><%= part.code %> / <%= palette.name %></p>
          </div>
          <%= button_to "Supprimer part", admin_v2_product_color_part_path(product, part), method: :delete, class: "admin-v2-focus rounded-lg border border-red-300/20 bg-red-300/10 px-3 py-2 text-[11px] font-semibold text-[var(--g-red)]", form: { data: { turbo_stream: true, turbo_confirm: "Supprimer cette part couleur ?" } } %>
        </header>

        <div class="grid gap-4 p-4">
          <%= form_with scope: :product_color_part,
            url: admin_v2_product_color_part_path(product, part),
            method: :patch,
            data: { controller: "inline-form", action: "turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete" },
            class: "grid grid-cols-[1fr_1fr_1fr_auto] gap-3" do |f| %>
            <%= f.text_field :label, value: part.label, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
            <%= f.text_field :code, value: part.code, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
            <%= f.text_field :palette_name, value: palette.name, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface-inset)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
            <%= f.submit "OK", class: "admin-v2-focus h-10 rounded-lg border border-white/[0.09] bg-white/[0.055] px-3 text-[11px] font-semibold text-[var(--g-text)]" %>
          <% end %>

          <%= form_with scope: :color_palette_item,
            url: admin_v2_product_color_part_items_path(product, part),
            method: :post,
            data: { controller: "inline-form", action: "turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete" },
            class: "grid grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)_auto_auto] gap-3 rounded-lg border border-white/[0.075] bg-[var(--g-surface-inset)] p-3" do |f| %>
            <%= f.select :ral_id, options_for_select(rals.map { |ral| ["#{ral.ref} - #{ral.name}", ral.id] }), { include_blank: "Choisir RAL" }, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
            <%= f.select :finish_id, options_for_select(finishes.map { |finish| ["#{finish.label} (#{finish.code})", finish.id] }), { include_blank: "Sans finition" }, class: "rounded-lg border border-white/[0.09] bg-[var(--g-surface)] px-3 py-2 text-sm text-[var(--g-text)] focus:border-[var(--g-accent-border)] focus:ring-0" %>
            <label class="flex items-center gap-2 rounded-lg border border-white/[0.075] px-3 text-[11px] font-semibold text-[var(--g-muted)]">
              <%= f.check_box :paid_option, class: "rounded border-white/[0.13] bg-[var(--g-surface)] text-[var(--g-accent)] focus:ring-[var(--g-accent)]" %>
              Payant
            </label>
            <%= f.submit "Ajouter", class: "admin-v2-focus h-10 rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-3 text-[11px] font-semibold text-[var(--g-accent-text)] hover:bg-[var(--g-accent-hover)]" %>
          <% end %>

          <table class="min-w-full table-fixed overflow-hidden rounded-lg">
            <thead class="border-b border-white/[0.075] bg-white/[0.035]">
              <tr>
                <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--g-faint)]">RAL</th>
                <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--g-faint)]">Finition</th>
                <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--g-faint)]">Statut</th>
                <th class="px-3 py-2 text-right font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--g-faint)]">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/[0.055]">
              <% if items.empty? %>
                <tr>
                  <td colspan="4" class="px-3 py-5 text-center text-sm text-[var(--g-subtle)]">Aucune couleur dans cette palette.</td>
                </tr>
              <% end %>

              <% items.each do |item| %>
                <tr>
                  <td class="px-3 py-2 text-[12px] text-[var(--g-text)]">
                    <span class="font-mono text-[var(--g-cyan)]"><%= item.ral.ref %></span> <%= item.ral.name %>
                  </td>
                  <td class="px-3 py-2 text-[12px] text-[var(--g-muted)]"><%= item.finish&.label || "Aucune" %></td>
                  <td class="px-3 py-2">
                    <%= form_with scope: :color_palette_item,
                      url: admin_v2_product_color_part_item_path(product, part, item),
                      method: :patch,
                      data: { controller: "inline-form", action: "change->inline-form#submit turbo:submit-start->inline-form#pending turbo:submit-end->inline-form#complete" },
                      class: "inline-flex items-center gap-2" do |f| %>
                      <%= hidden_field_tag "color_palette_item[paid_option]", "0" %>
                      <%= f.check_box :paid_option, checked: item.paid_option, class: "rounded border-white/[0.13] bg-[var(--g-surface)] text-[var(--g-accent)] focus:ring-[var(--g-accent)]" %>
                      <span class="text-[11px] text-[var(--g-muted)]">Option payante</span>
                    <% end %>
                  </td>
                  <td class="px-3 py-2 text-right">
                    <%= button_to "Supprimer", admin_v2_product_color_part_item_path(product, part, item), method: :delete, class: "admin-v2-focus rounded-lg border border-red-300/20 bg-red-300/10 px-3 py-2 text-[11px] font-semibold text-[var(--g-red)]", form: { data: { turbo_stream: true, turbo_confirm: "Supprimer cette couleur ?" } } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>
  </div>
<% end %>
