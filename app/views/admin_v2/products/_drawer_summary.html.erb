<div id="admin_v2_product_drawer_summary" class="min-h-full">
  <div class="border-b border-white/[0.075] p-5">
    <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">Product context</p>
    <h2 class="mt-2 text-xl font-semibold text-[var(--g-text)]"><%= product.name %></h2>
    <p class="mt-1 text-sm text-[var(--g-muted)]"><%= product.category.name %></p>
  </div>

  <div class="space-y-4 p-5">
    <% if product.primary_image %>
      <div class="overflow-hidden rounded-xl border border-white/[0.075] bg-[var(--g-surface)]">
        <%= cl_image_tag(product.primary_image.key, crop: :scale, class: "h-56 w-full object-cover") %>
      </div>
    <% end %>

    <%= render AdminV2::Ui::PanelComponent.new(title: "Résumé", subtitle: "Données actuelles") do %>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Images</dt>
          <dd class="text-[var(--g-text)]"><%= product.images.size %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Documentations</dt>
          <dd class="text-[var(--g-text)]"><%= product.documentations.size %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Options</dt>
          <dd class="text-[var(--g-text)]"><%= product.options.size %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Color parts</dt>
          <dd class="text-[var(--g-text)]"><%= product.product_color_parts.size %></dd>
        </div>
      </dl>
    <% end %>

    <%= link_to "Ouvrir l’atelier edit V2", edit_admin_v2_product_path(product), data: { turbo_frame: "admin_v2_main" }, class: "admin-v2-focus flex h-10 items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-sm font-semibold text-[var(--g-accent-text)] hover:bg-[var(--g-accent-hover)]" %>
  </div>
</div>
