<div id="admin_v2_product_drawer_summary" class="relative min-h-full" style="min-height: calc(var(--admin-v2-grid-unit) * 26);">
  <div
    class="absolute left-0 top-0 flex w-full flex-col justify-center border-b border-white/[0.075] pr-5"
    style="height: calc(var(--admin-v2-grid-unit) * 4); padding-left: var(--admin-v2-grid-unit);">
    <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">Product context</p>
    <h2 class="mt-2 text-xl font-semibold text-[var(--g-text)]"><%= product.name %></h2>
    <p class="mt-1 text-sm text-[var(--g-muted)]"><%= product.category.name %></p>
  </div>

  <% if product.primary_image %>
    <div
      class="absolute overflow-hidden rounded-xl border border-white/[0.075] bg-[var(--g-surface)]"
      style="left: calc(var(--admin-v2-grid-unit) * 1); top: calc(var(--admin-v2-grid-unit) * 5); width: calc(var(--admin-v2-grid-unit) * 14); height: calc(var(--admin-v2-grid-unit) * 8);">
      <%= cl_image_tag(product.primary_image.key, crop: :scale, class: "h-full w-full object-cover") %>
    </div>
  <% end %>

  <div
    class="absolute [&>section]:h-full"
    style="left: calc(var(--admin-v2-grid-unit) * 1); top: calc(var(--admin-v2-grid-unit) * 14); width: calc(var(--admin-v2-grid-unit) * 14); height: calc(var(--admin-v2-grid-unit) * 7);">
    <%= render AdminV2::Ui::PanelComponent.new(title: "Résumé", subtitle: "Données actuelles") do %>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Images</dt>
          <dd class="text-[var(--g-text)]"><%= product.images.size %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Documentations</dt>
          <dd class="text-[var(--g-text)]"><%= product.documentations.size %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Options</dt>
          <dd class="text-[var(--g-text)]"><%= product.options.size %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Color parts</dt>
          <dd class="text-[var(--g-text)]"><%= product.product_color_parts.size %></dd>
        </div>
      </dl>
    <% end %>
  </div>

  <%= link_to "Edit factory", edit_admin_v2_product_path(product), data: { turbo_stream: true }, class: "admin-v2-focus absolute flex items-center justify-center rounded-lg bg-[var(--g-accent)] text-sm font-semibold text-black transition hover:brightness-110", style: "left: calc(var(--admin-v2-grid-unit) * 5); top: calc(var(--admin-v2-grid-unit) * 22); width: calc(var(--admin-v2-grid-unit) * 6); height: calc(var(--admin-v2-grid-unit) * 2);" %>
</div>
