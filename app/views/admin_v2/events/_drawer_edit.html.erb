<div id="admin_v2_event_drawer_edit" class="min-h-full">
  <%= render "admin_v2/events/drawer_header", event: event, eyebrow: "Event edit" %>

  <div class="space-y-4 p-5">
    <%= render "admin_v2/events/panels/details", event: event %>
    <%= render "admin_v2/events/panels/schedule", event: event %>
    <%= render "admin_v2/events/panels/preview", event: event %>

    <%= link_to "Revenir au résumé", admin_v2_event_path(event), data: { turbo_frame: "admin_v2_drawer" }, class: "admin-v2-focus flex h-10 items-center justify-center rounded-lg border border-white/[0.09] bg-white/[0.055] text-sm font-semibold text-[var(--g-text)] hover:bg-white/[0.09]" %>
  </div>
</div>
