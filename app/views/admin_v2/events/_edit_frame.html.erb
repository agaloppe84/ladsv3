<turbo-frame id="admin_v2_main">
  <div class="min-h-full">
    <header class="sticky top-0 z-10 border-b border-white/[0.075] bg-[var(--g-bg)]/90 px-7 py-5 backdrop-blur">
      <div class="flex items-end justify-between gap-5">
        <div>
          <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">admin-v2 / events / edit</p>
          <%= render "admin_v2/events/header_title", event: event %>
          <p class="mt-1 text-sm text-[var(--g-muted)]">Atelier live, sans submit global. Chaque bloc sauvegarde sa propre action.</p>
        </div>
        <div class="flex items-center gap-2">
          <%= render AdminV2::Ui::BadgeComponent.new(label: "Event##{event.id}", variant: :server) %>
          <%= render "admin_v2/events/header_status", event: event %>
        </div>
      </div>
    </header>

    <div class="grid gap-5 px-7 py-6">
      <div class="grid grid-cols-[minmax(0,1fr)_360px] gap-5">
        <div class="space-y-5">
          <%= render "admin_v2/events/panels/details", event: event %>
          <%= render "admin_v2/events/panels/preview", event: event %>
        </div>

        <div class="space-y-5">
          <%= render "admin_v2/events/panels/schedule", event: event %>
        </div>
      </div>
    </div>
  </div>
</turbo-frame>
