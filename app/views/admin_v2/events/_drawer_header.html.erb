<div
  id="admin_v2_event_drawer_header"
  class="absolute left-0 top-0 flex w-full flex-col justify-center border-b border-white/[0.075] pr-5"
  style="height: calc(var(--admin-v2-grid-unit) * 4); padding-left: var(--admin-v2-grid-unit);">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]"><%= local_assigns.fetch(:eyebrow, "Event context") %></p>
      <h2 class="mt-2 truncate text-xl font-semibold text-[var(--g-text)]"><%= event.title.presence || "Event sans titre" %></h2>
      <p class="mt-1 truncate text-sm text-[var(--g-muted)]"><%= event.content.to_s.squish.presence || "Aucun contenu public." %></p>
    </div>
    <%= render AdminV2::Events::StatusBadgeComponent.new(event: event) %>
  </div>
</div>
