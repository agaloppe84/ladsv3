<div id="admin_v2_event_drawer_summary" class="min-h-full">
  <div class="border-b border-white/[0.075] p-5">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">Event context</p>
        <h2 class="mt-2 truncate text-xl font-semibold text-[var(--g-text)]"><%= event.title.presence || "Event sans titre" %></h2>
        <p class="mt-1 text-sm text-[var(--g-muted)]"><%= event.content.to_s.squish.presence || "Aucun contenu public." %></p>
      </div>
      <%= render AdminV2::Events::StatusBadgeComponent.new(event: event) %>
    </div>
  </div>

  <div class="space-y-4 p-5">
    <%= render AdminV2::Ui::PanelComponent.new(title: "Planning", subtitle: "Fenêtre de diffusion") do %>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Début</dt>
          <dd class="text-right font-mono text-[var(--g-text)]"><%= event.start_date ? l(event.start_date, format: :long) : "Non défini" %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Fin</dt>
          <dd class="text-right font-mono text-[var(--g-text)]"><%= event.end_date ? l(event.end_date, format: :long) : "Non défini" %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">État</dt>
          <dd><%= render AdminV2::Events::StatusBadgeComponent.new(event: event) %></dd>
        </div>
      </dl>
    <% end %>

    <%= render AdminV2::Ui::PanelComponent.new(title: "Message", subtitle: "Contenu actuellement publié") do %>
      <div class="rounded-xl border border-white/[0.075] bg-white/[0.035] p-4 text-sm leading-6 text-[var(--g-muted)]">
        <% if event.content.present? %>
          <%= simple_format(event.content) %>
        <% else %>
          <p>Aucun message renseigné.</p>
        <% end %>
      </div>
    <% end %>

    <%= link_to "Ouvrir l’atelier event V2", edit_admin_v2_event_path(event), data: { turbo_stream: true }, class: "admin-v2-focus flex h-10 items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-sm font-semibold text-[var(--g-accent-text)] hover:bg-[var(--g-accent-hover)]" %>
  </div>
</div>
