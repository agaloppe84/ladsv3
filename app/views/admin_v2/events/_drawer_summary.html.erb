<div id="admin_v2_event_drawer_summary" class="relative min-h-full" style="min-height: calc(var(--admin-v2-grid-unit) * 28);">
  <%= render "admin_v2/events/drawer_header", event: event, eyebrow: "Event context" %>

  <div
    class="absolute"
    style="left: calc(var(--admin-v2-grid-unit) * 1); top: calc(var(--admin-v2-grid-unit) * 5); width: calc(var(--admin-v2-grid-unit) * 14); display: grid; gap: var(--admin-v2-grid-unit); padding-bottom: var(--admin-v2-grid-unit);">
    <%= render AdminV2::Ui::PanelComponent.new(title: "Planning", subtitle: "Fenêtre de diffusion") do %>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Début</dt>
          <dd class="text-right font-mono text-[var(--g-text)]"><%= event.start_date ? l(event.start_date, format: :long) : "Non défini" %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">Fin</dt>
          <dd class="text-right font-mono text-[var(--g-text)]"><%= event.end_date ? l(event.end_date, format: :long) : "Non défini" %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--g-subtle)]">État</dt>
          <dd><%= render AdminV2::Events::StatusBadgeComponent.new(event: event) %></dd>
        </div>
      </dl>
    <% end %>

    <%= render AdminV2::Ui::PanelComponent.new(title: "Message", subtitle: "Contenu actuellement publié") do %>
      <div class="rounded-xl border border-white/[0.075] bg-white/[0.035] p-4 text-sm leading-6 text-[var(--g-muted)]">
        <% if event.content.present? %>
          <%= simple_format(event.content) %>
        <% else %>
          <p>Aucun message renseigné.</p>
        <% end %>
      </div>
    <% end %>

    <%= link_to "Modifier dans le drawer", edit_admin_v2_event_path(event), data: { turbo_frame: "admin_v2_drawer" }, class: "admin-v2-focus flex items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-sm font-semibold text-[var(--g-accent-text)] hover:bg-[var(--g-accent-hover)]", style: "height: calc(var(--admin-v2-grid-unit) * 2);" %>
  </div>
</div>
