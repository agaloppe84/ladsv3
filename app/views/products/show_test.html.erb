<% title "#{@product.name} - Show test couleurs" %>
<% description "Version test de la fiche produit basée sur la nouvelle architecture de couleurs (parts, palettes, finitions, option payante)." %>
<% keywords "RAL, finitions, option payante, fiche produit test" %>

<%= render BreadcrumbComponent.new(breadcrumbs) %>

<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-6 lg:px-8 lg:py-8 space-y-5">
    <div class="rounded-3xl border border-slate-200 bg-white p-5">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-orange-500">Version Test</p>
          <h1 class="mt-1 text-2xl font-bold text-slate-900"><%= @product.name %></h1>
          <p class="mt-1 text-xs font-medium text-slate-500">Catégorie : <%= @product.category.name %></p>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <%= link_to "Show actuelle", product_path(slug: @product.slug), class: "inline-flex items-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100" %>
          <%= link_to "Show test v2", show_test_v2_product_path(slug: @product.slug), class: "inline-flex items-center rounded-xl border border-violet-200 bg-violet-50 px-3 py-2 text-xs font-semibold text-violet-700 transition hover:border-violet-300 hover:bg-violet-100" %>
          <%= link_to "Sélecteur toile", canvas_selector_product_path(slug: @product.slug), class: "inline-flex items-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100" %>
        </div>
      </div>

      <p class="mt-3 text-sm text-slate-600">
        Cette page est isolée et lit la nouvelle architecture de données: <span class="font-semibold">parts</span>,
        <span class="font-semibold">palettes</span>, <span class="font-semibold">finitions</span> et
        <span class="font-semibold">option payante</span>.
      </p>
    </div>

    <% if @product_color_parts.any? %>
      <div class="space-y-4">
        <% @product_color_parts.each do |part| %>
          <% palette = part.color_palette %>
          <% items = palette.color_palette_items.sort_by { |item| [item.ral&.collection.to_s, item.ral&.ref.to_s, item.finish&.label.to_s] } %>

          <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white">
            <header class="border-b border-slate-200 bg-slate-50 px-5 py-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div>
                  <h2 class="text-base font-bold text-slate-900"><%= part.label %></h2>
                  <p class="text-xs font-medium text-slate-500">
                    Code: <span class="font-semibold text-slate-700"><%= part.code %></span>
                    | Palette: <span class="font-semibold text-slate-700"><%= palette.name %></span>
                  </p>
                </div>
                <span class="inline-flex items-center rounded-full bg-orange-50 px-2.5 py-1 text-xs font-semibold text-orange-700 ring-1 ring-inset ring-orange-100">
                  <%= items.size %> couleur<%= "s" if items.size > 1 %>
                </span>
              </div>
            </header>

            <div class="p-5">
              <% if items.empty? %>
                <p class="text-sm text-slate-500">Aucune couleur configurée pour cette part.</p>
              <% else %>
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-slate-200">
                    <thead>
                      <tr>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500">RAL</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500">Collection</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500">Finition</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500">Statut</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                      <% items.each do |item| %>
                        <% ral = item.ral %>
                        <tr>
                          <td class="px-3 py-2">
                            <div class="flex items-center gap-2">
                              <span class="h-5 w-5 rounded-full border border-slate-300" style="background-color: <%= ral&.hex.presence || '#e2e8f0' %>;"></span>
                              <div class="text-xs">
                                <p class="font-semibold text-slate-800"><%= ral&.ref || "RAL inconnu" %></p>
                                <p class="text-slate-500"><%= ral&.name || "Nom indisponible" %></p>
                              </div>
                            </div>
                          </td>
                          <td class="px-3 py-2 text-xs text-slate-600"><%= ral&.collection || "-" %></td>
                          <td class="px-3 py-2 text-xs text-slate-600"><%= item.finish&.label || "Sans finition" %></td>
                          <td class="px-3 py-2">
                            <% if item.paid_option %>
                              <span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-1 text-[11px] font-semibold text-amber-700 ring-1 ring-inset ring-amber-100">
                                Option payante
                              </span>
                            <% else %>
                              <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-1 text-[11px] font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-100">
                                Inclus
                              </span>
                            <% end %>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-8 text-center">
        <p class="text-sm font-semibold text-slate-700">Aucune part couleur n’est configurée sur ce produit.</p>
        <p class="mt-2 text-xs text-slate-500">Passe par l’admin Product Configurator pour créer les parts et palettes.</p>
      </div>
    <% end %>

    <div class="rounded-3xl border border-slate-200 bg-white p-5">
      <h3 class="text-sm font-bold text-slate-900">Legacy (source historique)</h3>
      <p class="mt-1 text-xs text-slate-500">RAL liés directement au produit via `products_rals`.</p>

      <% if @legacy_rals.any? %>
        <ul role="list" class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-6">
          <% @legacy_rals.each do |ral| %>
            <li class="rounded-xl border border-slate-200 bg-white p-2">
              <div class="mx-auto h-6 w-6 rounded-full border border-slate-300" style="background-color: <%= ral.hex %>;"></div>
              <p class="mt-1 text-center text-[11px] font-semibold text-slate-700"><%= ral.ref %></p>
              <p class="truncate text-center text-[10px] text-slate-500"><%= ral.name %></p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-3 text-xs text-slate-500">Aucun RAL legacy sur ce produit.</p>
      <% end %>
    </div>
  </div>
</section>
