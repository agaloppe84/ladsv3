<% title "#{@product.name} - Sélecteur de toile" %>
<% description "Sélecteur de toile Dickson" %>
<% keywords "Dickson, toile, configurateur" %>

<%= render BreadcrumbComponent.new(breadcrumbs) %>

<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-6 lg:px-8 lg:py-8">
    <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 px-4 py-3">
        <h1 class="text-base font-bold text-slate-900">Sélecteur de toile Dickson</h1>
        <%= link_to "Retour produit", product_path(@product), class: "inline-flex items-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100" %>
      </div>

      <div class="h-[80vh] w-full">
        <iframe src="https://www.dicksondesigner.com/fr/?code=fa20cd8b2281f8a585592eaab2e053b3" frameborder="0" class="h-full w-full"></iframe>
      </div>
    </div>
  </div>
</section>
