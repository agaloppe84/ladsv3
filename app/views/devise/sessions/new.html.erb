<div class="admin-v2 admin-v2-login admin-v2-grid-bg min-h-full overflow-hidden font-mono">
  <div class="grid h-full grid-cols-1 lg:grid-cols-[minmax(420px,520px)_minmax(0,1fr)]">
    <section class="flex min-h-0 flex-col border-r border-white/[0.075] bg-[var(--g-bg-soft)]/95">
      <div class="border-b border-white/[0.075] px-6 py-5">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-[var(--g-accent-text)]">
            <%= inline_svg_tag("logos/ads-logo-full-cleaned.svg", class: "h-6 w-6 shrink-0") %>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-[0.28em] text-[var(--g-subtle)]">Graphite</p>
            <h1 class="mt-1 text-lg font-semibold text-[var(--g-text)]">Store Console</h1>
          </div>
        </div>
      </div>

      <div class="flex flex-1 items-center px-6 py-10">
        <div class="w-full">
          <div class="mb-7">
            <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">admin-v2 / auth / login</p>
            <h2 class="mt-3 text-2xl font-semibold text-[var(--g-text)]">Connexion admin</h2>
            <p class="mt-2 text-sm text-[var(--g-muted)]">Accède à l'interface live catalogue.</p>
          </div>

          <div class="overflow-hidden rounded-xl border border-white/[0.075] bg-[var(--g-surface)]/88 shadow-[0_20px_80px_rgba(0,0,0,0.18)]">
            <div class="border-b border-white/[0.075] px-4 py-3">
              <h3 class="text-xs uppercase tracking-[0.2em] text-[var(--g-accent)]">Accès</h3>
              <p class="mt-1 text-[10px] text-[var(--g-faint)]">Session sécurisée</p>
            </div>

            <div class="p-4">
              <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
                <div>
                  <%= f.label :email, "Email", class: "mb-1 block text-[11px] font-semibold text-[var(--g-subtle)]" %>
                  <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    class: "admin-v2-focus h-10 w-full rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 text-sm text-[var(--g-text)] placeholder:text-[var(--g-faint)] focus:border-[var(--g-accent-border)] focus:ring-0",
                    placeholder: "admin@domain.tld" %>
                </div>

                <div>
                  <%= f.label :password, "Mot de passe", class: "mb-1 block text-[11px] font-semibold text-[var(--g-subtle)]" %>
                  <%= f.password_field :password,
                    autocomplete: "current-password",
                    class: "admin-v2-focus h-10 w-full rounded-lg border border-white/[0.09] bg-white/[0.045] px-3 text-sm text-[var(--g-text)] placeholder:text-[var(--g-faint)] focus:border-[var(--g-accent-border)] focus:ring-0",
                    placeholder: "********" %>
                </div>

                <% if devise_mapping.rememberable? %>
                  <label class="flex items-center gap-3 rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 py-2 text-[11px] font-semibold text-[var(--g-muted)]">
                    <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-white/[0.12] bg-[var(--g-surface-inset)] text-[var(--g-accent)] focus:ring-[var(--g-accent)] focus:ring-offset-0" %>
                    Se souvenir de moi
                  </label>
                <% end %>

                <button
                  type="submit"
                  class="admin-v2-focus inline-flex h-10 w-full items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-4 text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--g-accent-text)] transition hover:bg-[var(--g-accent-hover)]">
                  Se connecter
                </button>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative hidden min-h-0 overflow-hidden lg:block">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_28%_18%,rgba(var(--g-accent-rgb),0.22),transparent_30rem),linear-gradient(180deg,#10131a_0%,var(--g-bg)_58%)]"></div>
      <div class="absolute inset-x-0 top-0 border-b border-white/[0.075] px-7 py-5">
        <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-faint)]">live-interface / turbo / ready</p>
      </div>

      <div class="relative flex h-full items-center justify-center px-10">
        <div class="w-full max-w-2xl overflow-hidden rounded-xl border border-white/[0.075] bg-[linear-gradient(135deg,rgba(var(--g-accent-rgb),0.1),rgba(255,255,255,0.025)_34%,rgba(255,255,255,0.015))] shadow-[0_40px_140px_rgba(0,0,0,0.32)]">
          <div class="flex items-center justify-between border-b border-white/[0.075] px-5 py-4">
            <div>
              <p class="text-[10px] uppercase tracking-[0.24em] text-[var(--g-accent-text)]">Boot preview</p>
              <p class="mt-1 text-[11px] text-[var(--g-subtle)]">Console session handshake</p>
            </div>
            <span class="inline-flex items-center gap-2 rounded-lg border border-emerald-300/20 bg-emerald-300/10 px-2.5 py-1.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--g-green)]">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--g-green)] shadow-[0_0_18px_rgba(117,214,123,0.55)]"></span>
              standby
            </span>
          </div>

          <div class="admin-v2-grid-bg p-5">
            <div class="rounded-xl border border-white/[0.075] bg-[var(--g-surface-inset)]/92 p-3">
              <% [
                ["system", "auth gateway available"],
                ["server", "env available"],
                ["success", "status: OK"],
                ["info", "waiting for operator"]
              ].each do |level, message| %>
                <div class="grid grid-cols-[8px_72px_minmax(0,1fr)] items-start gap-2 border-b border-white/[0.055] px-2 py-2 last:border-b-0">
                  <span class="mt-1.5 h-1.5 w-1.5 rounded-full <%= level == "success" ? "bg-[var(--g-green)]" : level == "server" ? "bg-[var(--g-cyan)]" : level == "info" ? "bg-[var(--g-accent)]" : "bg-[var(--g-faint)]" %>"></span>
                  <span class="text-[9px] uppercase tracking-[0.16em] <%= level == "success" ? "text-[var(--g-green)]" : level == "server" ? "text-[var(--g-cyan)]" : level == "info" ? "text-[var(--g-accent)]" : "text-[var(--g-faint)]" %>"><%= level %></span>
                  <span class="min-w-0 truncate text-[11px] text-[var(--g-muted)]"><%= message %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
