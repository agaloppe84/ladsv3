<div class="px-6 pb-6 space-y-6">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 pt-4">
    <div class="border border-slate-100 rounded p-4">
      <p class="text-[11px] font-semibold text-slate-700 mb-3">Créer une finition</p>

      <%= form_with scope: :finish, url: create_finish_admin_product_configurator_path(product), method: :post, class: "space-y-3" do |f| %>
        <div>
          <%= f.label :code, "Code", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
          <%= f.text_field :code, class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
        </div>
        <div>
          <%= f.label :label, "Nom", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
          <%= f.text_field :label, class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
        </div>
        <%= f.submit "Ajouter la finition", class: "border rounded px-3 py-1 font-semibold border-violet-200 text-violet-600 text-[11px] hover:bg-violet-50" %>
      <% end %>
    </div>

    <div class="border border-slate-100 rounded p-4" data-controller="part-form">
      <p class="text-[11px] font-semibold text-slate-700 mb-3">Créer une part couleur</p>

      <%= form_with scope: :product_color_part, url: create_part_admin_product_configurator_path(product), method: :post, class: "space-y-3" do |f| %>
        <div>
          <%= f.label :label, "Label de la part", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
          <%= f.text_field :label,
                           class: "w-full border border-slate-200 rounded px-2 py-1 text-xs",
                           data: { "part-form-target": "label", action: "input->part-form#syncCode" } %>
        </div>
        <div>
          <%= f.label :code, "Code part (unique sur le produit)", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
          <%= f.text_field :code,
                           class: "w-full border border-slate-200 rounded px-2 py-1 text-xs",
                           data: { "part-form-target": "code", action: "input->part-form#markManualEdit" } %>
        </div>
        <div>
          <%= f.label :palette_name, "Nom de la palette", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
          <%= f.text_field :palette_name, class: "w-full border border-slate-200 rounded px-2 py-1 text-xs", placeholder: "Optionnel" %>
        </div>
        <%= f.submit "Ajouter la part", class: "border rounded px-3 py-1 font-semibold border-violet-200 text-violet-600 text-[11px] hover:bg-violet-50" %>
      <% end %>
    </div>
  </div>

  <div class="space-y-4">
    <% if product_color_parts.empty? %>
      <div class="border border-slate-100 rounded bg-slate-50 p-5 text-[11px] font-medium text-slate-500">
        Aucune part configurée pour ce produit.
      </div>
    <% end %>

    <% product_color_parts.each do |part| %>
      <% palette = part.color_palette %>
      <% items = palette.color_palette_items.sort_by { |item| [item.ral&.collection.to_s, item.ral&.ref.to_s, item.finish&.label.to_s] } %>

      <div class="border border-slate-100 rounded">
        <div class="border-b border-slate-100 px-4 py-3 bg-slate-50">
          <p class="text-[12px] font-semibold text-slate-700"><%= part.label %></p>
          <p class="text-[10px] text-slate-500">Code: <span class="font-semibold"><%= part.code %></span> | Palette: <span class="font-semibold"><%= palette.name %></span></p>
        </div>

        <div class="p-4 space-y-4">
          <%= form_with scope: :product_color_part, url: part_admin_product_configurator_path(product, part_id: part.id), method: :patch, class: "grid grid-cols-1 lg:grid-cols-4 gap-3 items-end" do |f| %>
            <div>
              <%= f.label :label, "Label", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
              <%= f.text_field :label, value: part.label, class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
            </div>
            <div>
              <%= f.label :code, "Code", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
              <%= f.text_field :code, value: part.code, class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
            </div>
            <div>
              <%= f.label :palette_name, "Nom palette", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
              <%= f.text_field :palette_name, value: palette.name, class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
            </div>
            <div class="flex items-center space-x-2">
              <%= f.submit "Mettre à jour", class: "border rounded px-3 py-1 font-semibold border-violet-200 text-violet-600 text-[11px] hover:bg-violet-50" %>
              <%= link_to "Supprimer",
                          destroy_part_admin_product_configurator_path(product, part_id: part.id),
                          data: { turbo_method: :delete, turbo_confirm: "Supprimer cette part et sa palette si elle n'est plus utilisée ?" },
                          class: "border rounded px-3 py-1 font-semibold border-red-200 text-red-600 text-[11px] hover:bg-red-50" %>
            </div>
          <% end %>

          <div class="border border-slate-100 rounded p-3">
            <p class="text-[11px] font-semibold text-slate-700 mb-2">Ajouter une couleur à la palette</p>
            <%= form_with scope: :color_palette_item, url: part_items_admin_product_configurator_path(product, part_id: part.id), method: :post, class: "grid grid-cols-1 lg:grid-cols-4 gap-3 items-end" do |f| %>
              <div class="lg:col-span-2">
                <%= f.label :ral_id, "RAL", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
                <%= f.select :ral_id,
                             options_for_select(rals.map { |ral| ["#{ral.ref} - #{ral.name}", ral.id] }),
                             { include_blank: "Sélectionnez un RAL" },
                             class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
              </div>
              <div>
                <%= f.label :finish_id, "Finition (optionnelle)", class: "block text-[10px] font-semibold text-slate-500 mb-1" %>
                <%= f.select :finish_id,
                             options_for_select(finishes.map { |finish| ["#{finish.label} (#{finish.code})", finish.id] }),
                             { include_blank: "Sans finition" },
                             class: "w-full border border-slate-200 rounded px-2 py-1 text-xs" %>
              </div>
              <div class="flex items-center justify-between border border-slate-100 rounded px-2 py-1 h-[30px]">
                <div class="flex items-center space-x-2">
                  <%= f.check_box :paid_option, class: "rounded border-slate-300 text-violet-500 focus:ring-violet-300" %>
                  <%= f.label :paid_option, "Option payante", class: "text-[10px] font-semibold text-slate-600" %>
                </div>
                <%= f.submit "Ajouter", class: "border rounded px-2 py-1 font-semibold border-violet-200 text-violet-600 text-[10px] hover:bg-violet-50" %>
              </div>
            <% end %>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100">
              <thead>
                <tr>
                  <th class="px-3 py-2 text-left text-[10px] font-semibold text-slate-500">RAL</th>
                  <th class="px-3 py-2 text-left text-[10px] font-semibold text-slate-500">Finition</th>
                  <th class="px-3 py-2 text-left text-[10px] font-semibold text-slate-500">Statut</th>
                  <th class="px-3 py-2 text-right text-[10px] font-semibold text-slate-500">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% if items.empty? %>
                  <tr>
                    <td colspan="4" class="px-3 py-4 text-[11px] font-medium text-slate-400">Aucune couleur dans cette palette.</td>
                  </tr>
                <% end %>

                <% items.each do |item| %>
                  <tr>
                    <td class="px-3 py-2 text-[11px] text-slate-700">
                      <span class="font-semibold"><%= item.ral.ref %></span> - <%= item.ral.name %>
                    </td>
                    <td class="px-3 py-2 text-[11px] text-slate-700">
                      <%= item.finish&.label || "Aucune" %>
                    </td>
                    <td class="px-3 py-2 text-[11px]">
                      <%= form_with scope: :color_palette_item, url: part_item_admin_product_configurator_path(product, part_id: part.id, item_id: item.id), method: :patch, class: "inline-flex items-center space-x-2" do |f| %>
                        <%= f.check_box :paid_option, { checked: item.paid_option, class: "rounded border-slate-300 text-violet-500 focus:ring-violet-300" } %>
                        <%= f.label :paid_option, "Option payante", class: "text-[10px] font-semibold text-slate-600" %>
                        <%= f.submit "OK", class: "border rounded px-2 py-1 font-semibold border-slate-200 text-slate-600 text-[10px] hover:bg-slate-50" %>
                      <% end %>
                    </td>
                    <td class="px-3 py-2 text-right">
                      <%= link_to "Supprimer",
                                  destroy_item_admin_product_configurator_path(product, part_id: part.id, item_id: item.id),
                                  data: { turbo_method: :delete, turbo_confirm: "Supprimer cette couleur de la palette ?" },
                                  class: "border rounded px-2 py-1 font-semibold border-red-200 text-red-600 text-[10px] hover:bg-red-50" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
