<section class="w-full bg-white border-y border-slate-100">
  <nav class="flex p-2 bg-white max-w-7xl mx-auto text-sm font-semibold" aria-label="Breadcrumb">
    <ol role="list" class="flex items-center p-3 px-5">

      <% @breadcrumbs.each do |crumb| %>
        <li class="flex items-center">
          <% if crumb.link? %>
            <%= link_to crumb.name, crumb.path, class: "text-gray-700 hover:text-gray-500 transition" %>
          <% else %>
            <div class="flex items-center">
              <div class="text-orange-500 truncate text-ellipsis"><%= crumb.name %></div>
            </div>
          <% end %>

          <% unless crumb == @breadcrumbs.last %>
            <div class="flex items-center mx-1">
              <svg class="pt-[2px] h-6 w-6 flex-shrink-0 text-gray-300" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
              </svg>
            </div>
          <% end %>

          <% if crumb.count? %>
            <span class="hidden inline-flex items-center rounded-full bg-orange-50 px-2 py-1 text-sm font-medium text-orange-700 ring-1 ring-inset ring-orange-700/10 ml-4"><%= "#{crumb.count} produits" %></span>
          <% end %>

        </li>
      <% end %>

    </ol>
  </nav>
</section>