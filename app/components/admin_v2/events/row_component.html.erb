<article id="admin_v2_event_<%= event.id %>" class="group flex items-center gap-4 rounded-xl border border-white/[0.075] bg-[linear-gradient(135deg,rgba(var(--g-accent-rgb),0.08),rgba(255,255,255,0.025)_34%,rgba(255,255,255,0.015))] p-4 transition hover:border-[var(--g-accent-border)] hover:bg-[linear-gradient(135deg,rgba(var(--g-accent-rgb),0.12),rgba(255,255,255,0.035)_38%,rgba(255,255,255,0.018))]">
  <%= link_to admin_v2_event_path(event), data: { turbo_frame: "admin_v2_drawer" }, class: "min-w-0 flex-1" do %>
    <p class="truncate text-base font-semibold text-[var(--g-text)]"><%= title %></p>
    <p class="mt-1 truncate text-[11px] text-[var(--g-subtle)]">Event#<%= event.id %> · <%= content_preview %></p>
  <% end %>

  <div class="grid w-72 shrink-0 grid-cols-2 gap-2">
    <span class="truncate rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 py-2 text-center text-[10px] font-bold text-[var(--g-muted)]">
      <span class="text-[var(--g-faint)]">from</span>
      <span class="ml-1 font-mono"><%= formatted_datetime(event.start_date) %></span>
    </span>
    <span class="truncate rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 py-2 text-center text-[10px] font-bold text-[var(--g-muted)]">
      <span class="text-[var(--g-faint)]">to</span>
      <span class="ml-1 font-mono"><%= formatted_datetime(event.end_date) %></span>
    </span>
  </div>

  <div class="flex shrink-0 items-center gap-2">
    <%= render AdminV2::Events::StatusBadgeComponent.new(event: event) %>
  </div>

  <div class="flex shrink-0 justify-end gap-2">
    <%= link_to admin_v2_event_path(event), data: { turbo_frame: "admin_v2_drawer" }, title: "Ouvrir le context drawer", class: "admin-v2-focus inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/[0.075] bg-white/[0.035] text-[var(--g-accent)] transition hover:border-[var(--g-accent-border)] hover:bg-[var(--g-accent-soft)]" do %>
      <span class="sr-only">Ouvrir le context drawer</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17 17 7" />
        <path d="M8 7h9v9" />
      </svg>
    <% end %>

    <%= link_to edit_admin_v2_event_path(event), data: { turbo_stream: true }, title: "Éditer l’event", class: "admin-v2-focus inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-[var(--g-accent)] transition hover:bg-[var(--g-accent-hover)]" do %>
      <span class="sr-only">Éditer l’event</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
      </svg>
    <% end %>
  </div>
</article>
