<% if disabled? %>
  <span class="<%= classes %>">
    <span><%= label %></span>
    <% if count %>
      <span class="text-[10px] text-[var(--g-faint)]"><%= count %></span>
    <% end %>
  </span>
<% else %>
  <%= link_to path, class: classes, data: data do %>
    <span><%= label %></span>
    <% if count %>
      <span class="text-[10px] <%= active? ? "text-[var(--g-accent)]" : "text-[var(--g-subtle)]" %>"><%= count %></span>
    <% end %>
  <% end %>
<% end %>
