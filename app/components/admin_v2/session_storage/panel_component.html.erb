<div id="admin_v2_session_storage_panel" data-controller="disclosure" class="mt-1">
  <button
    type="button"
    class="admin-v2-focus flex h-9 w-full items-center justify-between rounded-lg border border-transparent px-3 text-[12px] font-medium text-[var(--g-muted)] transition hover:border-white/[0.075] hover:bg-white/[0.035] hover:text-[var(--g-text)]"
    aria-expanded="false"
    data-disclosure-target="button"
    data-action="disclosure#toggle">
    <span>Session storage</span>
    <span class="flex items-center gap-2">
      <span class="font-mono text-[10px] text-[var(--g-subtle)]"><%= stats.prunable_sessions_count %></span>
      <svg data-disclosure-target="icon" viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5 text-[var(--g-subtle)] transition-transform" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </span>
  </button>

  <div data-disclosure-target="panel" class="hidden px-2 pb-2 pt-2">
    <div class="rounded-lg border border-white/[0.06] bg-white/[0.025] p-2.5">
      <dl class="grid gap-1.5">
        <% [
          ["sessions", stats.sessions_total],
          ["events", stats.events_total],
          ["kept", "#{stats.keep_count} latest"],
          ["prunable", stats.prunable_sessions_count],
          ["event drop", stats.prunable_events_count]
        ].each do |label, value| %>
          <div class="flex items-center justify-between gap-3 text-[9px]">
            <dt class="font-semibold uppercase tracking-[0.16em] text-[var(--g-faint)]"><%= label %></dt>
            <dd class="max-w-24 truncate text-right font-mono text-[var(--g-subtle)]"><%= value %></dd>
          </div>
        <% end %>
      </dl>

      <%= button_to "Purger",
                    prune_admin_v2_session_storage_path,
                    method: :post,
                    disabled: !prunable?,
                    class: purge_classes,
                    form: {
                      data: {
                        turbo_stream: true,
                        turbo_confirm: "Purger les anciennes sessions Admin V2 ? Les #{stats.keep_count} dernières sessions seront conservées."
                      }
                    } %>
    </div>
  </div>
</div>
