<div
  class="absolute z-10 text-center"
  style="left: calc(var(--admin-v2-grid-unit) * 1); top: calc(var(--admin-v2-grid-unit) * 1); width: calc(var(--admin-v2-grid-unit) * 14); height: calc(var(--admin-v2-grid-unit) * 6);">
  <section
    class="flex h-full items-center justify-center overflow-hidden rounded-2xl border bg-transparent px-7"
    style="border-color: rgba(var(--g-accent-rgb), 0.16); box-shadow: inset 0 0 0 1px rgba(var(--g-accent-rgb), 0.045), 0 20px 80px rgba(0, 0, 0, 0.24);">
    <div>
      <p class="text-[10px] uppercase tracking-[0.28em] text-[var(--g-accent)]"><%= title %></p>

      <% if message.present? %>
        <p class="mt-3 text-[11px] leading-5 tracking-normal text-[var(--g-accent-text)]"><%= message %></p>
      <% end %>
    </div>
  </section>
</div>
