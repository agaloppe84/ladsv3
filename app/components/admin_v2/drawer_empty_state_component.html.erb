<div
  class="absolute z-10 text-center"
  style="left: calc(var(--admin-v2-grid-unit) * 1); top: calc(var(--admin-v2-grid-unit) * 1); width: calc(var(--admin-v2-grid-unit) * 22); height: calc(var(--admin-v2-grid-unit) * 6);">
  <section
    class="relative h-full overflow-hidden rounded-2xl border border-dashed bg-transparent"
    style="border-color: rgba(var(--g-accent-rgb), 0.32);">
    <div
      class="absolute inset-x-0 px-6"
      style="top: var(--admin-v2-grid-unit);">
      <div
        class="mx-auto flex items-center justify-center"
        style="width: calc(var(--admin-v2-grid-unit) * 10); height: var(--admin-v2-grid-unit);">
        <p
          class="text-[10px] uppercase tracking-[0.28em] text-[var(--g-accent)]"
          style="line-height: var(--admin-v2-grid-unit);"><%= title %></p>
      </div>

      <% if message.present? %>
        <p
          class="-translate-y-0.5 text-[11px] tracking-normal text-[var(--g-accent-text)]"
          style="margin-top: var(--admin-v2-grid-unit); line-height: var(--admin-v2-grid-unit);"><%= message %></p>
      <% end %>
    </div>
  </section>
</div>
