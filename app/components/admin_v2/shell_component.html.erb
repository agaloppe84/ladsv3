<div class="admin-v2-shell relative grid h-dvh grid-cols-[296px_minmax(720px,1fr)_500px] overflow-hidden">
  <aside class="flex min-h-0 flex-col border-r border-white/[0.075] bg-[var(--g-bg-soft)]/95">
    <div class="border-b border-white/[0.075] px-5 py-5">
      <p class="text-[10px] uppercase tracking-[0.28em] text-[var(--g-subtle)]">Graphite</p>
      <div class="mt-1 flex items-center gap-3">
        <h1 class="text-lg font-semibold text-[var(--g-text)]">Store Console</h1>
        <%= render AdminV2::BrandOrbitComponent.new %>
      </div>
    </div>

    <nav class="admin-v2-scrollbar min-h-0 flex-1 overflow-y-auto px-3 py-4">
      <%= render "admin_v2/shared/store_nav", active: active %>

      <%= render AdminV2::SidebarSectionComponent.new(title: "Operations") do %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Imports", path: "#", disabled: true) %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Exports", path: "#", disabled: true) %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Session feed", path: "#", disabled: true) %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Webhooks", path: "#", disabled: true) %>
      <% end %>

      <%= render AdminV2::SidebarSectionComponent.new(title: "Configuration") do %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Utilisateurs", path: "#", disabled: true) %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Rôles", path: "#", disabled: true) %>
        <%= render AdminV2::SidebarItemComponent.new(label: "Paramètres", path: "#", disabled: true) %>
      <% end %>

      <section class="mb-7 px-2" data-controller="color-theme">
        <h2 class="text-[10px] uppercase tracking-[0.22em] text-[var(--g-faint)]">Accent</h2>
        <div class="mt-3 grid grid-cols-5 gap-2">
          <% [
            ["Violet", "124, 92, 255", "#d9d2ff", "#7c5cff"],
            ["Indigo", "99, 102, 241", "#d7d8ff", "#6366f1"],
            ["Cyan", "103, 216, 239", "#cff6ff", "#67d8ef"],
            ["Teal", "45, 212, 191", "#c7fff5", "#2dd4bf"],
            ["Green", "117, 214, 123", "#d8ffdc", "#75d67b"],
            ["Lime", "190, 242, 100", "#efffd1", "#bef264"],
            ["Amber", "245, 196, 81", "#fff0c4", "#f5c451"],
            ["Coral", "255, 104, 104", "#ffd0d0", "#ff6868"],
            ["Rose", "244, 114, 182", "#ffd4e9", "#f472b6"],
            ["Slate", "148, 163, 184", "#e5edf7", "#94a3b8"]
          ].each_with_index do |(label, rgb, text, hex), index| %>
            <button
              type="button"
              title="<%= label %>"
              aria-label="<%= label %>"
              aria-pressed="<%= index.zero? ? "true" : "false" %>"
              data-color-theme-target="button"
              data-action="color-theme#select"
              data-label="<%= label %>"
              data-rgb="<%= rgb %>"
              data-text="<%= text %>"
              class="admin-v2-focus flex h-8 items-center justify-center rounded-lg border <%= index.zero? ? "border-[var(--g-accent-border)] bg-[var(--g-accent-soft)]" : "border-white/[0.075]" %>">
              <span class="h-3.5 w-3.5 rounded-full" style="background:<%= hex %>"></span>
            </button>
          <% end %>
        </div>
      </section>

      <section class="mb-7 px-2" data-controller="font-theme">
        <h2 class="text-[10px] uppercase tracking-[0.22em] text-[var(--g-faint)]">Typography</h2>
        <div class="mt-3 grid grid-cols-2 gap-2">
          <button
            type="button"
            aria-pressed="true"
            data-font-theme-target="button"
            data-action="font-theme#select"
            data-label="Sans"
            data-font-variable="--g-font-sans"
            class="admin-v2-focus h-8 rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-3 text-[11px] font-semibold text-[var(--g-accent-text)]">
            Sans
          </button>
          <button
            type="button"
            aria-pressed="false"
            data-font-theme-target="button"
            data-action="font-theme#select"
            data-label="Mono"
            data-font-variable="--g-font-mono"
            class="admin-v2-focus h-8 rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 text-[11px] font-semibold text-[var(--g-muted)] hover:text-[var(--g-text)]">
            Mono
          </button>
        </div>
      </section>
    </nav>

    <div class="border-t border-white/[0.075] px-5 py-4">
      <%= render "admin_v2/sessions/report", current_user: current_user, admin_v2_session: admin_v2_session, active: active %>
      <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "mt-2 text-[11px] font-semibold text-[var(--g-subtle)] hover:text-[var(--g-text)]" %>
    </div>
  </aside>

  <main class="admin-v2-scrollbar min-h-0 overflow-y-auto">
    <%= content %>
  </main>

  <aside class="grid min-h-0 grid-rows-[248px_minmax(0,1fr)] border-l border-white/[0.075] bg-[var(--g-bg-soft)]/90">
    <%= render AdminV2::SessionFeedComponent.new(admin_v2_session: admin_v2_session) %>
    <turbo-frame id="admin_v2_drawer" class="admin-v2-grid-bg admin-v2-scrollbar min-h-0 overflow-y-auto">
      <% if drawer %>
        <%= drawer %>
      <% else %>
        <div class="flex h-full items-center justify-center px-8 text-center">
          <div>
            <p class="text-[10px] uppercase tracking-[0.26em] text-[var(--g-faint)]">Context drawer</p>
            <p class="mt-2 text-[11px] tracking-normal text-[var(--g-accent-text)]">Sélectionne un produit ou une action pour ouvrir son contexte.</p>
          </div>
        </div>
      <% end %>
    </turbo-frame>
  </aside>

  <% if show_boot_panel %>
    <%= render AdminV2::BootPanelComponent.new(current_user: current_user) %>
  <% end %>
</div>
