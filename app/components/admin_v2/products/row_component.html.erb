<article id="admin_v2_product_<%= product.id %>" class="group flex items-center gap-4 rounded-xl border border-white/[0.075] bg-[linear-gradient(135deg,rgba(var(--g-accent-rgb),0.08),rgba(255,255,255,0.025)_34%,rgba(255,255,255,0.015))] p-4 transition hover:border-[var(--g-accent-border)] hover:bg-[linear-gradient(135deg,rgba(var(--g-accent-rgb),0.12),rgba(255,255,255,0.035)_38%,rgba(255,255,255,0.018))]">
  <%= link_to admin_v2_product_path(product), data: { turbo_frame: "admin_v2_drawer" }, class: "min-w-0 flex-1" do %>
    <p class="truncate text-base font-semibold text-[var(--g-text)]"><%= product.name %></p>
    <p class="mt-1 text-[11px] text-[var(--g-subtle)]">Product#<%= product.id %> · <%= category_name %></p>
  <% end %>

  <div class="flex shrink-0 items-center gap-2">
    <span class="min-w-40 truncate rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 py-2 text-center text-[11px] font-bold capitalize text-[var(--g-muted)]"><%= category_name %></span>
    <span class="rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-3 py-2 text-[11px] font-bold text-[var(--g-accent)]"><%= product.images.size %> images</span>
    <span class="rounded-lg border border-white/[0.075] bg-white/[0.035] px-3 py-2 text-[11px] font-bold text-[var(--g-muted)]"><%= product.documentations.size %> docs</span>
  </div>

  <div class="flex shrink-0 justify-end gap-2">
    <%= link_to admin_v2_product_path(product), data: { turbo_frame: "admin_v2_drawer" }, title: "Ouvrir la fiche", class: "admin-v2-focus inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/[0.075] bg-white/[0.035] text-[var(--g-accent)] transition hover:border-[var(--g-accent-border)] hover:bg-[var(--g-accent-soft)]" do %>
      <span class="sr-only">Ouvrir la fiche</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17 17 7" />
        <path d="M8 7h9v9" />
      </svg>
    <% end %>

    <%= link_to edit_admin_v2_product_path(product), data: { turbo_stream: true }, title: "Éditer le produit", class: "admin-v2-focus inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] text-[var(--g-accent)] transition hover:bg-[var(--g-accent-hover)]" do %>
      <span class="sr-only">Éditer le produit</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
      </svg>
    <% end %>

    <%= button_to admin_v2_product_path(product),
                  method: :delete,
                  params: index_params,
                  title: "Supprimer le produit",
                  class: "admin-v2-focus inline-flex h-9 w-9 items-center justify-center rounded-lg border border-red-300/20 bg-red-300/10 text-[var(--g-red)] transition hover:bg-red-300/15",
                  form: {
                    data: {
                      turbo_stream: true,
                      turbo_confirm: "Supprimer Product##{product.id} ?",
                      admin_v2_confirm: true,
                      admin_v2_confirm_title: "Supprimer ce produit ?",
                      admin_v2_confirm_body: "Cette action supprime le produit, ses options, son service, ses médias, ses documentations et sa configuration couleur. La page publique du produit disparaîtra aussi.",
                      admin_v2_confirm_action: "Supprimer"
                    }
                  } do %>
      <span class="sr-only">Supprimer le produit</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 6h18" />
        <path d="M8 6V4h8v2" />
        <path d="M19 6l-1 14H6L5 6" />
        <path d="M10 11v5" />
        <path d="M14 11v5" />
      </svg>
    <% end %>
  </div>
</article>
