<nav class="flex items-center justify-between gap-4" aria-label="Pagination">
  <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--g-faint)]">
    <%= summary %>
  </p>

  <div class="flex items-center gap-1.5">
    <% if pagination.previous_page %>
      <%= link_to page_path(pagination.previous_page), data: { turbo_frame: frame }, class: link_classes do %>
        <span class="sr-only">Page precedente</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6" />
        </svg>
      <% end %>
    <% else %>
      <span class="<%= link_classes(disabled: true) %>">
        <span class="sr-only">Page precedente indisponible</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6" />
        </svg>
      </span>
    <% end %>

    <% page_items.each do |item| %>
      <% if item == :gap %>
        <span class="flex h-8 min-w-8 items-center justify-center text-[10px] font-semibold text-[var(--g-faint)]">...</span>
      <% else %>
        <%= link_to item, page_path(item), data: { turbo_frame: frame }, aria: { current: item == pagination.page ? "page" : nil }, class: link_classes(active: item == pagination.page) %>
      <% end %>
    <% end %>

    <% if pagination.next_page %>
      <%= link_to page_path(pagination.next_page), data: { turbo_frame: frame }, class: link_classes do %>
        <span class="sr-only">Page suivante</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      <% end %>
    <% else %>
      <span class="<%= link_classes(disabled: true) %>">
        <span class="sr-only">Page suivante indisponible</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    <% end %>
  </div>
</nav>
