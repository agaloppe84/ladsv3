<section id="<%= id %>" class="overflow-hidden rounded-xl border border-white/[0.075] bg-[var(--g-surface)]/88 shadow-[0_20px_80px_rgba(0,0,0,0.18)]">
  <% if title || subtitle %>
    <header class="flex min-h-12 items-center justify-between border-b border-white/[0.075] px-4 py-3">
      <div>
        <% if title %>
          <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--g-accent-text)]"><%= title %></h2>
        <% end %>
        <% if subtitle %>
          <p class="mt-1 font-mono text-[10px] tracking-normal text-[var(--g-faint)]"><%= subtitle %></p>
        <% end %>
      </div>
    </header>
  <% end %>
  <div class="p-4">
    <%= content %>
  </div>
</section>
