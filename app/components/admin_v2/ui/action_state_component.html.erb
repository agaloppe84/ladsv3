<span
  data-action-state-target="status"
  class="hidden h-8 items-center gap-2 rounded-lg border border-[var(--g-accent-border)] bg-[var(--g-accent-soft)] px-2.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--g-accent)]">
  <svg
    data-action-state-target="spinner"
    viewBox="0 0 24 24"
    aria-hidden="true"
    class="hidden h-3.5 w-3.5 animate-spin"
    fill="none">
    <circle class="opacity-20" cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" />
    <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
  </svg>

  <svg
    data-action-state-target="successIcon"
    viewBox="0 0 20 20"
    aria-hidden="true"
    class="hidden h-3.5 w-3.5"
    fill="none">
    <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5" />
    <path d="m7.25 10.2 1.85 1.85 3.8-4.1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
  </svg>

  <svg
    data-action-state-target="errorIcon"
    viewBox="0 0 20 20"
    aria-hidden="true"
    class="hidden h-3.5 w-3.5"
    fill="none">
    <circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5" />
    <path d="M10 6.75v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
    <path d="M10 14h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>

  <span data-action-state-target="label"><%= default_label %></span>
</span>
