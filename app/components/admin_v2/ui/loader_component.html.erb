<svg class="<%= classes %>" viewBox="0 0 48 24" fill="none" aria-hidden="true" focusable="false">
  <% case variant %>
  <% when :dot_relay %>
    <line class="admin-v2-loader__rail" x1="7" y1="12" x2="41" y2="12" />
    <g class="admin-v2-loader__dots">
      <circle cx="10" cy="12" r="1.8" />
      <circle cx="17" cy="12" r="1.8" />
      <circle cx="24" cy="12" r="1.8" />
      <circle cx="31" cy="12" r="1.8" />
      <circle cx="38" cy="12" r="1.8" />
    </g>
  <% when :signal_bars %>
    <line class="admin-v2-loader__rail" x1="8" y1="19" x2="40" y2="19" />
    <g class="admin-v2-loader__bars">
      <line x1="12" y1="18" x2="12" y2="7" />
      <line x1="18" y1="18" x2="18" y2="7" />
      <line x1="24" y1="18" x2="24" y2="7" />
      <line x1="30" y1="18" x2="30" y2="7" />
      <line x1="36" y1="18" x2="36" y2="7" />
    </g>
  <% when :grid_scan %>
    <rect class="admin-v2-loader__frame" x="7" y="5" width="34" height="14" rx="3" />
    <g class="admin-v2-loader__scan-grid">
      <line x1="14" y1="6" x2="14" y2="18" />
      <line x1="24" y1="6" x2="24" y2="18" />
      <line x1="34" y1="6" x2="34" y2="18" />
    </g>
    <rect class="admin-v2-loader__scanner" x="9" y="7" width="4" height="10" rx="2" />
  <% when :constellation %>
    <g class="admin-v2-loader__links">
      <line x1="10" y1="16" x2="18" y2="8" />
      <line x1="18" y1="8" x2="28" y2="14" />
      <line x1="28" y1="14" x2="38" y2="7" />
    </g>
    <g class="admin-v2-loader__nodes">
      <circle cx="10" cy="16" r="2" />
      <circle cx="18" cy="8" r="2" />
      <circle cx="28" cy="14" r="2" />
      <circle cx="38" cy="7" r="2" />
    </g>
  <% end %>
</svg>
