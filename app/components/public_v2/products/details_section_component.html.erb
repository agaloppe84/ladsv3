<section class="<%= component_classes %>" <%= debug_attributes %>>
  <aside class="pv2-product-side grid gap-5 min-[1121px]:sticky min-[1121px]:top-[92px]">
    <% if product_page.warranty_card_value.present? %>
      <section class="pv2-product-warranty-card pv2-product-side__card" aria-label="Garantie produit">
        <div class="pv2-product-warranty-card__content">
          <strong>Garantie <span><%= product_page.warranty_card_value %></span></strong>
          <% product_page.warranty_card_details.each do |detail| %>
            <p><%= detail %></p>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if product_page.dickson_configurator? && product_page.dickson_configurator_path.present? %>
      <%= link_to product_page.dickson_configurator_path, class: "pv2-product-dickson-card pv2-product-side__card" do %>
        <strong>Configurer la toile</strong>
        <p>Ouvrir le selecteur Dickson pour comparer les tissus et affiner la demande.</p>
        <em>Ouvrir</em>
        <%= image_tag "public_v2/dickson-fabric-rolls-cgi.png", class: "pv2-product-dickson-card__image", alt: "", aria: { hidden: true }, width: 637, height: 980, loading: "eager", decoding: "async" %>
      <% end %>
    <% end %>

    <section class="pv2-product-quote-card pv2-product-side__card">
      <strong>Devis gratuit</strong>
      <p>Dimensions, pose, options.</p>
      <div>
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: product_page.quote_path, variant: :primary, size: :sm, shape: :pill, classes: "pv2-product-quote-card__primary", debug: debug?) %>
      </div>
      <%= image_tag "public_v2/product-quote-notepad-isometric-cgi.png", class: "pv2-product-quote-card__image", alt: "", aria: { hidden: true }, loading: "lazy" %>
    </section>

    <% if product_page.brand_panel? %>
      <section class="pv2-product-brand-card pv2-product-side__card">
        <strong>Fabricants</strong>
        <% if product_page.brand_names_text.present? %>
          <p class="pv2-product-brand-names"><%= product_page.brand_names_text %></p>
        <% end %>
        <%= link_to "Nos partenaires", product_page.partners_path, class: "pv2-product-brand-card__button" %>
        <%= image_tag "public_v2/somfy-tubular-motor-cgi.png", class: "pv2-product-brand-card__image", alt: "", aria: { hidden: true }, width: 680, height: 980, loading: "eager", decoding: "async" %>
      </section>
    <% end %>
  </aside>

  <div class="pv2-product-content grid min-w-0 gap-4">
    <% if technical_info_item.present? || product_page.option_items.any? %>
      <section class="pv2-product-spec-block" aria-labelledby="pv2-product-spec-title">
        <header class="pv2-product-spec-block__header">
          <h2 id="pv2-product-spec-title"><%= product_page.product.name %></h2>
          <% if technical_info_item.present? %>
            <p><%= technical_info_item.text %></p>
          <% end %>
        </header>

        <%= render PublicV2::Products::OptionListComponent.new(
          items: product_page.option_items,
          variant: :list,
          debug: debug?
        ) if product_page.option_items.any? %>
      </section>
    <% end %>

    <% palette_sections = product_page.palette_sections %>
    <% if palette_sections.any? %>
      <section
        class="pv2-product-finishes-block"
        aria-labelledby="pv2-product-finishes-title"
        <% if palette_sections.many? %>data-controller="palette-tabs"<% end %>>
        <header class="pv2-product-finishes-block__header">
          <h2 id="pv2-product-finishes-title">Finitions</h2>
        </header>
        <%= image_tag "public_v2/product-finishes-palette-cgi.png", class: "pv2-product-finishes-block__image", alt: "", aria: { hidden: true }, width: 482, height: 760, loading: "eager", decoding: "async" %>

        <% if palette_sections.many? %>
          <div class="pv2-product-palette-tabs" role="tablist" aria-label="Parties du produit">
            <% palette_sections.each_with_index do |palette, index| %>
              <button
                id="<%= palette_tab_id(index) %>"
                type="button"
                class="<%= "is-active" if index.zero? %>"
                role="tab"
                aria-selected="<%= index.zero? %>"
                aria-controls="<%= palette_panel_id(index) %>"
                data-palette-tabs-target="tab"
                data-palette-tabs-index-param="<%= index %>"
                data-action="palette-tabs#select">
                <%= palette_part_name(palette) %>
              </button>
            <% end %>
          </div>
        <% end %>

        <div class="pv2-product-palettes grid grid-cols-1 gap-3">
          <% palette_sections.each_with_index do |palette, index| %>
            <article
              class="<%= "hidden" if palette_sections.many? && index.positive? %>"
              data-controller="palette-modal"
              data-action="keydown.esc@window->palette-modal#close"
              <% if palette_sections.many? %>
                id="<%= palette_panel_id(index) %>"
                role="tabpanel"
                aria-labelledby="<%= palette_tab_id(index) %>"
                aria-hidden="<%= index.positive? %>"
                data-palette-tabs-target="panel"
              <% end %>>
              <div class="pv2-product-swatches">
                <% palette.preview_swatches.each do |swatch| %>
                  <span class="pv2-product-swatch-card" title="<%= swatch_title(swatch) %>">
                    <i style="background-color:<%= swatch.color %>"></i>
                    <strong><%= swatch_label(swatch) %></strong>
                  </span>
                <% end %>
              </div>
              <% if palette.hidden_swatch_count.positive? %>
                <button
                  type="button"
                  class="pv2-product-palette-more"
                  data-action="palette-modal#open"
                  aria-haspopup="dialog"
                  aria-controls="<%= palette_modal_id(index) %>">
                  Voir les <%= palette.count %> coloris
                </button>

                <div
                  id="<%= palette_modal_id(index) %>"
                  class="pv2-product-palette-modal hidden opacity-0"
                  data-palette-modal-target="modal"
                  data-action="click->palette-modal#backdropClose"
                  role="dialog"
                  aria-modal="true"
                  aria-label="<%= palette.modal_title %>">
                  <div class="pv2-product-palette-modal__panel opacity-0 scale-95 translate-y-2" data-palette-modal-target="panel">
                    <header>
                      <div>
                        <h3><%= palette.modal_title %></h3>
                      </div>
                      <button type="button" data-action="palette-modal#close" data-palette-modal-close aria-label="Fermer les coloris">Fermer</button>
                    </header>

                    <div class="pv2-product-palette-modal__grid">
                      <% palette.swatches.each do |swatch| %>
                        <span class="pv2-product-swatch-card pv2-product-swatch-card--modal" title="<%= swatch_title(swatch) %>">
                          <i style="background-color:<%= swatch.color %>"></i>
                          <strong><%= swatch_label(swatch) %></strong>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if product_page.documentation_items.any? %>
      <%= render PublicV2::Ui::PanelComponent.new(kicker: "Documents", title: "Fichiers a telecharger.", text: "Notices, fiches techniques et documents associes au produit.", classes: "pv2-product-panel", debug: debug?) do %>
        <div class="pv2-product-docs grid gap-2">
          <% product_page.documentation_items.each do |documentation| %>
            <%= link_to rails_blob_path(documentation, disposition: "attachment") do %>
              <span><%= documentation.filename.to_s %></span>
              <em>Telecharger</em>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
