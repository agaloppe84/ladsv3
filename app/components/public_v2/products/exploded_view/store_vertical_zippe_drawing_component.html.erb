<svg
  class="pv2-product-exploded__svg"
  viewBox="0 0 <%= layout.svg_width %> <%= layout.svg_height %>"
  role="img"
  aria-labelledby="<%= title_id %> <%= svg_description_id %>"
  shape-rendering="geometricPrecision"
  text-rendering="geometricPrecision">
  <desc id="<%= svg_description_id %>"><%= svg_description %></desc>
  <%= background_grid %>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--supports <%= active_part_class("supports") %>"
    data-exploded-view-target="part"
    data-part-id="supports"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("supports") %>"
    aria-label="Supports et pose">
    <rect x="<%= layout.supports.hit.x %>" y="<%= layout.supports.hit.y %>" width="<%= layout.supports.hit.width %>" height="<%= layout.supports.hit.height %>" class="pv2-product-exploded__hit-area" />
    <% %i[left right].each do |side| %>
      <%= solid_support_profile(layout.supports.solid_profile_for(side)) %>
    <% end %>

    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.supports.marker.x %> <%= layout.supports.marker.y %>)">
      <circle r="68" />
      <text y="25">6</text>
    </g>
    <%= callout_for("supports") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--motorisation <%= active_part_class("motorisation") %>"
    data-exploded-view-target="part"
    data-part-id="motorisation"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("motorisation") %>"
    aria-label="Motorisation">
    <rect x="<%= layout.motor.hit.x %>" y="<%= layout.motor.hit.y %>" width="<%= layout.motor.hit.width %>" height="<%= layout.motor.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_motor_profile(layout.motor.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.motor.marker.x %> <%= layout.motor.marker.y %>)">
      <circle r="68" />
      <text y="25">5</text>
    </g>
    <%= callout_for("motorisation") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--coffre <%= active_part_class("coffre") %>"
    data-exploded-view-target="part"
    data-part-id="coffre"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("coffre") %>"
    aria-label="Coffre extrudé">
    <rect x="<%= layout.coffre.hit.x %>" y="<%= layout.coffre.hit.y %>" width="<%= layout.coffre.hit.width %>" height="<%= layout.coffre.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_housing_profile(layout.coffre.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.coffre.marker.x %> <%= layout.coffre.marker.y %>)">
      <circle r="68" />
      <text y="25">1</text>
    </g>
    <%= callout_for("coffre") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--coulisses pv2-product-exploded__part--coulisse-left <%= active_part_class("coulisses") %>"
    data-exploded-view-target="part"
    data-part-id="coulisses"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("coulisses") %>"
    aria-label="Coulisse latérale gauche">
    <rect x="<%= layout.coulisse.hit.x %>" y="<%= layout.coulisse.hit.y %>" width="<%= layout.coulisse.hit.width %>" height="<%= layout.coulisse.hit.height %>" class="pv2-product-exploded__hit-area" />

    <% left_zip = layout.coulisse.zip_edge_box(side: :left, y: layout.fabric.body.y, height: layout.fabric.body.height) %>
    <g class="pv2-product-exploded__mirror-unit">
      <%= solid_profile(layout.coulisse.solid_profile_for(:left)) %>
      <%= zip_edge_track(
        box: left_zip,
        teeth_side: layout.coulisse.zip_teeth_side(:left),
        step: fabric_zip_tooth_step(layout.fabric)
      ) %>
    </g>

    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.coulisse.marker.x %> <%= layout.coulisse.marker.y %>)">
      <circle r="68" />
      <text y="25">2</text>
    </g>
    <%= callout_for("coulisses") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--coulisses pv2-product-exploded__part--coulisse-right <%= active_part_class("coulisses") %>"
    data-exploded-view-target="part"
    data-part-id="coulisses"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("coulisses") %>"
    aria-label="Coulisse latérale droite">
    <rect x="<%= layout.svg_width - layout.coulisse.hit.x - layout.coulisse.hit.width %>" y="<%= layout.coulisse.hit.y %>" width="<%= layout.coulisse.hit.width %>" height="<%= layout.coulisse.hit.height %>" class="pv2-product-exploded__hit-area" />
    <% right_zip = layout.coulisse.zip_edge_box(side: :right, y: layout.fabric.body.y, height: layout.fabric.body.height) %>
    <g class="pv2-product-exploded__mirror-unit">
      <%= solid_profile(layout.coulisse.solid_profile_for(:right)) %>
      <%= zip_edge_track(
        box: right_zip,
        teeth_side: layout.coulisse.zip_teeth_side(:right),
        step: fabric_zip_tooth_step(layout.fabric)
      ) %>
    </g>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--toile <%= active_part_class("toile") %>"
    data-exploded-view-target="part"
    data-part-id="toile"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("toile") %>"
    aria-label="Toile zippée">
    <rect x="<%= layout.fabric.hit.x %>" y="<%= layout.fabric.hit.y %>" width="<%= layout.fabric.hit.width %>" height="<%= layout.fabric.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
    <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.fabric.marker.x %> <%= layout.fabric.marker.y %>)">
      <circle r="68" />
      <text y="25">3</text>
    </g>
    <%= callout_for("toile") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--barre-charge <%= active_part_class("barre-charge") %>"
    data-exploded-view-target="part"
    data-part-id="barre-charge"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("barre-charge") %>"
    aria-label="Barre de charge">
    <rect x="<%= layout.barre.hit.x %>" y="<%= layout.barre.hit.y %>" width="<%= layout.barre.hit.width %>" height="<%= layout.barre.hit.height %>" class="pv2-product-exploded__hit-area" />
    <% if layout.barre.solid_profile %>
      <%= solid_bar_profile(layout.barre.solid_profile) %>
    <% else %>
      <%= surface_path(layout.barre.outline_path) %>
      <path d="<%= layout.barre.outline_path %>" class="pv2-product-exploded__outline" />
      <rect x="<%= layout.barre.handle.x %>" y="<%= layout.barre.handle.y %>" width="<%= layout.barre.handle.width %>" height="<%= layout.barre.handle.height %>" rx="<%= layout.barre.handle.rx %>" class="pv2-product-exploded__fill" />
      <path d="<%= layout.barre.detail_path %>" class="pv2-product-exploded__detail" />
    <% end %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.barre.marker.x %> <%= layout.barre.marker.y %>)">
      <circle r="68" />
      <text y="25">4</text>
    </g>
    <%= callout_for("barre-charge") %>
  </g>
</svg>
