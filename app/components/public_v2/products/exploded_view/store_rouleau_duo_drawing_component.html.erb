<svg
  class="pv2-product-exploded__svg"
  viewBox="0 0 <%= layout.svg_width %> <%= layout.svg_height %>"
  role="img"
  aria-labelledby="<%= title_id %> <%= svg_description_id %>"
  shape-rendering="geometricPrecision"
  text-rendering="geometricPrecision">
  <desc id="<%= svg_description_id %>"><%= svg_description %></desc>
  <%= background_grid %>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--duo-rail <%= active_part_class("rail-superieur") %>"
    data-exploded-view-target="part"
    data-part-id="rail-superieur"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("rail-superieur") %>"
    aria-label="Rail superieur">
    <rect x="<%= layout.headrail.hit.x %>" y="<%= layout.headrail.hit.y %>" width="<%= layout.headrail.hit.width %>" height="<%= layout.headrail.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_profile(layout.headrail.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.headrail.marker.x %> <%= layout.headrail.marker.y %>)">
      <circle r="68" />
      <text y="25">1</text>
    </g>
    <%= callout_for("rail-superieur") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--duo-supports <%= active_part_class("supports-pose") %>"
    data-exploded-view-target="part"
    data-part-id="supports-pose"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("supports-pose") %>"
    aria-label="Supports de pose">
    <rect x="<%= layout.supports.hit.x %>" y="<%= layout.supports.hit.y %>" width="<%= layout.supports.hit.width %>" height="<%= layout.supports.hit.height %>" class="pv2-product-exploded__hit-area" />
    <% %i[left right].each do |side| %>
      <%= solid_support_profile(layout.supports.solid_profile_for(side)) %>
    <% end %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.supports.marker.x %> <%= layout.supports.marker.y %>)">
      <circle r="68" />
      <text y="25">6</text>
    </g>
    <%= callout_for("supports-pose") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--duo-roll <%= active_part_class("tube-enroulement") %>"
    data-exploded-view-target="part"
    data-part-id="tube-enroulement"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("tube-enroulement") %>"
    aria-label="Tube d'enroulement">
    <% roll_highlight = duo_roll_highlight %>
    <rect x="<%= layout.roll.hit.x %>" y="<%= layout.roll.hit.y %>" width="<%= layout.roll.hit.width %>" height="<%= layout.roll.hit.height %>" class="pv2-product-exploded__hit-area" />
    <rect x="<%= layout.roll.body.x %>" y="<%= layout.roll.body.y %>" width="<%= layout.roll.body.width %>" height="<%= layout.roll.body.height %>" rx="<%= layout.roll.body.rx %>" class="<%= solid_tone_class(:mid) %>" />
    <rect x="<%= roll_highlight.x %>" y="<%= roll_highlight.y %>" width="<%= roll_highlight.width %>" height="<%= roll_highlight.height %>" rx="<%= roll_highlight.rx %>" class="<%= solid_tone_class(:light) %>" />
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.roll.marker.x %> <%= layout.roll.marker.y %>)">
      <circle r="68" />
      <text y="25">2</text>
    </g>
    <%= callout_for("tube-enroulement") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--duo-toile <%= active_part_class("toile-duo") %>"
    data-exploded-view-target="part"
    data-part-id="toile-duo"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("toile-duo") %>"
    aria-label="Toile duo">
    <rect x="<%= layout.fabric.hit.x %>" y="<%= layout.fabric.hit.y %>" width="<%= layout.fabric.hit.width %>" height="<%= layout.fabric.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
    <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.fabric.marker.x %> <%= layout.fabric.marker.y %>)">
      <circle r="68" />
      <text y="25">3</text>
    </g>
    <%= callout_for("toile-duo") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--duo-barre <%= active_part_class("barre-charge") %>"
    data-exploded-view-target="part"
    data-part-id="barre-charge"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("barre-charge") %>"
    aria-label="Barre de charge">
    <rect x="<%= layout.bottom_bar.hit.x %>" y="<%= layout.bottom_bar.hit.y %>" width="<%= layout.bottom_bar.hit.width %>" height="<%= layout.bottom_bar.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_bar_profile(layout.bottom_bar.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.bottom_bar.marker.x %> <%= layout.bottom_bar.marker.y %>)">
      <circle r="68" />
      <text y="25">4</text>
    </g>
    <%= callout_for("barre-charge") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--duo-commande <%= active_part_class("commande") %>"
    data-exploded-view-target="part"
    data-part-id="commande"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("commande") %>"
    aria-label="Commande">
    <rect x="<%= layout.control.hit.x %>" y="<%= layout.control.hit.y %>" width="<%= layout.control.hit.width %>" height="<%= layout.control.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_control_profile(layout.control.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.control.marker.x %> <%= layout.control.marker.y %>)">
      <circle r="68" />
      <text y="25">5</text>
    </g>
    <%= callout_for("commande") %>
  </g>
</svg>
