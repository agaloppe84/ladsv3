<svg
  class="pv2-product-exploded__svg"
  viewBox="0 0 <%= layout.svg_width %> <%= layout.svg_height %>"
  role="img"
  aria-labelledby="<%= title_id %> <%= svg_description_id %>"
  shape-rendering="geometricPrecision"
  text-rendering="geometricPrecision">
  <desc id="<%= svg_description_id %>"><%= svg_description %></desc>
  <%= background_grid %>

  <% if vertical_zippe_layout? %>
    <%= part_group("supports", class_suffix: "supports", hit: layout.supports.hit, marker: layout.supports.marker) do %>
      <% %i[left right].each do |side| %>
        <%= solid_support_profile(layout.supports.solid_profile_for(side)) %>
      <% end %>
    <% end %>

    <%= part_group("motorisation", class_suffix: "motorisation", hit: layout.motor.hit, marker: layout.motor.marker) do %>
      <%= solid_motor_profile(layout.motor.solid_profile) %>
    <% end %>

    <%= part_group("coffre", class_suffix: "coffre", hit: layout.coffre.hit, marker: layout.coffre.marker) do %>
      <%= solid_housing_profile(layout.coffre.solid_profile) %>
    <% end %>

    <%= part_group(
      "coulisses",
      class_suffix: "coulisses pv2-product-exploded__part--coulisse-left",
      hit: layout.coulisse.hit,
      marker: layout.coulisse.marker,
      aria_label: "#{part_label("coulisses")} gauche"
    ) do %>
      <% left_zip = layout.coulisse.zip_edge_box(side: :left, y: layout.fabric.body.y, height: layout.fabric.body.height) %>
      <g class="pv2-product-exploded__mirror-unit">
        <%= solid_profile(layout.coulisse.solid_profile_for(:left)) %>
        <%= zip_edge_track(
          box: left_zip,
          teeth_side: layout.coulisse.zip_teeth_side(:left),
          step: fabric_zip_tooth_step(layout.fabric)
        ) %>
      </g>
    <% end %>

    <%= mirror_part_group(
      "coulisses",
      class_suffix: "coulisses pv2-product-exploded__part--coulisse-right",
      hit: mirrored_hit_box(layout.coulisse.hit),
      aria_label: "#{part_label("coulisses")} droite"
    ) do %>
      <% right_zip = layout.coulisse.zip_edge_box(side: :right, y: layout.fabric.body.y, height: layout.fabric.body.height) %>
      <g class="pv2-product-exploded__mirror-unit">
        <%= solid_profile(layout.coulisse.solid_profile_for(:right)) %>
        <%= zip_edge_track(
          box: right_zip,
          teeth_side: layout.coulisse.zip_teeth_side(:right),
          step: fabric_zip_tooth_step(layout.fabric)
        ) %>
      </g>
    <% end %>

    <%= part_group("toile", class_suffix: "toile", hit: layout.fabric.hit, marker: layout.fabric.marker) do %>
      <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
      <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
    <% end %>

    <%= part_group("barre-charge", class_suffix: "barre-charge", hit: layout.barre.hit, marker: layout.barre.marker) do %>
      <%= solid_bar_profile(layout.barre.solid_profile) %>
    <% end %>
  <% elsif enroulable_verticale_layout? %>
    <%= part_group("caisson", class_suffix: "enroulable-caisson", hit: layout.cassette.hit, marker: layout.cassette.marker) do %>
      <%= solid_housing_profile(layout.cassette.solid_profile) %>
    <% end %>

    <%= part_group(
      "double-coulisse",
      class_suffix: "enroulable-coulisse pv2-product-exploded__part--enroulable-coulisse-left",
      hit: layout.rails.hit,
      marker: layout.rails.marker,
      aria_label: "#{part_label("double-coulisse")} gauche"
    ) do %>
      <%= solid_profile(layout.rails.solid_profile_for(:left)) %>
    <% end %>

    <%= mirror_part_group(
      "double-coulisse",
      class_suffix: "enroulable-coulisse pv2-product-exploded__part--enroulable-coulisse-right",
      hit: right_vertical_pair_hit_box(layout.rails),
      aria_label: "#{part_label("double-coulisse")} droite"
    ) do %>
      <%= solid_profile(layout.rails.solid_profile_for(:right)) %>
    <% end %>

    <%= part_group("toile-bordee", class_suffix: "enroulable-toile", hit: layout.fabric.hit, marker: layout.fabric.marker) do %>
      <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
      <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
    <% end %>

    <%= part_group("barre-charge", class_suffix: "enroulable-barre", hit: layout.bottom_bar.hit, marker: layout.bottom_bar.marker) do %>
      <%= solid_bar_profile(layout.bottom_bar.solid_profile) %>
    <% end %>

    <%= part_group("fermeture-magnetique", class_suffix: "enroulable-lock", hit: layout.lock.hit, marker: layout.lock.marker) do %>
      <%= solid_accessory_profile(layout.lock.solid_profile) %>
    <% end %>

    <%= part_group("bavettes", class_suffix: "enroulable-bavettes", hit: layout.bavettes.hit, marker: layout.bavettes.marker) do %>
      <%= solid_accessory_profile(layout.bavettes.solid_profile) %>
    <% end %>
  <% else %>
    <% unsupported_layout! %>
  <% end %>
</svg>
