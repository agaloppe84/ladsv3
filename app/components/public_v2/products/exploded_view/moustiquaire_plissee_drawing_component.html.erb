<svg
  class="pv2-product-exploded__svg"
  viewBox="0 0 <%= layout.svg_width %> <%= layout.svg_height %>"
  role="img"
  aria-labelledby="<%= title_id %> <%= svg_description_id %>"
  shape-rendering="geometricPrecision"
  text-rendering="geometricPrecision">
  <desc id="<%= svg_description_id %>"><%= svg_description %></desc>
  <%= background_grid %>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-guide-haut <%= active_part_class("guide-haut") %>"
    data-exploded-view-target="part"
    data-part-id="guide-haut"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("guide-haut") %>"
    aria-label="Guide supérieur">
    <rect x="<%= layout.guide.hit.x %>" y="<%= layout.guide.hit.y %>" width="<%= layout.guide.hit.width %>" height="<%= layout.guide.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_profile(layout.guide.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.guide.marker.x %> <%= layout.guide.marker.y %>)">
      <circle r="68" />
      <text y="25">1</text>
    </g>
    <%= callout_for("guide-haut") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-profils pv2-product-exploded__part--plissee-profils-left <%= active_part_class("profils-muraux") %>"
    data-exploded-view-target="part"
    data-part-id="profils-muraux"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("profils-muraux") %>"
    aria-label="Profil mural gauche">
    <rect x="<%= layout.profiles.hit.x %>" y="<%= layout.profiles.hit.y %>" width="<%= layout.profiles.hit.width %>" height="<%= layout.profiles.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_profile(layout.profiles.solid_profile_for(:left)) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.profiles.marker.x %> <%= layout.profiles.marker.y %>)">
      <circle r="68" />
      <text y="25">2</text>
    </g>
    <%= callout_for("profils-muraux") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-profils pv2-product-exploded__part--plissee-profils-right <%= active_part_class("profils-muraux") %>"
    data-exploded-view-target="part"
    data-part-id="profils-muraux"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("profils-muraux") %>"
    aria-label="Profil mural droit">
    <rect x="<%= layout.profiles.right.x - 70 %>" y="<%= layout.profiles.hit.y %>" width="<%= layout.profiles.hit.width %>" height="<%= layout.profiles.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_profile(layout.profiles.solid_profile_for(:right)) %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-toile <%= active_part_class("toile-plissee") %>"
    data-exploded-view-target="part"
    data-part-id="toile-plissee"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("toile-plissee") %>"
    aria-label="Toile plissée">
    <rect x="<%= layout.fabric.hit.x %>" y="<%= layout.fabric.hit.y %>" width="<%= layout.fabric.hit.width %>" height="<%= layout.fabric.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
    <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.fabric.marker.x %> <%= layout.fabric.marker.y %>)">
      <circle r="68" />
      <text y="25">3</text>
    </g>
    <%= callout_for("toile-plissee") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-barre-poignee <%= active_part_class("barre-poignee") %>"
    data-exploded-view-target="part"
    data-part-id="barre-poignee"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("barre-poignee") %>"
    aria-label="Barre poignée">
    <rect x="<%= layout.handle.hit.x %>" y="<%= layout.handle.hit.y %>" width="<%= layout.handle.hit.width %>" height="<%= layout.handle.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_bar_profile(layout.handle.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.handle.marker.x %> <%= layout.handle.marker.y %>)">
      <circle r="68" />
      <text y="25">4</text>
    </g>
    <%= callout_for("barre-poignee") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-seuil-bas <%= active_part_class("seuil-bas") %>"
    data-exploded-view-target="part"
    data-part-id="seuil-bas"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("seuil-bas") %>"
    aria-label="Guide au sol extra-plat">
    <rect x="<%= layout.threshold.hit.x %>" y="<%= layout.threshold.hit.y %>" width="<%= layout.threshold.hit.width %>" height="<%= layout.threshold.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_bar_profile(layout.threshold.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.threshold.marker.x %> <%= layout.threshold.marker.y %>)">
      <circle r="68" />
      <text y="25">5</text>
    </g>
    <%= callout_for("seuil-bas") %>
  </g>

  <g
    class="pv2-product-exploded__part pv2-product-exploded__part--plissee-verrouillage <%= active_part_class("verrouillage") %>"
    data-exploded-view-target="part"
    data-part-id="verrouillage"
    data-action="click->exploded-view#select keydown->exploded-view#selectKey"
    role="button"
    tabindex="0"
    aria-pressed="<%= aria_pressed("verrouillage") %>"
    aria-label="Verrouillage magnétique">
    <rect x="<%= layout.lock.hit.x %>" y="<%= layout.lock.hit.y %>" width="<%= layout.lock.hit.width %>" height="<%= layout.lock.hit.height %>" class="pv2-product-exploded__hit-area" />
    <%= solid_accessory_profile(layout.lock.solid_profile) %>
    <g class="pv2-product-exploded__marker" transform="translate(<%= layout.lock.marker.x %> <%= layout.lock.marker.y %>)">
      <circle r="68" />
      <text y="25">6</text>
    </g>
    <%= callout_for("verrouillage") %>
  </g>
</svg>
