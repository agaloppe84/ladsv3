<% supports_part_id = part_id_for_slot("top-supports") %>
<% motor_part_id = part_id_for_slot("motor") %>
<% housing_part_id = part_id_for_slot("top-housing") %>
<% side_guides_part_id = part_id_for_slot("side-guides") %>
<% fabric_part_id = part_id_for_slot("fabric") %>
<% bottom_bar_part_id = part_id_for_slot("bottom-bar") %>

<%= part_group(supports_part_id, class_suffix: slot_class_suffix("top-supports"), hit: layout.supports.hit, marker: layout.supports.marker) do %>
  <% %i[left right].each do |side| %>
    <%= solid_support_profile(layout.supports.solid_profile_for(side)) %>
  <% end %>
<% end %>

<%= part_group(motor_part_id, class_suffix: slot_class_suffix("motor"), hit: layout.motor.hit, marker: layout.motor.marker) do %>
  <%= solid_motor_profile(layout.motor.solid_profile) %>
<% end %>

<%= part_group(housing_part_id, class_suffix: slot_class_suffix("top-housing"), hit: layout.coffre.hit, marker: layout.coffre.marker) do %>
  <%= solid_housing_profile(layout.coffre.solid_profile) %>
<% end %>

<%= part_group(
  side_guides_part_id,
  class_suffix: slot_class_suffix("side-guides", side: "left"),
  hit: layout.coulisse.hit,
  marker: layout.coulisse.marker,
  aria_label: "#{part_label(side_guides_part_id)} gauche"
) do %>
  <% left_zip = layout.coulisse.zip_edge_box(side: :left, y: layout.fabric.body.y, height: layout.fabric.body.height) %>
  <g class="pv2-product-exploded__mirror-unit">
    <%= solid_profile(layout.coulisse.solid_profile_for(:left)) %>
    <%= zip_edge_track(
      box: left_zip,
      teeth_side: layout.coulisse.zip_teeth_side(:left),
      step: fabric_zip_tooth_step(layout.fabric)
    ) %>
  </g>
<% end %>

<%= mirror_part_group(
  side_guides_part_id,
  class_suffix: slot_class_suffix("side-guides", side: "right"),
  hit: mirrored_hit_box(layout.coulisse.hit),
  aria_label: "#{part_label(side_guides_part_id)} droite"
) do %>
  <% right_zip = layout.coulisse.zip_edge_box(side: :right, y: layout.fabric.body.y, height: layout.fabric.body.height) %>
  <g class="pv2-product-exploded__mirror-unit">
    <%= solid_profile(layout.coulisse.solid_profile_for(:right)) %>
    <%= zip_edge_track(
      box: right_zip,
      teeth_side: layout.coulisse.zip_teeth_side(:right),
      step: fabric_zip_tooth_step(layout.fabric)
    ) %>
  </g>
<% end %>

<%= part_group(fabric_part_id, class_suffix: slot_class_suffix("fabric"), hit: layout.fabric.hit, marker: layout.fabric.marker) do %>
  <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
  <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
<% end %>

<%= part_group(bottom_bar_part_id, class_suffix: slot_class_suffix("bottom-bar"), hit: layout.barre.hit, marker: layout.barre.marker) do %>
  <%= solid_bar_profile(layout.barre.solid_profile) %>
<% end %>
