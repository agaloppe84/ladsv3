<% top_rail_part_id = part_id_for_slot("top-rail") %>
<% supports_part_id = part_id_for_slot("top-supports") %>
<% fabric_part_id = part_id_for_slot("fabric") %>
<% intermediate_rail_part_id = part_id_for_slot("intermediate-rail") %>
<% bottom_rail_part_id = part_id_for_slot("bottom-rail") %>
<% guide_cords_part_id = part_id_for_slot("guide-cords") %>

<%= part_group(top_rail_part_id, class_suffix: slot_class_suffix("top-rail"), hit: layout.top_rail.hit, marker: layout.top_rail.marker) do %>
  <% top_rail_profile = layout.top_rail.solid_profile %>
  <%= hit_rect(top_rail_profile.clip_box) %>
  <%= solid_bar_profile(top_rail_profile) %>
<% end %>

<%= part_group(supports_part_id, class_suffix: slot_class_suffix("top-supports"), hit: layout.supports.hit, marker: layout.supports.marker) do %>
  <% %i[left right].each do |side| %>
    <%= solid_support_profile(layout.supports.solid_profile_for(side)) %>
  <% end %>
<% end %>

<%= part_group(fabric_part_id, class_suffix: slot_class_suffix("fabric"), hit: layout.fabric.hit, marker: layout.fabric.marker) do %>
  <%= fabric_pattern(layout.fabric.pattern, slot: :under_outline) %>
  <%= fabric_pattern(layout.fabric.pattern, slot: :over_outline) %>
<% end %>

<%= part_group(intermediate_rail_part_id, class_suffix: slot_class_suffix("intermediate-rail"), hit: layout.intermediate_rail.hit, marker: layout.intermediate_rail.marker) do %>
  <%= solid_bar_profile(layout.intermediate_rail.solid_profile) %>
<% end %>

<%= part_group(bottom_rail_part_id, class_suffix: slot_class_suffix("bottom-rail"), hit: layout.bottom_rail.hit, marker: layout.bottom_rail.marker) do %>
  <% bottom_rail_profile = layout.bottom_rail.solid_profile %>
  <%= hit_rect(bottom_rail_profile.clip_box) %>
  <%= solid_bar_profile(bottom_rail_profile) %>
<% end %>

<%= part_group(guide_cords_part_id, class_suffix: slot_class_suffix("guide-cords"), hit: layout.cords.hit, marker: layout.cords.marker) do %>
  <%= solid_control_profile(layout.cords.solid_profile) %>
<% end %>
