<% headrail_part_id = part_id_for_slot("headrail", fallback: "boitier-haut") %>
<% supports_part_id = part_id_for_slot("top-supports", fallback: "supports-pose") %>
<% fabric_part_id = part_id_for_slot("fabric", fallback: "lames-orientables") %>
<% ladder_cords_part_id = part_id_for_slot("ladder-cords", fallback: "cordons-echelles") %>
<% bottom_bar_part_id = part_id_for_slot("bottom-bar", fallback: "barre-finale") %>
<% controls_part_id = part_id_for_slot("controls", fallback: "commande") %>

<%= part_group(headrail_part_id, class_suffix: "venitien-boitier", hit: layout.headrail.hit, marker: layout.headrail.marker) do %>
  <%= solid_profile(layout.headrail.solid_profile) %>
<% end %>

<%= part_group(supports_part_id, class_suffix: "venitien-supports", hit: layout.supports.hit, marker: layout.supports.marker) do %>
  <% %i[left right].each do |side| %>
    <%= solid_support_profile(layout.supports.solid_profile_for(side)) %>
  <% end %>
<% end %>

<%= part_group(fabric_part_id, class_suffix: "venitien-lames", hit: layout.slats.hit, marker: layout.slats.marker) do %>
  <%= slat_pattern(layout.slats.slat_pattern) %>
<% end %>

<%= part_group(ladder_cords_part_id, class_suffix: "venitien-cordons", hit: venetian_cord_hit_box, marker: layout.callout(ladder_cords_part_id).marker) do %>
  <%= solid_control_profile(layout.slats.cord_solid_profile) %>
<% end %>

<%= part_group(bottom_bar_part_id, class_suffix: "venitien-barre", hit: layout.bottom_bar.hit, marker: layout.bottom_bar.marker) do %>
  <%= solid_bar_profile(layout.bottom_bar.solid_profile) %>
<% end %>

<%= part_group(controls_part_id, class_suffix: "venitien-commande", hit: layout.control.hit, marker: layout.control.marker) do %>
  <%= solid_control_profile(layout.control.solid_profile) %>
<% end %>
