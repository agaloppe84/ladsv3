<section class="<%= component_classes %>" <%= debug_attributes %>>
  <div class="pv2-product-hero-v2__copy">
    <article class="pv2-product-hero-v2__lead">
      <div class="pv2-product-hero-v2__title-stack">
        <h1><%= product.name %></h1>
      </div>
      <span><%= description_text %></span>

      <div class="pv2-product-hero-v2__actions flex flex-wrap gap-2">
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: quote_path, variant: :primary, size: :sm, shape: :pill, classes: "pv2-product-hero-v2__quote-button", debug: debug?) %>
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Retour catalogue", path: catalog_path, variant: :secondary, size: :sm, shape: :pill, classes: "pv2-product-hero-v2__catalog-button", debug: debug?) %>
      </div>
    </article>
  </div>

  <aside class="pv2-product-hero-v2__showcase">
    <%= render PublicV2::Ui::ShowcaseCarouselComponent.new(
      items: gallery_items,
      aria_label: "Photos #{product.name}",
      variant: :default,
      size: :wide,
      show_modal: gallery_modal?,
      classes: "pv2-product-hero-v2__carousel",
      debug: debug?
    ) %>
  </aside>
</section>
