<section class="<%= component_classes %>" <%= debug_attributes %>>
  <div class="pv2-product-hero-v2__copy grid min-w-0 gap-3 min-[1121px]:self-center">
    <%= render PublicV2::Ui::SpotlightPanelComponent.new(
      kicker: category.name,
      title: product.name,
      text: description_text,
      variant: :soft,
      size: :md,
      classes: "pv2-product-hero-v2__lead",
      debug: debug?
    ) do %>
      <div class="pv2-product-hero-v2__actions flex flex-wrap gap-2">
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: quote_path, variant: :primary, size: :sm, debug: debug?) %>
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Retour catalogue", path: catalog_path, variant: :secondary, size: :sm, debug: debug?) %>
      </div>
    <% end %>

    <dl class="pv2-product-facts grid grid-cols-2 gap-2 min-[821px]:grid-cols-4">
      <% product_page.hero_fact_items.each do |item| %>
        <div>
          <dt><%= item[:label] %></dt>
          <dd><%= item[:value] %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <aside class="pv2-product-hero-v2__showcase grid min-w-0 gap-3">
    <div class="pv2-product-hero__media">
      <%= render PublicV2::Ui::MediaFrameComponent.new(image: image, fallback: "placeholder.jpg", alt: product.name, ratio: :wide, loading: "eager", classes: "h-full min-h-full", debug: debug?) %>
    </div>

    <%= render PublicV2::Ui::ProofRailComponent.new(
      items: product_page.hero_proof_items,
      label: "Ressources produit",
      variant: :soft,
      debug: debug?
    ) %>
  </aside>
</section>
