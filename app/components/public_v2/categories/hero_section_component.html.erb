<%= tag.section class: component_classes, data: debug_data do %>
  <div class="pv2-public-index-hero-v2__catalog">
    <header class="pv2-public-index-hero-v2__intro">
      <h1>
        <% category_index_page.hero_title_lines.each do |line| %>
          <span><%= line %></span>
        <% end %>
      </h1>
      <p><%= category_index_page.hero_text %></p>
    </header>

  </div>

  <nav class="pv2-category-anchor-strip" aria-label="Aller a une categorie">
    <% category_index_page.anchor_items.each do |item| %>
      <%= link_to item.label, item.href, class: "pv2-category-anchor-strip__item" %>
    <% end %>
  </nav>
<% end %>
