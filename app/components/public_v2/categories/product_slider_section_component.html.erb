<%= tag.article id: section.anchor_id, class: component_classes, data: debug_data.merge(category_scrollspy_target: "section") do %>
  <header class="pv2-category-product-section__head">
    <p><%= section.need_label %></p>
    <h2><%= section.title %></h2>
    <span><%= section.text %></span>
  </header>

  <% if section.products.any? %>
    <%= render PublicV2::Ui::ShowcaseCarouselComponent.new(
      items: product_cards,
      id: "#{section.anchor_id}-produits",
      aria_label: "Produits #{section.title}",
      variant: :soft,
      size: :content,
      initial_index: 0,
      show_pagination: true,
      show_modal: false,
      classes: "pv2-category-product-slider",
      debug: debug?
    ) %>
  <% elsif section.empty_message.present? %>
    <%= render PublicV2::Ui::EmptyStateComponent.new(message: section.empty_message, debug: debug?) %>
  <% end %>
<% end %>
