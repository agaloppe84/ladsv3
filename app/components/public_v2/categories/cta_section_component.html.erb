    primary_path: public_v2_new_quote_path,
    secondary_label: "Voir le showroom",
    secondary_path: public_v2_contact_path,
    meta: "Un premier retour permet de cadrer le produit avant d'affiner.",
    variant: :soft,
    debug: debug?
  ) %>

  <%= render PublicV2::Ui::ProofRailComponent.new(
    items: category_index_page.hero_proof_items,
    label: "Pour avancer",
    variant: :compact,
    debug: debug?
  ) %>
