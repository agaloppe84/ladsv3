  ) %>

  <%= render PublicV2::Ui::SummaryBoxComponent.new(
    kicker: "Familles traitees",
    title: "Du conseil au suivi.",
    text: "Le showroom et l'equipe terrain couvrent les grandes familles du catalogue.",
