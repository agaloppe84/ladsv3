<%= tag.section class: component_classes, data: debug_data do %>
  <div class="pv2-contact-showroom-v2__media">
    <%= render PublicV2::Ui::MediaFrameComponent.new(
      image: contact_page.showroom_image,
      alt: "Showroom technique Les Artisans du Store",
      ratio: :wide,
      classes: "h-full min-h-full",
      debug: debug?
    ) %>
  </div>

  <%= render PublicV2::Ui::PanelComponent.new(
    kicker: "Showroom technique",
    title: "Voir les details qui changent le devis.",
    text: "Motorisation, toile, coffre, rail, tablier, exposition, pose : le showroom rend visibles les choix qui comptent vraiment.",
    variant: :soft,
    padding: :lg,
    classes: "pv2-contact-showroom-v2__copy h-full",
    debug: debug?
  ) do %>
    <%= render PublicV2::Ui::ComparisonStripComponent.new(
      items: contact_page.showroom_context_items,
      label: "A comparer sur place",
      variant: :compact,
      debug: debug?
    ) %>

    <%= render PublicV2::Ui::TrustClusterComponent.new(
      items: contact_page.trust_items,
      variant: :compact,
      debug: debug?
    ) %>
  <% end %>
<% end %>
