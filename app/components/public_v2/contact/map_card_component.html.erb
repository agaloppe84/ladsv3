        <use href="#<%= svg_id(:icon_river) %>" x="-6" y="-6" width="12" height="12" />
        <text x="14" y="4">Riviere</text>
      </g>

    </svg>
  </div>

  <div class="pv2-contact-map-card__city-overlay" aria-hidden="true"><%= city_label %></div>

  <%= link_to "Itinéraire",
    contact_info.map_href,
    class: "pv2-contact-map-card__route-link",
    target: "_blank",
    rel: "noopener",
    aria: { label: "Ouvrir l'itinéraire vers le showroom dans Google Maps" } %>
<% end %>
