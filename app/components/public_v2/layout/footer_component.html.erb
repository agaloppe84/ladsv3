<%= tag.footer id: id, class: component_classes, data: debug_data do %>
  <div class="pv2-public-footer__main grid gap-5 p-4 min-[821px]:p-5 min-[1121px]:p-6">
    <div class="pv2-public-footer__mast grid gap-4 min-[1121px]:grid-cols-[minmax(0,1fr)_minmax(340px,0.46fr)] min-[1121px]:items-end">
      <div class="pv2-public-footer__intro grid w-full min-w-0 gap-[0.66rem]">
        <p class="pv2-eyebrow"><%= eyebrow %></p>
        <h2><%= title %></h2>
        <p><%= text %></p>
        <div class="pv2-public-footer__actions flex flex-wrap gap-2">
          <%= link_to "Demander un devis", public_v2_new_quote_path, class: "pv2-public-footer__primary" %>
          <%= link_to "Voir le showroom", public_v2_contact_path, class: "pv2-public-footer__secondary" %>
        </div>
      </div>

      <div class="pv2-public-footer__quote-card grid gap-3">
        <div>
          <span>Devis prepare</span>
          <strong>Retour sous 48h</strong>
          <p>Produit, photo, dimensions : on cadre vite le bon niveau de conseil.</p>
        </div>
        <div class="pv2-public-footer__proof-grid grid grid-cols-3 gap-2" aria-label="Preuves rapides">
          <% proof_cards.each do |proof| %>
            <article>
              <span><%= proof[:label] %></span>
              <strong><%= proof[:value] %></strong>
              <em><%= proof[:text] %></em>
            </article>
          <% end %>
        </div>
      </div>
    </div>

    <div class="pv2-public-footer__body grid gap-4 min-[821px]:grid-cols-[minmax(0,0.92fr)_minmax(260px,0.48fr)] min-[1121px]:grid-cols-[minmax(0,0.72fr)_minmax(0,0.68fr)_minmax(310px,0.42fr)]">
      <section class="pv2-public-footer__proofs grid gap-2" aria-label="Accompagnement">
        <p>Accompagnement</p>
        <div class="flex flex-wrap gap-[0.46rem]">
          <% proof_items.each do |proof_item| %>
            <span><%= proof_item %></span>
          <% end %>
        </div>
      </section>

      <nav class="pv2-public-footer__families grid gap-2" aria-label="Familles produits">
        <p>Familles</p>
        <div class="flex flex-wrap gap-[0.46rem]">
          <% category_links.each do |category| %>
            <%= link_to category.name, public_v2_categories_path(anchor: "categorie-#{category.id}") %>
          <% end %>
        </div>
      </nav>

      <section class="pv2-public-footer__contact-grid grid gap-2" aria-label="Coordonnées">
        <%= link_to phone_href, class: "pv2-public-footer__contact-card grid gap-[0.24rem]" do %>
          <span>Telephone</span>
          <strong><%= phone %></strong>
          <em>Appel showroom</em>
        <% end %>

        <%= link_to mail_href, class: "pv2-public-footer__contact-card grid gap-[0.24rem]" do %>
          <span>Email</span>
          <strong><%= email %></strong>
          <em>Elements projet et photos</em>
        <% end %>

        <%= link_to public_v2_contact_path, class: "pv2-public-footer__contact-card grid gap-[0.24rem]" do %>
          <span>Showroom</span>
          <strong><%= address %></strong>
          <em><%= city %> · <%= hours %></em>
        <% end %>
      </section>
    </div>
  </div>

  <div class="pv2-public-footer__bottom flex flex-col items-start gap-3 pt-4 min-[821px]:flex-row min-[821px]:items-center min-[821px]:justify-between">
    <span>Les Artisans du Store · L'Arbresle</span>
    <nav class="flex flex-wrap gap-[0.55rem] min-[821px]:justify-end" aria-label="Navigation secondaire">
      <% navigation_items.each do |item| %>
        <%= link_to item[:label], item[:path] %>
      <% end %>
    </nav>
  </div>
<% end %>
