<%= tag.footer id: id, class: component_classes, data: debug_data do %>
  <div class="pv2-public-footer__main grid">
    <div class="pv2-public-footer__hero grid gap-4 min-[1021px]:grid-cols-2">
      <div class="pv2-public-footer__intro grid w-full min-w-0">
        <p class="pv2-public-footer__kicker"><%= eyebrow %></p>
        <h2><%= title %></h2>
        <p><%= text %></p>
        <div class="pv2-public-footer__actions flex flex-wrap gap-2">
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: public_v2_new_quote_path, variant: :primary, size: :md, shape: :pill, classes: "pv2-public-footer__button pv2-public-footer__button--primary", debug: debug?) %>
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Appeler", path: phone_href, variant: :secondary, size: :md, shape: :pill, classes: "pv2-public-footer__button pv2-public-footer__button--secondary", debug: debug?) %>
        </div>
      </div>

      <aside class="pv2-public-footer__contact-panel grid" aria-label="Contact showroom">
        <div class="pv2-public-footer__contact-list grid" aria-label="Coordonnees">
          <% contact_items.each do |item| %>
            <%= link_to item[:path], class: "pv2-public-footer__contact-card pv2-public-footer__contact-card--#{item[:icon]} grid" do %>
              <%= contact_icon(item[:icon]) %>
              <strong><%= item[:value] %></strong>
            <% end %>
          <% end %>
        </div>
      </aside>
    </div>
  </div>

  <div class="pv2-public-footer__bottom flex flex-col items-start gap-3 pt-4 min-[821px]:flex-row min-[821px]:items-center min-[821px]:justify-between">
    <span>Les Artisans du Store</span>
    <nav class="flex flex-wrap gap-[0.55rem] min-[821px]:justify-end" aria-label="Navigation secondaire">
      <% navigation_items.each do |item| %>
        <%= link_to item[:label], item[:path] %>
      <% end %>
    </nav>
  </div>
<% end %>
