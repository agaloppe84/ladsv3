<section class="<%= component_classes %>" aria-labelledby="public-v2-partners-title" <%= debug_attributes %>>
  <div class="pv2-partners__head grid max-w-[620px] gap-2">
    <p class="pv2-eyebrow">Marques techniques</p>
    <h2 id="public-v2-partners-title"><%= title %></h2>
    <p><%= text %></p>
  </div>

  <div class="pv2-partners__grid grid grid-cols-2 gap-3 min-[821px]:grid-cols-3 min-[1121px]:grid-cols-5">
    <% partners.each do |partner| %>
      <figure class="pv2-partners__item grid min-h-28 items-center justify-items-center gap-2 p-[0.9rem]" title="<%= partner[:name] %>" aria-label="<%= partner[:name] %>">
        <%= inline_svg_tag("logos/#{partner[:logo]}", class: "pv2-partners__logo") %>
        <figcaption><%= partner[:name] %></figcaption>
      </figure>
    <% end %>
  </div>
</section>
