<section id="devis" class="pv2-home-section pv2-home-quote-panel grid w-full min-w-0 grid-cols-1 items-start gap-6 p-5 min-[1121px]:grid-cols-[minmax(0,.78fr)_minmax(320px,.48fr)]">
  <div>
    <p class="pv2-eyebrow">Demande de devis</p>
    <h2>Selectionner un produit ou laisser l'equipe orienter le projet.</h2>
    <p>Un premier retour permet de cadrer le besoin, les dimensions, l'exposition et les options utiles.</p>
  </div>
  <%= form_with url: public_v2_new_quote_path, method: :get, class: "pv2-home-form grid gap-3 p-4", data: { turbo: false } do |form| %>
    <label class="grid gap-[0.35rem]">
      Produit
      <%= form.select :product_id,
            options_for_select(product_options, selected_product_id),
            { include_blank: "A definir avec l'equipe" } %>
    </label>
    <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", type: "submit", variant: :primary) %>
  <% end %>
</section>
