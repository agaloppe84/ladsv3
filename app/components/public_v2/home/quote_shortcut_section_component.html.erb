<section id="devis" class="<%= component_classes %>" <%= debug_attributes %>>
  <div class="grid gap-3">
    <%= render PublicV2::Ui::ActionDockComponent.new(
      kicker: "Demande de devis",
      title: "Envoyer le bon point de depart.",
      text: "Produit, photo ou dimensions : l'equipe revient avec un premier cadrage utile, pas un devis automatique hors-sol.",
      primary_label: "Ouvrir le formulaire",
      primary_path: public_v2_new_quote_path,
      secondary_label: "Appeler",
      secondary_path: PublicV2::ContactInfo.phone_href,
      meta: "Premier retour commercial sous 48h.",
      variant: :soft,
      debug: debug?
    ) %>

    <%= render PublicV2::Ui::StepRailComponent.new(
      steps: home_page.project_steps,
      label: "Ce qu'on regarde",
      variant: :compact,
      debug: debug?
    ) %>
  </div>

  <%= form_with url: public_v2_new_quote_path, method: :get, class: "pv2-home-form grid gap-3 p-4", data: { turbo: false } do |form| %>
    <label class="grid gap-[0.35rem]">
      Produit
      <%= form.select :product_id,
            options_for_select(product_options, selected_product_id),
            { include_blank: "A definir avec l'equipe" } %>
    </label>
    <%= render PublicV2::Ui::ButtonComponent.new(label: "Preparer ma demande", type: "submit", variant: :primary, full_width: true, debug: debug?) %>
  <% end %>
</section>
