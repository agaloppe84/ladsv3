<section class="<%= component_classes %>" <%= debug_attributes %>>
  <div class="pv2-home-hero-v2__layout grid w-full min-w-0 items-stretch gap-4 min-[1121px]:grid-cols-[minmax(0,0.95fr)_minmax(360px,0.72fr)]">
    <div class="pv2-home-hero-v2__copy grid min-w-0 gap-3">
      <%= render PublicV2::Ui::SpotlightPanelComponent.new(
        kicker: "Stores / volets / fermetures",
        title: "Un projet cadre vite, un devis plus clair.",
        text: "Conseil showroom, lecture technique et pose locale pour stores, volets, portes de garage, moustiquaires et pergolas.",
        variant: :soft,
        size: :md,
        classes: "pv2-home-hero-v2__lead",
        debug: debug?
      ) do %>
        <div class="pv2-home-hero-v2__actions flex flex-wrap gap-2">
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: public_v2_new_quote_path, variant: :primary, size: :sm, debug: debug?) %>
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Voir les produits", path: public_v2_categories_path, variant: :secondary, size: :sm, debug: debug?) %>
        </div>
      <% end %>

      <div class="pv2-home-hero-v2__panels grid min-w-0 gap-3 min-[641px]:grid-cols-3">
        <% support_panels.each do |panel| %>
          <%= render PublicV2::Ui::PanelComponent.new(
            kicker: panel[:kicker],
            title: panel[:title],
            variant: panel[:variant],
            padding: :sm,
            classes: "h-full",
            debug: debug?
          ) do %>
            <p><%= panel[:text] %></p>
          <% end %>
        <% end %>
      </div>
    </div>

    <aside class="pv2-home-hero-v2__media-col grid min-w-0 gap-3">
      <div class="pv2-home-media pv2-home-hero-v2__media">
        <%= render PublicV2::Ui::MediaFrameComponent.new(
          image: hero_image,
          alt: featured_alt,
          loading: "eager",
          ratio: :wide,
          classes: "h-full min-h-full",
          debug: debug?
        ) %>
      </div>

      <%= render PublicV2::Ui::ProofRailComponent.new(items: proof_items, label: "Preuves utiles", variant: :compact, debug: debug?) %>
    </aside>
  </div>
</section>
