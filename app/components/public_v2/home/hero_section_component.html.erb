<section class="<%= component_classes %>" <%= debug_attributes %>>
  <div class="grid w-full min-w-0 items-stretch gap-4 min-[1121px]:grid-cols-2">
    <%= render PublicV2::Ui::SpotlightPanelComponent.new(
      kicker: "Stores · Volets · Fermetures",
      title: "Protection solaire et fermetures sur mesure.",
      text: "Les Artisans du Store accompagnent les projets de stores, volets roulants, portes de garage, moustiquaires et pergolas dans le Rhone.",
      variant: :flashy,
      size: :lg,
      debug: debug?
    ) %>

    <div class="pv2-home-media min-h-[320px] min-[1121px]:h-full min-[1121px]:min-h-0">
      <%= render PublicV2::Ui::MediaFrameComponent.new(
        image: home_page.featured_image || "magasin-01.jpeg",
        alt: featured_alt,
        loading: "eager",
        classes: "h-full min-h-full",
        debug: debug?
      ) %>
    </div>
  </div>

  <div class="grid w-full min-w-0 grid-cols-2 gap-3 min-[1121px]:grid-cols-4">
    <% support_panels.each do |panel| %>
      <%= render PublicV2::Ui::PanelComponent.new(kicker: panel[:kicker], title: panel[:title], variant: :outline, padding: :sm, classes: "h-full", debug: debug?) do %>
        <p><%= panel[:text] %></p>
      <% end %>
    <% end %>
  </div>
</section>
