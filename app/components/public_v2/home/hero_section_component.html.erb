<section class="<%= component_classes %>" <%= debug_attributes %>>
  <header class="pv2-home-hero-v2__intro">
    <h1>
      <span>Les Artisans du</span>
      <span>Store</span>
    </h1>
  </header>

  <div class="pv2-home-hero-v2__stage">
    <div class="pv2-home-hero-v2__left-stack">
      <article class="pv2-home-hero-v2__card">
        <strong>Devis clair <span>Vite</span></strong>
        <p>On verifie l'usage, l'exposition, les dimensions et les contraintes avant de chiffrer.</p>

        <div class="pv2-home-hero-v2__actions">
          <%= render PublicV2::Ui::ButtonComponent.new(label: "Demander un devis", path: public_v2_new_quote_path, variant: :primary, size: :md, shape: :pill, classes: "pv2-home-hero-v2__quote-button", debug: debug?) %>
        </div>
      </article>

      <aside class="pv2-home-hero-v2__facts-card" aria-label="Preuves utiles">
        <% hero_fact_items.each do |item| %>
          <article class="pv2-home-hero-v2__fact-card pv2-home-hero-v2__fact-card--<%= item[:variant] %>">
            <strong>
              <% if item[:value] == "200m2" %>
                200m<sup>2</sup>
              <% else %>
                <%= item[:value] %>
              <% end %>
            </strong>
            <p><%= item[:text] %></p>
          </article>
        <% end %>
      </aside>
    </div>

    <div
      class="pv2-home-hero-v2__media-card"
      data-controller="hero-product-slider"
      data-hero-product-slider-initial-index-value="<%= hero_product_initial_index %>"
      data-action="keydown.left->hero-product-slider#previous keydown.right->hero-product-slider#next"
      role="region"
      aria-label="Produits en situation"
      tabindex="0"
      style="--pv2-hero-media-accent: <%= hero_product_initial_card[:accent] %>;"
    >
      <div class="pv2-home-hero-v2__media-viewport">
        <div
          class="pv2-home-hero-v2__media-track"
          data-hero-product-slider-target="track"
        >
          <% hero_product_cards.each_with_index do |card, index| %>
            <% is_active = index == hero_product_initial_index %>
            <article
              class="pv2-home-hero-v2__product-slide <%= "is-active" if is_active %>"
              data-hero-product-slider-target="slide"
              aria-label="<%= card[:label] %>"
              aria-current="<%= is_active ? "true" : "false" %>"
              aria-hidden="<%= is_active ? "false" : "true" %>"
              style="--pv2-hero-media-accent: <%= card[:accent] %>;"
            >
              <%= image_tag(
                card[:image],
                alt: card[:alt],
                loading: is_active ? "eager" : "lazy",
                decoding: "async",
                class: "pv2-cover-image"
              ) %>
              <div class="pv2-home-hero-v2__media-caption">
                <span><%= card[:kicker] %></span>
                <strong><%= card[:title] %> <em><%= card[:accent_title] %></em></strong>
              </div>
            </article>
          <% end %>
        </div>
      </div>

      <nav class="pv2-home-hero-v2__media-dots" aria-label="Changer de produit">
        <% hero_product_cards.each_with_index do |card, index| %>
          <% is_active = index == hero_product_initial_index %>
          <button
            type="button"
            class="pv2-home-hero-v2__media-dot <%= "is-active" if is_active %>"
            data-hero-product-slider-target="dot"
            data-action="hero-product-slider#goTo"
            data-hero-product-slider-index-param="<%= index %>"
            aria-current="<%= is_active ? "true" : "false" %>"
            aria-label="Afficher <%= card[:label] %>"
          ></button>
        <% end %>
      </nav>
    </div>
  </div>
</section>
