<section id="showroom" class="<%= component_classes %>" <%= debug_attributes %>>
  <header class="pv2-home-showroom-story__head">
    <h2>
      <span>Comparer</span>
      <span class="pv2-home-showroom-story__accent">Choisir juste</span>
    </h2>
    <p>Au showroom de L'Arbresle, les produits deviennent concrets : toiles, moteurs, finitions et contraintes de pose se comparent avant le devis.</p>
  </header>

  <div class="pv2-home-showroom-story__layout">
    <article class="pv2-home-showroom-story__card">
      <strong>Voir les bons détails</strong>
      <p>Une équipe métier vous aide à choisir ce qui compte vraiment : usage quotidien, exposition, intégration en façade et confort après pose.</p>

      <div class="pv2-home-showroom-story__focus-grid">
        <% focus_items.each do |item| %>
          <div>
            <span>
              <%= inline_svg_tag(item[:icon], class: "pv2-home-showroom-story__icon") %>
              <%= item[:label] %>
            </span>
            <p><%= item[:text] %></p>
          </div>
        <% end %>
      </div>
    </article>

    <figure class="pv2-home-showroom-story__media" aria-label="Showroom Les Artisans du Store">
      <%= image_tag("public_v2/showroom-textile-catalog-cgi.png", alt: "Catalogue de toiles et finitions textile Les Artisans du Store", loading: "lazy", decoding: "async", class: "pv2-cover-image") %>
      <figcaption>
        <span>200m<sup>2</sup></span>
      </figcaption>
    </figure>
  </div>
</section>
