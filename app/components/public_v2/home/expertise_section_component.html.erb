<section id="solutions" class="pv2-home-section pv2-home-graphite__matrix grid w-full min-w-0 gap-5">
  <%= render PublicV2::Content::SectionHeaderComponent.new(
    kicker: "Expertise",
    title: "Trois besoins principaux, une lecture rapide.",
    variant: :home
  ) %>

  <div class="pv2-home-graphite__tracks grid grid-cols-1 gap-3 min-[821px]:grid-cols-3">
    <% tracks.each do |number, title, text| %>
      <article class="grid gap-2 p-4">
        <span><%= number %></span>
        <h3><%= title %></h3>
        <p><%= text %></p>
      </article>
    <% end %>
  </div>
</section>
