<%= tag.section class: component_classes, data: debug_data do %>
  <div class="pv2-quote-hero-v2__layout grid min-w-0 items-stretch gap-4 min-[1121px]:grid-cols-[minmax(0,0.78fr)_minmax(320px,0.52fr)]">
    <%= render PublicV2::Ui::SpotlightPanelComponent.new(
      kicker: "Devis gratuit",
      title: "Un bon devis commence par un bon cadrage.",
      text: "Produit deja repere ou besoin encore flou : envoyez les infos utiles, l'equipe revient vers vous pour valider dimensions, exposition et contraintes.",
      variant: :soft,
      size: :md,
      classes: "pv2-quote-hero-v2__lead",
      debug: debug?
    ) do %>
      <div class="flex flex-wrap gap-2">
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Remplir le formulaire", path: "#formulaire", variant: :primary, size: :sm, debug: debug?) %>
        <%= render PublicV2::Ui::ButtonComponent.new(label: "Appeler", path: PublicV2::ContactInfo.phone_href, variant: :secondary, size: :sm, debug: debug?) %>
      </div>
    <% end %>

    <aside class="grid min-w-0 gap-3">
      <%= render PublicV2::Ui::ProofRailComponent.new(
        items: quote_page.hero_proof_items,
        label: "Avant le devis",
        variant: :soft,
        debug: debug?
      ) %>

      <%= render PublicV2::Ui::StepRailComponent.new(
        steps: quote_page.guide_steps,
        label: "Parcours",
        variant: :rail,
        debug: debug?
      ) %>
    </aside>
  </div>
<% end %>
