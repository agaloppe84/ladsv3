<%= tag.section id: "formulaire", class: component_classes, data: debug_data do %>
  <header class="pv2-quote-intro">
    <h1>Demande de devis</h1>
    <p>Quelques infos suffisent. On vous rappelle pour valider les dimensions, la pose et les options utiles.</p>
  </header>

  <div class="pv2-quote-board">
    <%= render PublicV2::Quotes::FormPanelComponent.new(
      quote_page: quote_page,
      url: form_url,
      debug: debug?
    ) %>

    <aside class="pv2-quote-context" aria-label="Informations utiles">
      <% if quote_page.selected_product? %>
        <%= render PublicV2::Quotes::FormProductCardComponent.new(
          product: quote_page.selected_product,
          image: quote_page.selected_product_image,
          debug: debug?
        ) %>
      <% end %>

      <article class="pv2-quote-context__panel pv2-quote-context__panel--steps <%= debug_class %>" <%= debug_attributes %>>
        <ol>
          <li>
            <strong>1. Cadrage</strong>
            <p>On verifie le produit, les dimensions et les contraintes.</p>
          </li>
          <li>
            <strong>2. Conseil</strong>
            <p>L'equipe vous oriente vers la bonne solution.</p>
          </li>
          <li>
            <strong>3. Devis</strong>
            <p>Retour clair pour decider.</p>
          </li>
        </ol>
      </article>

    </aside>
  </div>
<% end %>
