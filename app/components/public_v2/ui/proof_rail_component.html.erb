<section class="<%= component_classes %>" <%= debug_attributes %>>
  <% if label.present? %>
    <p class="pv2-ui-proof-rail__label"><%= label %></p>
  <% end %>

  <div class="pv2-ui-proof-rail__items grid min-w-0 gap-2">
    <% items.each do |item| %>
      <article class="pv2-ui-proof-rail__item grid min-w-0 gap-1">
        <strong><%= item[:value] %></strong>
        <span><%= item[:label] %></span>
        <% if item[:text].present? %>
          <p><%= item[:text] %></p>
        <% end %>
      </article>
    <% end %>
  </div>
</section>
