<section class="<%= component_classes %>" <%= debug_attributes %>>
  <% if label.present? %>
    <p class="pv2-ui-step-rail__label"><%= label %></p>
  <% end %>

  <ol class="pv2-ui-step-rail__items grid min-w-0 gap-2">
    <% steps.each_with_index do |step, index| %>
      <li class="pv2-ui-step-rail__item grid min-w-0 gap-1">
        <span><%= step[:kicker].presence || Kernel.format("%02d", index + 1) %></span>
        <strong><%= step[:title] %></strong>
        <% if step[:text].present? %>
          <p><%= step[:text] %></p>
        <% end %>
      </li>
    <% end %>
  </ol>
</section>
