<div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
  <div class="flex items-center gap-3 rounded-3xl border border-slate-200 bg-white px-5 py-4">
    <svg class="h-12 w-12 shrink-0 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4.5" y="4.5" width="15" height="15" rx="4" />
      <path d="M12 11.25v4.5" />
      <path d="M12 8.25h.01" />
    </svg>

    <div class="min-w-0">
      <p class="text-base font-semibold tracking-tight text-slate-950"><%= @event.title.downcase.capitalize %></p>
      <p class="mt-1 text-base font-medium tracking-tight text-slate-400"><%= @event.content %></p>
    </div>

    <time datetime="<%= @event.created_at.iso8601 %>" class="ml-auto hidden shrink-0 text-xs font-medium tracking-tight text-slate-400 sm:block">
      <%= I18n.l @event.created_at.to_date, format: :long %>
    </time>
  </div>
</div>
