<section class="mt-10">
  <div class="relative w-full overflow-hidden rounded-3xl border border-slate-200 bg-gradient-to-b from-slate-100">
    <div class="absolute inset-0 bg-gradient-to-b from-white/70 via-transparent to-white/40"></div>

    <div class="relative z-10 p-6 md:p-10">
      <h2 class="text-3xl font-extrabold leading-[0.92] tracking-tight text-slate-900 md:text-5xl">
        Nos engagements
      </h2>

      <p class="mt-2 text-xl font-extrabold leading-[0.92] tracking-tight text-transparent bg-gradient-to-r from-teal-500 to-lime-300 bg-clip-text [-webkit-text-fill-color:transparent] md:text-xl">
        Devis rapide, pose experte, suivi durable
      </p>

      <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-2">
        <div class="">
          <div class="flex items-center">
            <p class="text-3xl mr-6 font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-teal-500 to-lime-300 bg-clip-text [-webkit-text-fill-color:transparent]">Devis sous 48h</p>
            <%= link_to new_quote_path, class: "inline-flex text-slate-400 items-center justify-center rounded-lg hover:text-teal-500 transition tracking-tight" do %>
              <div><%= inline_svg_tag("icons/arrow-right-circle.svg", class: "h-8 w-8 shrink-0") %></div>
            <% end %>
          </div>
          <p class="mt-2 text-xl font-extrabold text-slate-600 leading-[0.9] tracking-tight">Chiffrage clair, sans surprise</p>
        </div>

        <div class="">
          <p class="text-3xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-teal-500 to-lime-300 bg-clip-text [-webkit-text-fill-color:transparent]">Pose maîtrisée</p>
          <p class="mt-2 text-xl font-extrabold text-slate-600 leading-[0.9] tracking-tight">Équipe interne expérimentée</p>
        </div>

        <div class="">
          <p class="text-3xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-teal-500 to-lime-300 bg-clip-text [-webkit-text-fill-color:transparent]">Garantie & SAV</p>
          <p class="mt-2 text-xl font-extrabold text-slate-600 leading-[0.9] tracking-tight">Accompagnement après pose</p>
        </div>

        <div class="">
          <p class="text-3xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-teal-500 to-lime-300 bg-clip-text [-webkit-text-fill-color:transparent]">Marques de référence</p>
          <p class="mt-2 text-xl font-extrabold text-slate-600 leading-[0.9] tracking-tight">Motorisations Somfy, toiles Dickson…</p>
        </div>
      </div>
    </div>
  </div>
</section>
