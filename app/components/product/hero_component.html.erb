<section data-reveal-target="item" class="opacity-0 translate-y-4 transition-all duration-700 ease-out rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="grid gap-5 lg:grid-cols-2">
    <div class="flex flex-col justify-center p-2 md:p-6">
      <p class="inline-flex w-fit items-center rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.12em] text-orange-500">
        <%= product.category.name %>
      </p>
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 md:text-5xl"><%= product.name %></h1>
      <p class="mt-2 max-w-prose text-base leading-7 text-slate-600 font-medium"><%= product.description %></p>

      <div class="mt-12 flex flex-wrap items-center gap-3">
        <%= link_to "Devis", new_quote_path(product_id: product.id), class: "inline-flex items-center justify-center rounded-2xl border border-orange-500 bg-orange-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-orange-600 hover:border-orange-600" %>
        <%= link_to "Documentation", "#product-documentation", class: "inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
      </div>

      <% if manufacturers.any? || motorists.any? %>
        <div class="mt-6 flex flex-wrap gap-2">
          <% manufacturers.each do |manufacturer| %>
            <div class="inline-flex h-14 items-center justify-center rounded-lg border border-slate-200 bg-white px-3">
              <% if manufacturer.logo.present? %>
                <%= inline_svg_tag("logos/#{manufacturer.logo}", class: "h-10 w-20 fill-slate-700 text-slate-700") %>
              <% else %>
                <span class="text-xs font-semibold text-slate-600"><%= manufacturer.name %></span>
              <% end %>
            </div>
          <% end %>

          <% motorists.each do |motorist| %>
            <div class="inline-flex h-14 items-center justify-center rounded-lg border border-slate-200 bg-white px-3">
              <% if motorist.logo.present? %>
                <%= inline_svg_tag("logos/#{motorist.logo}", class: "h-8 w-20 fill-slate-700 text-slate-700") %>
              <% else %>
                <span class="text-xs font-semibold text-slate-600"><%= motorist.name %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="relative min-h-[320px] overflow-hidden rounded-2xl border border-slate-200 md:min-h-[420px]">
      <% if images.any? %>
        <div
          class="relative h-full"
          data-controller="hero-rotator"
          data-hero-rotator-interval-value="7000"
          data-hero-rotator-pause-on-hover-value="true"
        >
          <% images.each_with_index do |image, index| %>
            <figure
              data-hero-rotator-target="slide"
              class="absolute inset-0 h-full w-full transition-opacity duration-700 ease-in-out <%= "opacity-0 pointer-events-none" unless index.zero? %>"
              aria-hidden="<%= index.zero? ? "false" : "true" %>"
            >
              <%= cl_image_tag(image.key, crop: :scale, class: "h-full w-full object-cover object-center") %>
            </figure>
          <% end %>
        </div>
      <% else %>
        <img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1400&q=80" alt="<%= product.name %>" class="h-full w-full object-cover object-center">
      <% end %>
    </div>
  </div>
</section>
