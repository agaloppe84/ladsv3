<section id="product-documentation" data-reveal-target="item" class="opacity-0 translate-y-4 transition-all duration-700 ease-out rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="flex items-center gap-2 px-2 py-1">
    <%= inline_svg_tag("icons/pdf.svg", class: "h-5 w-5 fill-slate-500 text-slate-500") %>
    <h2 class="text-base font-bold text-slate-900">Documentation</h2>
  </div>

  <div class="mt-4 w-full space-y-2">
    <% @documentations.each do |documentation| %>
      <article class="flex h-14 w-full items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-3 transition hover:border-slate-300 hover:shadow-sm">
        <div class="flex min-w-0 items-center gap-2">
          <div class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-slate-200 bg-slate-50">
            <%= inline_svg_tag("icons/pdf.svg", class: "h-4 w-4 fill-slate-500 text-slate-500") %>
          </div>
          <p class="truncate text-sm font-semibold text-slate-700"><%= documentation.filename %></p>
        </div>
        <%= link_to "Ouvrir", cloudinary_url(documentation.key), target: "_blank", class: "inline-flex shrink-0 items-center rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100" %>
      </article>
    <% end %>
  </div>
</section>
