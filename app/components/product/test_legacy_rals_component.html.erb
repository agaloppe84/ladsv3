<section data-reveal-target="item" class="opacity-0 translate-y-4 transition-all duration-700 ease-out">
  <div class="rounded-3xl border border-slate-200 bg-white p-5 md:p-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-xl font-extrabold tracking-tight text-slate-900 md:text-2xl">Source legacy</h2>
      <p class="text-xs font-semibold text-slate-500">Liens historiques produit ↔ RAL (`products_rals`)</p>
    </div>

    <% if rals.any? %>
      <ul role="list" class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-6">
        <% rals.each do |ral| %>
          <li class="rounded-xl border border-slate-200 bg-white p-2">
            <div class="mx-auto h-7 w-7 rounded-full border border-slate-300" style="background-color: <%= swatch_color(ral) %>;"></div>
            <p class="mt-1 text-center text-[11px] font-semibold text-slate-700"><%= ral.ref %></p>
            <p class="truncate text-center text-[10px] text-slate-500"><%= ral.name %></p>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-4 text-sm text-slate-500">Aucun RAL legacy sur ce produit.</p>
    <% end %>
  </div>
</section>
