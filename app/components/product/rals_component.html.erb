<article class="rounded-2xl border border-slate-200 bg-white p-5">
  <div class="flex items-center gap-2">
    <%= inline_svg_tag("icons/cube-transparent.svg", class: "h-5 w-5 text-slate-500 stroke-slate-500") %>
    <h3 class="text-sm font-semibold text-slate-900">Coloris armature</h3>
  </div>

  <ul role="list" class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
    <% @rals.first(12).each do |ral| %>
      <li class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="mx-auto h-8 w-8 rounded-full border border-slate-300" style="background-color: <%= ral.hex %>;"></div>
        <p class="mt-2 truncate text-center text-xs font-semibold text-slate-700"><%= ral.ref %></p>
        <p class="truncate text-center text-[11px] text-slate-500"><%= ral.name %></p>
      </li>
    <% end %>
  </ul>

  <% if @rals.size > 12 %>
    <p class="mt-3 text-xs font-medium text-slate-500">+ <%= @rals.size - 12 %> coloris supplémentaires disponibles.</p>
  <% end %>
</article>
