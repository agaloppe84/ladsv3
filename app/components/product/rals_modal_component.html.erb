<div
  data-rals-modal-target="overlay"
  class="fixed inset-0 z-[100] hidden bg-slate-950/55 p-3 opacity-0 transition-opacity duration-300 sm:p-6"
>
  <div class="flex h-full w-full items-end justify-center sm:items-center">
    <section
      data-rals-modal-target="panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="rals-modal-title"
      class="w-full max-w-4xl overflow-hidden rounded-3xl border border-slate-200 bg-white opacity-0 shadow-2xl transition-all duration-300 scale-[0.98] translate-y-3"
    >
      <div class="flex h-[78vh] max-h-[78vh] flex-col sm:h-[72vh]">
        <header class="relative border-b border-slate-200 bg-gradient-to-r from-slate-50 to-white px-4 py-3 sm:px-6 sm:py-4">
          <div class="pr-12">
            <h3 id="rals-modal-title" class="text-sm font-bold text-slate-900 sm:text-base">
              Tous les coloris armature
            </h3>
            <p class="mt-1 text-xs text-slate-500">
              <%= @rals.size %> coloris disponibles
            </p>
          </div>

          <button
            type="button"
            data-rals-modal-close
            class="absolute right-3 top-3 inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 transition hover:border-slate-300 hover:text-slate-700 sm:right-4 sm:top-4"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <span class="sr-only">Fermer</span>
          </button>
        </header>

        <div class="flex-1 overflow-y-auto px-4 py-4 sm:px-6 sm:py-5">
          <ul role="list" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
            <% @rals.each do |ral| %>
              <li class="rounded-2xl border border-slate-200 bg-white p-3 transition duration-200 hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-sm">
                <div class="mx-auto h-10 w-10 rounded-full border border-slate-300 shadow-inner" style="background-color: <%= ral.hex %>;"></div>
                <p class="mt-2 truncate text-center text-xs font-semibold text-slate-800"><%= ral.ref %></p>
                <p class="truncate text-center text-[11px] text-slate-500"><%= ral.name %></p>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </section>
  </div>
</div>
