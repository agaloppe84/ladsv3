<article class="rounded-2xl border border-slate-200 bg-white p-5">
  <div class="flex items-center gap-2">
    <%= inline_svg_tag("icons/heart.svg", class: "h-5 w-5 text-slate-500 fill-slate-500") %>
    <h3 class="text-sm font-semibold text-slate-900">Marques</h3>
  </div>

  <div class="mt-4 grid grid-cols-2 gap-2 md:grid-cols-3">
    <% @manufacturers.each do |manufacturer| %>
      <div class="flex min-h-12 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 p-3 transition hover:bg-white">
        <% if manufacturer.logo.present? %>
          <%= inline_svg_tag("logos/#{manufacturer.logo}", class: "h-8 w-20 fill-slate-700 text-slate-700") %>
        <% else %>
          <span class="text-xs font-semibold text-slate-600"><%= manufacturer.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</article>
