<div class="grid gap-4 md:grid-cols-2">
  <% if @product.infos.present? %>
    <article class="rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center gap-2">
        <%= inline_svg_tag("icons/information-circle.svg", class: "h-5 w-5 text-slate-500 stroke-slate-500") %>
        <h3 class="text-sm font-semibold text-slate-900">Infos</h3>
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-600"><%= @product.infos %></p>
    </article>
  <% end %>

  <% if @product.options.any? %>
    <article class="rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center gap-2">
        <%= inline_svg_tag("icons/queue-list.svg", class: "h-5 w-5 text-slate-500 stroke-slate-500") %>
        <h3 class="text-sm font-semibold text-slate-900">Spécifications</h3>
      </div>
      <ul role="list" class="mt-3 space-y-2 text-sm leading-6 text-slate-600">
        <% @product.options.each do |option| %>
          <li class="flex gap-2">
            <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-orange-400"></span>
            <span><%= option.content %></span>
          </li>
        <% end %>
      </ul>
    </article>
  <% end %>
</div>
