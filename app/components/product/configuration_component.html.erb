<section data-reveal-target="item" class="opacity-0 translate-y-4 transition-all duration-700 ease-out ">
  <% if !show_specs? && parts.empty? %>
    <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-5">
      <p class="text-sm font-semibold text-slate-700">Aucune information disponible pour ce produit.</p>
    </div>
  <% else %>
    <div data-controller="product-tabs" data-product-tabs-initial-value="<%= initial_tab %>">
      <div class="mt-10 mb-6 pb-2 border-b flex flex-wrap items-center gap-5 px-2">
        <% if show_specs? %>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab-id="specs"
            data-product-tabs-target="tab"
            data-action="product-tabs#select"
            class="inline-flex items-center gap-1.5 py-2 text-[15px] font-semibold text-slate-400 transition-colors hover:text-slate-950"
          >
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="4.5" y="4.5" width="15" height="15" rx="4" />
              <path d="M12 11.25v4.5" />
              <path d="M12 8.25h.01" />
            </svg>
            <span>Infos et spécifications</span>
          </button>
        <% end %>

        <% parts.each do |part| %>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab-id="<%= part_tab_id(part) %>"
            data-product-tabs-target="tab"
            data-action="product-tabs#select"
            class="inline-flex items-center gap-1.5 py-2 text-[15px] font-semibold text-slate-400 transition-colors hover:text-slate-950"
          >
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="4.5" y="4.5" width="15" height="15" rx="4" />
              <path d="M8.25 7.5v9" />
              <path d="M12 7.5v9" />
              <path d="M15.75 7.5v9" />
              <path d="M7.5 16.5h9" />
            </svg>
            <span><%= part_tab_label(part) %></span>
          </button>
        <% end %>

        <% if show_canvas_selector? %>
          <%= link_to canvas_selector_product_path(slug: product.slug), class: "inline-flex items-center gap-1.5 py-2 text-[15px] font-semibold text-slate-400 transition-colors hover:text-slate-950" do %>
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="4.5" y="4.5" width="15" height="15" rx="4" />
              <path d="M8.25 7.5h7.5" />
              <path d="M8.25 16.5h7.5" />
              <path d="M9.5 7.5c1.5 2.1 1.5 6.9 0 9" />
              <path d="M14.5 7.5c-1.5 2.1-1.5 6.9 0 9" />
            </svg>
            <span>Sélecteur de toile Dickson</span>
          <% end %>
        <% end %>
      </div>

      <div class="">
        <% if show_specs? %>
          <div data-panel-id="specs" data-product-tabs-target="panel" role="tabpanel" aria-hidden="true" class="hidden">
            <%= render Product::SpecsComponent.new(product: product) %>
          </div>
        <% end %>

        <% parts.each do |part| %>
          <% part_rals = rals_for(part) %>
          <% preview_rals = preview_rals_for(part) %>
          <div data-panel-id="<%= part_tab_id(part) %>" data-product-tabs-target="panel" role="tabpanel" aria-hidden="true" class="hidden">
            <article
              data-controller="rals-modal"
              data-action="keydown.esc@window->rals-modal#close"
              class="rounded-2xl border border-slate-200 bg-white p-4"
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div>
                  <h3 class="text-sm font-bold text-slate-900"><%= part_tab_label(part) %></h3>
                  <p class="text-xs font-medium text-slate-500">
                    Palette: <span class="font-semibold text-slate-700"><%= part.color_palette&.name || "Palette inconnue" %></span>
                  </p>
                </div>
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-semibold text-slate-700">
                  <%= part_rals.size %> coloris
                </span>
              </div>

              <% if part_rals.empty? %>
                <p class="mt-3 text-xs font-medium text-slate-500">Aucune couleur configurée pour cette part.</p>
              <% else %>
                <ul role="list" class="mt-4 grid grid-cols-3 gap-3 sm:grid-cols-4 lg:grid-cols-8">
                  <% preview_rals.each do |ral| %>
                    <li class="rounded-xl border border-slate-200 bg-white p-3">
                      <div class="mx-auto h-8 w-8 rounded-full border border-slate-300" style="background-color: <%= swatch_color(ral) %>;"></div>
                      <p class="mt-2 truncate text-center text-xs font-semibold text-slate-700"><%= ral.ref %></p>
                      <p class="truncate text-center text-[11px] text-slate-500"><%= ral.name %></p>
                    </li>
                  <% end %>
                </ul>

                <% if part_rals.size > 16 %>
                  <button
                    type="button"
                    data-action="click->rals-modal#open"
                    class="group mt-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:border-slate-300 hover:bg-slate-100 hover:text-slate-700"
                  >
                    <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-white px-1 text-[11px] font-bold text-slate-600 shadow-sm">
                      +<%= hidden_rals_count(part) %>
                    </span>
                    <span>Voir tous les coloris</span>
                  </button>

                  <%= render Product::RalsModalComponent.new(rals: part_rals, title: part_modal_title(part)) %>
                <% end %>
              <% end %>
            </article>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
