<section data-reveal-target="item" class="opacity-0 translate-y-4 transition-all duration-700 ease-out rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="flex items-center gap-2 px-2 py-1">
    <%= inline_svg_tag("icons/queue-list.svg", class: "h-5 w-5 text-slate-500 stroke-slate-500") %>
    <h2 class="text-base font-bold text-slate-900">Configuration produit</h2>
  </div>

  <div
    class="mt-3"
    data-controller="product-tabs"
    data-product-tabs-initial-value="<%= initial_tab %>"
  >
    <div class="flex flex-wrap items-center justify-between gap-2 p-2">
      <div class="flex flex-wrap gap-2" role="tablist" aria-label="Sections produit">
        <% if show_specs? %>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab-id="specs"
            data-product-tabs-target="tab"
            data-action="product-tabs#select"
            class="rounded-xl border px-3 py-2 text-xs font-semibold transition"
          >
            Infos et spécifications
          </button>
        <% end %>

        <% if show_motorization? %>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab-id="motorization"
            data-product-tabs-target="tab"
            data-action="product-tabs#select"
            class="rounded-xl border px-3 py-2 text-xs font-semibold transition"
          >
            Motorisation
          </button>
        <% end %>

        <% if show_rals? %>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab-id="rals"
            data-product-tabs-target="tab"
            data-action="product-tabs#select"
            class="rounded-xl border px-3 py-2 text-xs font-semibold transition"
          >
            Coloris armature
          </button>
        <% end %>
      </div>

      <% if show_canvas_selector? %>
        <%= link_to "Sélecteur de toile", canvas_selector_product_path(product), class: "inline-flex items-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100" %>
      <% end %>
    </div>

    <div class="p-2 pt-4">
      <% if show_specs? %>
        <div data-panel-id="specs" data-product-tabs-target="panel" role="tabpanel" aria-hidden="true" class="hidden">
          <%= render Product::SpecsComponent.new(product: product) %>
        </div>
      <% end %>

      <% if show_motorization? %>
        <div data-panel-id="motorization" data-product-tabs-target="panel" role="tabpanel" aria-hidden="true" class="hidden">
          <%= render Product::MotorizationComponent.new(motorists: product.motorists) %>
        </div>
      <% end %>

      <% if show_rals? %>
        <div data-panel-id="rals" data-product-tabs-target="panel" role="tabpanel" aria-hidden="true" class="hidden">
          <%= render Product::RalsComponent.new(rals: product.rals) %>
        </div>
      <% end %>

    </div>
  </div>
</section>
