<article class="rounded-2xl border border-slate-200 bg-white p-5">
  <div class="flex items-center gap-2">
    <%= inline_svg_tag("icons/motor.svg", class: "h-5 w-5 text-slate-500 fill-slate-500") %>
    <h3 class="text-sm font-semibold text-slate-900">Motorisation</h3>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    <% @motorists.each do |motorist| %>
      <div class="inline-flex h-12 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 px-3">
        <% if motorist.logo.present? %>
          <%= inline_svg_tag("logos/#{motorist.logo}", class: "h-8 w-20 fill-slate-700 text-slate-700") %>
        <% else %>
          <span class="text-xs font-semibold text-slate-600"><%= motorist.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</article>
