<section data-reveal-target="item" class="opacity-0 translate-y-4 transition-all duration-700 ease-out rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="flex items-center gap-2">
    <%= inline_svg_tag("icons/check-circle.svg", class: "h-5 w-5 stroke-slate-500 text-slate-500") %>
    <h2 class="text-base font-bold text-slate-900">Services et engagements</h2>
  </div>

  <div class="mt-4 w-full space-y-2">
    <% features.each do |feature| %>
      <article class="flex h-14 w-full items-center gap-3 rounded-xl border border-slate-200 bg-white px-3 transition hover:border-slate-300 hover:shadow-sm">
        <div class="<%= feature[:tone_class] %> inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border">
          <%= inline_svg_tag(feature[:icon], class: feature[:icon_class]) %>
        </div>

        <p class="text-sm font-semibold text-slate-700"><%= feature[:label] %></p>
      </article>
    <% end %>
  </div>
</section>
