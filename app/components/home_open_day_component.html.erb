<section class="mt-10">
  <div class="grid grid-cols-1 items-stretch gap-3 md:grid-cols-2 md:gap-4">
    <div class="relative h-full w-full rounded-3xl bg-gradient-to-r from-orange-300 via-amber-300 to-yellow-200 p-[5px] shadow-[0_0_16px_rgba(253,224,71,0.22)]">
      <div class="pointer-events-none absolute -inset-1 -z-10 rounded-[1.9rem] bg-gradient-to-r from-orange-300 via-amber-300 to-yellow-200 opacity-25 blur-[6px]"></div>
      <div class="relative h-full min-h-[320px] overflow-hidden rounded-[1.35rem]">
        <%= image_tag("magasin-02.jpeg", class: "absolute inset-0 h-full w-full object-cover") %>

        <div class="absolute inset-0 bg-slate-900/60"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-slate-900/40 via-slate-900/30 to-slate-900/70"></div>

        <div class="relative z-10 flex h-full flex-col justify-between p-6 md:p-10">
          <div>
            <p class="inline-flex items-center rounded-2xl border border-white/60 bg-white/95 px-3 py-1.5 text-[10px] font-bold tracking-tight text-slate-700 md:text-xs">
              SHOWROOM L'ARBRESLE
            </p>
            <h2 class="mt-2 text-2xl font-extrabold leading-[0.92] tracking-tight text-white md:text-5xl">
              Portes Ouvertes
            </h2>
            <p class="mt-2 text-[15px] font-extrabold leading-tight tracking-tight text-transparent bg-gradient-to-r from-orange-400 via-amber-300 to-rose-400 bg-clip-text md:text-[18px]">
              Tout l'univers de la maison à découvrir au showroom
            </p>
          </div>

          <div class="my-12">
            <p class="text-5xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-orange-400 via-amber-300 to-yellow-200 bg-clip-text [-webkit-text-fill-color:transparent] md:text-[5.5rem]">
              -20%
            </p>
            <p class="mt-1 text-lg font-bold leading-tight text-white md:text-3xl">sur tous nos produits</p>
          </div>

          <div class="relative w-full">
            <div class="hidden pointer-events-none absolute -left-24 -right-24 top-7 h-24 -rotate-[13deg] rounded-[1.75rem] bg-gradient-to-r from-orange-700/95 via-orange-500/95 to-orange-400/90 shadow-[0_20px_45px_-20px_rgba(249,115,22,0.95)] md:top-8 md:h-32"></div>

            <div class="relative z-10">
              <p class="text-lg font-bold tracking-tight text-white md:text-2xl">Vendredi 27 et Samedi 28 mars</p>
              <p class="text-sm font-medium text-slate-100 md:text-lg">Non-stop de 9h à 18h30</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="h-full w-full overflow-hidden rounded-3xl border border-slate-200 bg-gradient-to-b from-slate-100">
      <div class="flex h-full flex-col justify-between p-6 md:p-10">

        <div>
          <p class="inline-flex w-fit items-center rounded-2xl border border-orange-200 bg-orange-100 px-3 py-1.5 text-[10px] font-bold tracking-tight text-orange-500 md:text-xs">
            OFFRE SPÉCIALE
          </p>

          <h3 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900 md:text-5xl">Journées Privilège</h3>
          <p class="mt-2 text-[15px] font-extrabold leading-tight tracking-tight text-transparent bg-gradient-to-r from-orange-400 via-amber-300 to-rose-400 bg-clip-text md:text-[18px]">
            -20% sur tous nos produits
          </p>
        </div>


        <div class="my-12">

          <p class="text-2xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-orange-400 via-amber-300 to-yellow-200 bg-clip-text [-webkit-text-fill-color:transparent] md:text-[3rem]">
            Vendredi 27 et
          </p>
          <p class="mt-2 text-2xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-orange-400 via-amber-300 to-yellow-200 bg-clip-text [-webkit-text-fill-color:transparent] md:text-[3rem]">
            Samedi 28 Mars
          </p>
          <p class="mt-2 text-2xl font-extrabold leading-[0.9] tracking-tight text-transparent bg-gradient-to-r from-orange-400 via-amber-300 to-yellow-200 bg-clip-text [-webkit-text-fill-color:transparent] md:text-[2rem]">
            Non-stop de 9h à 18h30
          </p>

          <div class="grid grid-cols-3 gap-4 hidden">
            <% all_category_names.each do |category_name| %>
              <div class="rounded-xl bg-gradient-to-r from-orange-400 via-rose-400 to-amber-300 p-[1.5px]">
                <div class="flex min-h-[46px] items-center justify-center rounded-[11px] bg-white px-2 py-2 text-center text-[12px] font-bold leading-tight text-slate-800 md:text-sm">
                  <span><%= category_name %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div>
          <div class="text-xs font-semibold leading-[0.9] tracking-tight text-slate-700 md:text-[20px]">
            <p class="font-extrabold">35, rue des Martinets - L'Arbresle</p>
            <p class="mt-2 text-[11px] font-semibold text-slate-600 md:text-[20px]">Tél: 04 74 01 05 11</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
