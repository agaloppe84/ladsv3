<section class="mt-10">
  <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
    <div class="grid lg:grid-cols-[1fr_1fr]">
      <div class="relative min-h-[320px] overflow-hidden">
        <%= image_tag("magasin-02.jpeg", class: "absolute inset-0 h-full w-full object-cover") %>

        <div class="absolute inset-0 bg-slate-900/60"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-slate-900/40 via-slate-900/30 to-slate-900/70"></div>

        <div class="relative z-10 flex h-full flex-col justify-between p-6 md:p-10">
          <div>
            <p class="inline-flex items-center rounded-2xl border border-white/60 bg-white/95 px-4 py-2 text-[11px] font-bold tracking-tight text-slate-700 md:text-sm">
              SHOWROOM L'ARBRESLE
            </p>
            <h2 class="mt-6 text-2xl font-extrabold leading-[0.92] tracking-tight text-white md:text-5xl">
              Portes Ouvertes
            </h2>
          </div>

          <div class="relative w-full">
            <div class="pointer-events-none absolute -left-24 -right-24 top-7 h-24 -rotate-[13deg] rounded-[1.75rem] bg-gradient-to-r from-orange-700/95 via-orange-500/95 to-orange-400/90 shadow-[0_20px_45px_-20px_rgba(249,115,22,0.95)] md:top-8 md:h-32"></div>

            <div class="relative z-10">
              <p class="text-5xl font-extrabold leading-[0.9] tracking-tight text-transparent [-webkit-text-fill-color:transparent] [-webkit-text-stroke:1.5px_rgba(255,255,255,0.95)] md:text-[5.5rem]">
                -20%
              </p>
              <p class="mt-1 text-lg font-bold leading-tight text-white md:text-3xl">sur tous nos produits</p>
              <p class="mt-6 text-lg font-bold tracking-tight text-white md:text-2xl">Vendredi 27 et Samedi 28 mars</p>
              <p class="text-sm font-medium text-slate-100 md:text-lg">Non-stop de 9h à 18h30</p>
            </div>
          </div>
        </div>
      </div>

      <div class="">
        <div class="flex h-full flex-col bg-slate-100/80 p-6 md:p-10">
          <p class="inline-flex w-fit items-center rounded-2xl border border-orange-200 bg-orange-100 px-4 py-2 text-[11px] font-bold tracking-tight text-orange-500 md:text-sm">
            OFFRE SPÉCIALE
          </p>

          <h3 class="mt-6 text-2xl font-extrabold tracking-tight text-slate-900 md:text-5xl">Journées Privilège</h3>
          <p class="mt-2 text-base font-bold leading-tight text-slate-700 md:text-2xl">Vendredi 27 et Samedi 28 mars</p>
          <p class="text-sm font-semibold text-slate-600 md:text-xl">Non-stop de 9h à 18h30</p>

          <div class="relative mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white/90 p-4">
            <div class="pointer-events-none absolute inset-x-2 top-1/2 h-8 -translate-y-1/2 -rotate-[2deg] rounded-full bg-orange-100/70"></div>
            <p class="relative text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500">Univers exposés</p>

            <div class="relative mt-3 space-y-2">
              <% all_category_names.each_slice(3) do |category_group| %>
                <p class="flex flex-wrap items-center gap-x-2 text-[11px] font-extrabold uppercase tracking-[0.08em] md:text-xs">
                  <% category_group.each_with_index do |category_name, index| %>
                    <span class="<%= index.even? ? 'text-slate-800' : 'text-orange-700' %>"><%= category_name %></span>
                    <% unless index == category_group.size - 1 %>
                      <span class="text-orange-400/90">•</span>
                    <% end %>
                  <% end %>
                </p>
              <% end %>
            </div>
          </div>

          <div class="mt-6 grid grid-cols-2 gap-3">
            <% right_panel_visuals.each do |visual| %>
              <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-slate-200 bg-white">
                <% if visual[:range]&.dig(:image).present? %>
                  <%= cl_image_tag(visual[:range][:image].key, crop: :scale, class: "absolute inset-0 h-full w-full object-cover") %>
                <% else %>
                  <%= image_tag(visual[:fallback], class: "absolute inset-0 h-full w-full object-cover") %>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="mt-5 text-xs font-semibold leading-tight text-slate-700 md:text-lg">
            <p>35, rue des Martinets - L'Arbresle</p>
            <p>Tél: 04 74 01 05 11</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
